{
  "ConnectionStrings": {
    "DefaultConnection": "CONFIGURADO_VIA_AZURE_APP_SERVICE"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[STAGING] [{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} T:{TenantId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/staging-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "FocusNfe": {
    "IsProducao": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5174",
      "https://red-rock-0d2fb150f7-staging.azurestaticapps.net"
    ]
  },
  "ApplicationInsights": {
    "ConnectionString": "CONFIGURADO_VIA_AZURE_APP_SERVICE"
  }
}
