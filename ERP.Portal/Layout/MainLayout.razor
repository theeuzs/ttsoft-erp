@inherits LayoutComponentBase
@using ERP.Portal.Services
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (!Auth.LoggedIn)
{
    <ERP.Portal.Pages.Login />
}
else
{
    <div class="erp-shell">

        <div class="@(_open ? "overlay open" : "overlay")" @onclick="Fechar"></div>

        <header class="topbar">
            <span class="brand">🏗️ TTSoft ERP</span>
            <button class="hamburger" @onclick="Toggle">☰</button>
        </header>

        <nav class="@(_open ? "sidebar open" : "sidebar")">
            <div class="sidebar-logo">
                <div class="logo-text">🏗️ TTSoft</div>
                <div class="logo-sub">Portal Gerencial</div>
            </div>

            @foreach (var item in _menu)
            {
                <a href="@item.Url" class="nav-item" @onclick="Fechar">
                    <span class="nav-icon">@item.Icon</span>
                    <span>@item.Label</span>
                </a>
            }

            <div class="sidebar-footer">
                <div class="user-name">@Auth.Usuario</div>
                <div class="user-role">@Auth.Cargo</div>
                <button @onclick="ToggleDarkMode"
                        style="background:#334155; color:#94A3B8; border:none; padding:7px 14px;
                        border-radius:6px; cursor:pointer; font-size:12px; font-weight:600;
                        width:100%; margin-bottom:6px;">
                    @(_darkMode ? "☀️ Modo Claro" : "🌙 Modo Escuro")
                </button>
                <button class="btn-sair" @onclick="LogoutAsync">Sair</button>
            </div>
        </nav>

        <main class="content">
            @Body
        </main>

        <ERP.Portal.Pages.Chat />

    </div>
}

<style>
    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; }

    /* ── Shell ── */
    .erp-shell { display: flex; height: 100vh; overflow: hidden;
                 font-family: 'Segoe UI', system-ui, sans-serif; background: #F1F5F9; }

    /* ── Topbar (oculto no desktop) ── */
    .topbar { display: none; position: fixed; top: 0; left: 0; right: 0; z-index: 200;
              background: #1E293B; color: white; padding: 14px 16px;
              align-items: center; justify-content: space-between; height: 54px; }
    .topbar .brand  { font-size: 16px; font-weight: 800; color: #60A5FA; }
    .hamburger { background: none; border: none; color: white; font-size: 26px;
                 cursor: pointer; line-height: 1; padding: 0 4px; }

    /* ── Overlay mobile ── */
    .overlay { display: none; }
    .overlay.open { display: block; position: fixed; inset: 0;
                    background: rgba(0,0,0,.5); z-index: 150; }

    /* ── Sidebar ── */
    .sidebar { width: 220px; min-width: 220px; background: #1E293B; color: white;
               display: flex; flex-direction: column; overflow-y: auto; }
    .sidebar-logo { padding: 20px; border-bottom: 1px solid #334155; }
    .logo-text    { font-size: 20px; font-weight: 800; color: #60A5FA; }
    .logo-sub     { font-size: 11px; color: #94A3B8; margin-top: 2px; }

    .nav-item { display: flex; align-items: center; gap: 12px; padding: 13px 20px;
                color: #CBD5E1; text-decoration: none; font-size: 14px;
                transition: background .15s; }
    .nav-item:hover { background: #1E3A5F; color: #60A5FA; }
    .nav-icon { font-size: 18px; }

    .sidebar-footer { margin-top: auto; padding: 16px 20px;
                      border-top: 1px solid #334155; }
    .user-name { font-size: 13px; color: #CBD5E1; font-weight: 600; }
    .user-role { font-size: 11px; color: #64748B; margin-bottom: 8px; }
    .btn-sair  { background: #EF4444; color: white; border: none; padding: 7px 14px;
                 border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 600; }

    /* ── Conteúdo ── */
    .content { flex: 1; overflow-y: auto; padding: 28px; }

    /* ══ MOBILE ═══════════════════════════════════════════════ */
    @@media (max-width: 768px) {
        .topbar  { display: flex; }
        .content { padding: 12px; margin-top: 54px; }

        .sidebar { position: fixed; top: 54px; left: 0; bottom: 0; z-index: 160;
                   transform: translateX(-100%); transition: transform .25s ease;
                   width: 260px; min-width: 260px; }
        .sidebar.open { transform: translateX(0); }
        .sidebar-logo { display: none; }

        /* Tabelas com scroll */
        table  { display: block; overflow-x: auto; white-space: nowrap; font-size: 12px; }

        /* KPIs: 2 colunas */
        [style*="grid-template-columns:repeat(4"] {
            display: grid !important;
            grid-template-columns: 1fr 1fr !important;
            gap: 10px !important;
        }
        [style*="grid-template-columns:repeat(3"] {
            display: grid !important;
            grid-template-columns: 1fr 1fr !important;
            gap: 10px !important;
        }
        /* Painéis lado a lado viram coluna */
        [style*="grid-template-columns:1fr 1fr"] {
            display: flex !important;
            flex-direction: column !important;
            gap: 12px !important;
        }
        /* Filtros quebram linha */
        [style*="display:flex"][style*="flex-wrap"] { flex-wrap: wrap !important; }
    }
</style>

@code {
    private bool _open = false;

    private record MenuItem(string Icon, string Label, string Url);
    private readonly MenuItem[] _menu =
    [
        // ── Principal ─────────────────────────────────────────────────────────
        new("📊", "Dashboard",         "/dashboard"),
        new("🖥️", "PDV Web",            "/pdv"),
        new("📦", "Produtos",           "/produtos"),
        new("👤", "Clientes",           "/clientes"),
        new("💰", "Vendas",             "/vendas"),

        // ── Fiscal e Financeiro ───────────────────────────────────────────────
        new("🧾", "Notas Fiscais",      "/notas-fiscais"),
        new("🔄", "Devoluções",         "/devolucoes"),
        new("🪙", "Haver",              "/haver"),
        new("💳", "Financeiro",         "/financeiro"),
        new("💸", "Contas Pagar",       "/contas-pagar"),

        // ── Estoque e Compras ─────────────────────────────────────────────────
        new("🏪", "Estoque",            "/estoque"),
        new("📦", "Inventário",         "/inventario"),
        new("🛒", "Compras",            "/compras"),
        new("🛒", "Sugestão Compras",   "/sugestao-compras"),
        new("🚚", "Entregas",           "/entregas"),
        new("🏪", "Transferências",     "/transferencias"),

       // ── Vendas e CRM ──────────────────────────────────────────────────────────────
        new("📋", "Orçamentos",         "/orcamentos"),
        new("📞", "CRM / Follow-up",    "/crm"),
        new("🎯", "Metas",              "/metas"),
        new("🏗️", "Calculadora",        "/calculadora"),
        new("🤝", "Autoatend. Cliente", "/cliente"),

        // ── Relatórios e BI ───────────────────────────────────────────────────
        new("📄", "Relatórios",         "/relatorios"),
        new("📈", "BI / Análises",      "/bi"),

        // ── Gestão ───────────────────────────────────────────────────────────
        new("👔", "Cargos",             "/cargos"),
        new("🔍", "Auditoria",          "/auditoria"),

        // ── Painéis especiais ─────────────────────────────────────────────────
        new("📺", "Dashboard TV",       "/tv"),
        new("🚚", "App Motorista",      "/motorista"),

        // ── Roadmap ───────────────────────────────────────────────────────────
        new("🗺️", "Próximas Melhorias", "/roadmap"),
    ];

    private bool _darkMode = false;

    protected override async Task OnInitializedAsync()
    {
        await Auth.CarregarSessaoAsync();
        try
        {
            var tema = await JS.InvokeAsync<string>("initTheme");
            _darkMode = tema == "dark";
        }
        catch { }
    }

    private async Task ToggleDarkMode()
    {
        var novoTema = await JS.InvokeAsync<string>("toggleDarkMode");
        _darkMode = novoTema == "dark";
    }

    private void Toggle() => _open = !_open;
    private void Fechar() => _open = false;

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }
}
