@page "/vendas"
@using ERP.Portal.Services
@inject ApiClient Api

<div style="padding:0 0 24px;">
    <h2 style="color:#1E293B; font-weight:800; margin:0 0 24px;">💰 Vendas</h2>

    <div style="background:white; border-radius:12px; padding:16px; margin-bottom:16px;
         box-shadow:0 2px 8px rgba(0,0,0,.06); display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <div>
            <label style="font-size:11px; font-weight:700; color:#64748B; display:block; margin-bottom:4px;">DE</label>
            <input type="date" @bind="_de"
                   style="padding:10px; border:1px solid #E2E8F0; border-radius:8px; font-size:14px;"/>
        </div>
        <div>
            <label style="font-size:11px; font-weight:700; color:#64748B; display:block; margin-bottom:4px;">ATÉ</label>
            <input type="date" @bind="_ate"
                   style="padding:10px; border:1px solid #E2E8F0; border-radius:8px; font-size:14px;"/>
        </div>
        <button @onclick="CarregarAsync"
                style="background:#1E62A6; color:white; border:none; padding:10px 20px;
                border-radius:8px; font-weight:700; cursor:pointer; height:42px;">
            🔍 Filtrar
        </button>

        @if (_vendas != null)
        {
            <div style="margin-left:auto; display:flex; gap:16px;">
                <div style="text-align:right;">
                    <div style="font-size:11px; color:#94A3B8; font-weight:600;">TOTAL PERÍODO</div>
                    <div style="font-size:20px; font-weight:800; color:#27AE60;">
                        @_vendas.Sum(v => v.Total).ToString("C")
                    </div>
                </div>
                <div style="text-align:right;">
                    <div style="font-size:11px; color:#94A3B8; font-weight:600;">QTD VENDAS</div>
                    <div style="font-size:20px; font-weight:800; color:#1E62A6;">@_vendas.Length</div>
                </div>
                <div style="text-align:right;">
                    <div style="font-size:11px; color:#94A3B8; font-weight:600;">TICKET MÉDIO</div>
                    <div style="font-size:20px; font-weight:800; color:#8B5CF6;">
                        @(_vendas.Length > 0 ? (_vendas.Sum(v => v.Total) / _vendas.Length).ToString("C") : "—")
                    </div>
                </div>
            </div>
        }
    </div>

    <div style="background:white; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,.06); overflow:hidden;">
        @if (_loading)
        {
            <div style="text-align:center; padding:60px; color:#94A3B8;">Carregando vendas...</div>
        }
        else if (_vendas?.Length == 0)
        {
            <div style="text-align:center; padding:60px; color:#94A3B8;">Nenhuma venda no período.</div>
        }
        else
        {
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:#F8FAFC; border-bottom:2px solid #E2E8F0;">
                        <th style="@Th">DATA</th>
                        <th style="@Th">CLIENTE</th>
                        <th style="@Th">VENDEDOR</th>
                        <th style="@Th; text-align:right;">SUBTOTAL</th>
                        <th style="@Th; text-align:right;">DESCONTO</th>
                        <th style="@Th; text-align:right;">TOTAL</th>
                        <th style="@Th; text-align:center;">STATUS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in _vendas!)
                    {
                        var statusCor = v.Status == "NotaEmitida" ? "#27AE60"
                                      : v.Status == "Cancelada" ? "#EF4444" : "#F59E0B";
                        var statusBg  = v.Status == "NotaEmitida" ? "#D1FAE5"
                                      : v.Status == "Cancelada" ? "#FEE2E2" : "#FEF3C7";
                        <tr style="border-bottom:1px solid #F1F5F9;"
                            onmouseover="this.style.background='#F8FAFC'"
                            onmouseout="this.style.background=''">
                            <td style="@Td; color:#64748B; font-size:12px;">
                                @v.SaleDate.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td style="@Td; font-weight:600; color:#1E293B;">
                                @(v.CustomerName ?? "Consumidor Final")
                            </td>
                            <td style="@Td; color:#64748B;">@(v.SellerName ?? "—")</td>
                            <td style="@Td; text-align:right; color:#64748B;">@v.Subtotal.ToString("C")</td>
                            <td style="@Td; text-align:right; color:#EF4444;">
                                @((v.Subtotal - v.Total) > 0 ? $"-{(v.Subtotal - v.Total).ToString("C")}" : "—")
                            </td>
                            <td style="@Td; text-align:right; font-weight:800; color:#1E293B;">
                                @v.Total.ToString("C")
                            </td>
                            <td style="@Td; text-align:center;">
                                <span style="background:@statusBg; color:@statusCor;
                                      padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700;">
                                    @(v.Status switch { "NotaEmitida" => "Com Nota", "Cancelada" => "Cancelada", "SemNota" => "Sem Nota", _ => v.Status })
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private VendaItem[]? _vendas;
    private DateTime _de  = DateTime.Today.AddDays(-30);
    private DateTime _ate = DateTime.Today;
    private bool _loading = true;

    private const string Th = "padding:12px 16px; font-size:11px; font-weight:700; color:#64748B; text-align:left;";
    private const string Td = "padding:12px 16px; font-size:13px;";

    protected override async Task OnInitializedAsync() => await CarregarAsync();

    private async Task CarregarAsync()
    {
        _loading = true;
        // 👇 CORREÇÃO: Adiciona 1 dia na data final para incluir tudo até às 23:59:59 do dia _ate
        var ateFimDoDia = _ate.AddDays(1);
        var url = $"api/Sales?from={_de:yyyy-MM-dd}&to={ateFimDoDia:yyyy-MM-dd}";
        
        _vendas  = await Api.GetAsync<VendaItem[]>(url) ?? [];
        _loading = false;
    }

    public class VendaItem
    {
        public Guid Id { get; set; }
        public DateTime SaleDate { get; set; }
        public DateTime DataVenda { set { SaleDate = value; } }

        public string? CustomerName { get; set; }
        public string ClienteNome { set { CustomerName = value; } }

        public string? SellerName { get; set; }
        public string VendedorNome { set { SellerName = value; } }

        public decimal Total { get; set; }
        public decimal ValorTotal { set { Total = value; } }

        public decimal Subtotal { get; set; }
        public decimal ValorSubtotal { set { Subtotal = value; } }

        public string Status { get; set; } = "";
    }
}