@page "/cargos"
@using ERP.Portal.Services
@inject ApiClient Api

<div style="padding:0 0 24px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
        <div>
            <h2 style="color:#1E293B; font-weight:800; margin:0;">👔 Cargos e Permissões</h2>
            <p style="color:#94A3B8; font-size:13px; margin:4px 0 0;">
                Gerencie os perfis de acesso do sistema
            </p>
        </div>
    </div>

    @if (_loading)
    {
        <div style="text-align:center; padding:60px; color:#94A3B8;">Carregando...</div>
    }
    else
    {
        <div style="display:grid; grid-template-columns:280px 1fr; gap:16px;">

            <!-- Lista de cargos -->
            <div style="background:white; border-radius:12px; padding:16px;
                 box-shadow:0 2px 8px rgba(0,0,0,.06);">
                <h3 style="font-size:13px; font-weight:700; color:#64748B; margin:0 0 12px;">CARGOS</h3>
                @foreach (var cargo in _cargos ?? [])
                {
                    <div @onclick="() => SelecionarCargo(cargo)"
                         style="padding:12px; border-radius:8px; cursor:pointer; margin-bottom:4px;
                         background:@(_cargoSelecionado?.Id == cargo.Id ? "#EFF6FF" : "transparent");
                         border:2px solid @(_cargoSelecionado?.Id == cargo.Id ? "#1E62A6" : "transparent");">
                        <div style="font-weight:700; font-size:14px; color:#1E293B;">@cargo.Name</div>
                        <div style="font-size:11px; color:#94A3B8; margin-top:2px;">
                            @(cargo.PermissionCodes?.Length ?? 0) permissões
                        </div>
                    </div>
                }
            </div>

            <!-- Permissões do cargo selecionado -->
            @if (_cargoSelecionado != null)
            {
                <div style="background:white; border-radius:12px; padding:24px;
                     box-shadow:0 2px 8px rgba(0,0,0,.06);">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                        <h3 style="font-size:16px; font-weight:800; color:#1E293B; margin:0;">
                            Permissões — @_cargoSelecionado.Name
                        </h3>
                        <button @onclick="SalvarPermissoesAsync"
                                style="background:#1E62A6; color:white; border:none; padding:8px 20px;
                                border-radius:8px; font-weight:700; cursor:pointer; font-size:13px;">
                            💾 Salvar
                        </button>
                    </div>

                    @foreach (var grupo in _permissoes?.GroupBy(p => p.Category) ?? [])
                    {
                        <div style="margin-bottom:20px;">
                            <h4 style="font-size:12px; font-weight:700; color:#64748B; margin:0 0 8px;
                                 text-transform:uppercase; border-bottom:1px solid #F1F5F9; padding-bottom:6px;">
                                @grupo.Key
                            </h4>
                            <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:6px;">
                                @foreach (var perm in grupo)
                                {
                                    var ativa = _permissoesAtivas.Contains(perm.Name);
                                    <label style="display:flex; align-items:center; gap:8px;
                                           padding:8px 10px; border-radius:6px; cursor:pointer;
                                           background:@(ativa ? "#F0FDF4" : "#F8FAFC");
                                           border:1px solid @(ativa ? "#27AE60" : "#E2E8F0");">
                                        <input type="checkbox" checked="@ativa"
                                               @onchange="e => TogglePermissao(perm.Name, (bool)(e.Value ?? false))"
                                               style="width:16px; height:16px; cursor:pointer;"/>
                                        <div>
                                            <div style="font-size:13px; font-weight:600; color:#1E293B;">@perm.DisplayName</div>
                                            <div style="font-size:11px; color:#94A3B8; font-family:monospace;">@perm.Name</div>
                                        </div>
                                    </label>
                                }
                            </div>
                        </div>
                    }

                    @if (_mensagem != null)
                    {
                        <div style="padding:12px; background:#D1FAE5; border-radius:8px;
                             font-size:13px; color:#065F46; font-weight:600; margin-top:12px;">
                            @_mensagem
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="background:white; border-radius:12px; padding:60px;
                     box-shadow:0 2px 8px rgba(0,0,0,.06); text-align:center;">
                    <div style="font-size:48px; margin-bottom:12px;">👔</div>
                    <div style="font-size:15px; color:#64748B;">Selecione um cargo para editar suas permissões</div>
                </div>
            }
        </div>
    }
</div>

@code {
    private CargoDto[]?    _cargos;
    private PermissaoDto[]? _permissoes;
    private CargoDto?      _cargoSelecionado;
    private HashSet<string> _permissoesAtivas = new();
    private bool    _loading = true;
    private string? _mensagem;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            Task.Run(async () => _cargos     = await Api.GetAsync<CargoDto[]>("api/Cargos")),
            Task.Run(async () => _permissoes = await Api.GetAsync<PermissaoDto[]>("api/Cargos/permissoes"))
        );
        _loading = false;
    }

    private void SelecionarCargo(CargoDto cargo)
    {
        _cargoSelecionado = cargo;
        _permissoesAtivas = cargo.PermissionCodes?.ToHashSet() ?? new();
        _mensagem         = null;
    }

    private void TogglePermissao(string nome, bool ativa)
    {
        if (ativa) _permissoesAtivas.Add(nome);
        else       _permissoesAtivas.Remove(nome);
    }

    private async Task SalvarPermissoesAsync()
    {
        if (_cargoSelecionado == null) return;
        // API espera PermissionIds (Guids), não codes — mapear via _permissoes
        var ids = _permissoes?
            .Where(p => _permissoesAtivas.Contains(p.Code))
            .Select(p => p.Id)
            .ToArray() ?? [];
        var resp = await Api.PutAsync("api/Cargos", new
        {
            Id                   = _cargoSelecionado.Id,
            MaxDiscountPercentage = 0m,
            MaxSangriaValue      = 0m,
            PermissionIds        = ids
        });
        if (resp.IsSuccessStatusCode)
        {
            _mensagem = "✅ Permissões salvas com sucesso!";
            _cargos   = await Api.GetAsync<CargoDto[]>("api/Cargos");
            _cargoSelecionado = _cargos?.FirstOrDefault(c => c.Id == _cargoSelecionado.Id);
            await Task.Delay(3000);
            _mensagem = null;
        }
    }

    class CargoDto
    {
        public Guid     Id              { get; set; }
        public string   Name            { get; set; } = "";
        // API retorna permissionCodes (lista de strings com os códigos)
        public string[]? PermissionCodes { get; set; }
        // Alias para o portal usar como Permissions
        public string[]? Permissions    { get => PermissionCodes; set { PermissionCodes = value; } }
    }
    class PermissaoDto
    {
        // API retorna: code, description, group, id
        public Guid   Id          { get; set; }
        public string Code        { get; set; } = "";
        public string Description { get; set; } = "";
        public string Group       { get; set; } = "";
        // Aliases para o template continuar funcionando
        public string Name        { get => Code; set { Code = value; } }
        public string DisplayName { get => Description; set { Description = value; } }
        public string Category    { get => Group; set { Group = value; } }
    }
}
