@page "/financeiro"
@using ERP.Portal.Services
@inject ApiClient Api
@inject IJSRuntime JS

<div style="padding:0 0 24px;">
    <h2 style="color:#1E293B; font-weight:800; margin:0 0 24px;">💳 Financeiro</h2>

    @if (_resumo != null)
    {
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px;">
            <KpiCard Titulo="Total Pendente"     Valor="@_resumo.TotalPendente.ToString("C")"  Icone="⏳" Cor="#F59E0B"/>
            <KpiCard Titulo="Total Vencido"      Valor="@_resumo.TotalVencido.ToString("C")"   Icone="🔴" Cor="#EF4444"/>
            <KpiCard Titulo="Clientes Devedores" Valor="@_resumo.QtdClientes.ToString()"       Icone="👤" Cor="#1E62A6"/>
        </div>
    }

    <div style="display:flex; gap:4px; margin-bottom:16px;">
        @foreach (var (tab, label) in new[]{("pendentes","⏳ Pendentes"),("inadimplentes","🔴 Inadimplentes")})
        {
            <button @onclick="@(() => MudarTab(tab))"
                    style="padding:10px 20px; border:none; border-radius:8px; font-weight:700;
                    font-size:14px; cursor:pointer;
                    background:@(_tab == tab ? "#1E62A6" : "#F1F5F9");
                    color:@(_tab == tab ? "white" : "#64748B");">
                @label
            </button>
        }
    </div>

    <div style="background:white; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,.06); overflow:hidden;">
        @if (_loading)
        {
            <div style="text-align:center; padding:60px; color:#94A3B8;">Carregando...</div>
        }
        else if (_contas?.Length == 0)
        {
            <div style="text-align:center; padding:60px; color:#94A3B8;">Nenhuma conta encontrada.</div>
        }
        else
        {
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:#F8FAFC;">
                        <th style="@Th">Cliente</th>
                        <th style="@Th">Descrição</th>
                        <th style="@Th; text-align:right;">Valor</th>
                        <th style="@Th; text-align:right;">Recebido</th>
                        <th style="@Th">Vencimento</th>
                        <th style="@Th">Parcela</th>
                        <th style="@Th; text-align:center;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _contas ?? [])
                    {
                        var saldo = c.ValorTotal - c.ValorRecebido;
                        var vencido = c.DataVencimento < DateTime.Today && c.Status == "Pendente";
                        <tr style="border-top:1px solid #F1F5F9; background:@(vencido ? "#FFF8F8" : "white");">
                            <td style="@Td; font-weight:600;">@(c.Customer?.Name ?? "—")</td>
                            <td style="@Td; color:#64748B; font-size:12px;">@c.Descricao</td>
                            <td style="@Td; text-align:right; font-weight:700; color:#1E293B;">@c.ValorTotal.ToString("C")</td>
                            <td style="@Td; text-align:right;">
                                @if (c.ValorRecebido > 0)
                                {
                                    <span style="color:#16A34A; font-weight:600;">@c.ValorRecebido.ToString("C")</span>
                                } else {
                                    <span style="color:#94A3B8;">—</span>
                                }
                            </td>
                            <td style="@Td; color:@(vencido ? "#EF4444" : "#1E293B"); font-weight:@(vencido ? "700" : "400");">
                                @c.DataVencimento.ToString("dd/MM/yyyy")
                                @if (vencido) { <span style="font-size:10px;"> ⚠️</span> }
                            </td>
                            <td style="@Td; text-align:center; color:#64748B;">
                                @if (c.TotalParcelas > 1)
                                {
                                    <span>@c.NumeroParcela/@c.TotalParcelas</span>
                                } else {
                                    <span style="color:#94A3B8;">—</span>
                                }
                            </td>
                            <td style="@Td; text-align:center;">
                                <div style="display:flex; gap:4px; justify-content:center; flex-wrap:wrap;">
                                    <button @onclick="() => DarBaixaTotal(c.Id)"
                                            style="background:#D1FAE5; color:#065F46; border:none;
                                                   padding:4px 8px; border-radius:6px; font-size:11px;
                                                   font-weight:700; cursor:pointer;"
                                            title="Quitar parcela">✓ Pago</button>
                                    <button @onclick="() => CobrarWhatsApp(c)"
                                            style="background:#D1FAE5; color:#128C7E; border:none;
                                                   padding:4px 8px; border-radius:6px; font-size:11px;
                                                   font-weight:700; cursor:pointer;"
                                            title="Cobrar via WhatsApp Web">💬</button>
                                    @if (!string.IsNullOrEmpty(c.BoletoUrl))
                                    {
                                        <a href="@c.BoletoUrl" target="_blank"
                                           style="background:#EFF6FF; color:#1E62A6; border:none;
                                                  padding:4px 8px; border-radius:6px; font-size:11px;
                                                  font-weight:700; cursor:pointer; text-decoration:none;"
                                           title="Abrir boleto">🎫 Ver</a>
                                    }
                                    else
                                    {
                                        <button @onclick="() => GerarBoletoAsync(c.Id)"
                                                disabled="@_gerandoBoleto"
                                                style="background:#FEF3C7; color:#92400E; border:none;
                                                       padding:4px 8px; border-radius:6px; font-size:11px;
                                                       font-weight:700; cursor:pointer;
                                                       opacity:@(_gerandoBoleto ? "0.5" : "1")"
                                                title="Gerar boleto via Asaas">🎫 Boleto</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private ContaItem[]?      _contas;
    private ResumoFinanceiro? _resumo;
    private string            _tab      = "pendentes";
    private bool              _loading  = true;
    private bool              _gerandoBoleto = false;

    private const string Th = "padding:12px 16px; font-size:11px; font-weight:700; color:#64748B; text-align:left;";
    private const string Td = "padding:12px 16px; font-size:13px;";

    protected override async Task OnInitializedAsync()
    {
        _resumo = await Api.GetAsync<ResumoFinanceiro>("api/contas-receber/resumo");
        await CarregarContasAsync();
    }

    private async Task MudarTab(string tab) { _tab = tab; await CarregarContasAsync(); }

    private async Task CarregarContasAsync()
    {
        _loading = true;
        var url = _tab == "inadimplentes"
            ? "api/contas-receber/inadimplentes"
            : "api/contas-receber/pendentes";
        _contas  = await Api.GetAsync<ContaItem[]>(url) ?? [];
        _loading = false;
    }

    // ── Dar baixa total ───────────────────────────────────────────────────────
    private async Task DarBaixaTotal(Guid contaId)
    {
        var resp = await Api.PostAsync($"api/contas-receber/{contaId}/baixa-total", new { });
        if (resp.IsSuccessStatusCode)
        {
            _resumo = await Api.GetAsync<ResumoFinanceiro>("api/contas-receber/resumo");
            await CarregarContasAsync();
        }
    }

    // ── Gerar boleto via Asaas ────────────────────────────────────────────────
    private async Task GerarBoletoAsync(Guid id)
    {
        _gerandoBoleto = true;
        try
        {
            var resultado = await Api.PostAsync($"api/contas-receber/{id}/gerar-boleto", new { });
            if (resultado.IsSuccessStatusCode)
            {
                await CarregarContasAsync();
                await JS.InvokeVoidAsync("alert", "✅ Boleto gerado! Clique em 🎫 Ver para abrir.");
            }
            else
            {
                var body = await resultado.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Erro ao gerar boleto: {body}");
            }
        }
        finally { _gerandoBoleto = false; }
    }

    // ── Cobrança via WhatsApp ─────────────────────────────────────────────────
    private async Task CobrarWhatsApp(ContaItem conta)
    {
        var saldo = conta.ValorTotal - conta.ValorRecebido;
        var dias  = (DateTime.Today - conta.DataVencimento).Days;
        var texto = $"Olá, {conta.Customer?.Name ?? "cliente"}! 👋\n\n" +
                    $"Identificamos uma parcela em aberto:\n" +
                    $"📋 {conta.Descricao}\n" +
                    $"💰 *Valor: {saldo:C}*\n" +
                    $"📅 Venceu há {dias} dia(s) ({conta.DataVencimento:dd/MM/yyyy})\n\n" +
                    "Acesse nossa loja para regularizar. Estamos à disposição! 😊";

        var enc    = Uri.EscapeDataString(texto);
        var phone  = conta.Customer?.Phone ?? "";
        string url;

        if (!string.IsNullOrEmpty(phone))
        {
            var numero = new string(phone.Where(char.IsDigit).ToArray());
            if (!numero.StartsWith("55")) numero = "55" + numero;
            url = $"https://wa.me/{numero}?text={enc}";
        }
        else
            url = $"https://web.whatsapp.com/send?text={enc}";

        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    // ── DTOs ──────────────────────────────────────────────────────────────────
    class ResumoFinanceiro
    {
        public decimal TotalPendente { get; set; }
        public decimal TotalVencido  { get; set; }
        public int     QtdClientes   { get; set; }
    }

    class ContaItem
    {
        public Guid         Id             { get; set; }
        public Guid         CustomerId     { get; set; }
        public string       Descricao      { get; set; } = "";
        public decimal      ValorTotal     { get; set; }
        public decimal      ValorRecebido  { get; set; }
        public DateTime     DataVencimento { get; set; }
        public string       Status         { get; set; } = "";
        public int          NumeroParcela  { get; set; }
        public int          TotalParcelas  { get; set; }
        public ClienteInfo? Customer       { get; set; }
        public string?      BoletoUrl      { get; set; }
        public string?      AsaasPaymentId { get; set; }
    }

    class ClienteInfo
    {
        public string  Name  { get; set; } = "";
        public string? Phone { get; set; }
    }
}
