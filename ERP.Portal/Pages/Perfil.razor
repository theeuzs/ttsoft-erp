@page "/perfil"
@using ERP.Portal.Services
@inject ApiClient Api
@inject ERP.Portal.Services.AuthService Auth

<div style="padding:0 0 32px; max-width:560px;">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
        <div style="font-size:32px;">👤</div>
        <div>
            <h2 style="color:#1E293B; font-weight:800; margin:0;">Meu Perfil</h2>
            <p style="color:#94A3B8; font-size:13px; margin:4px 0 0;">
                Dados da sua conta de acesso
            </p>
        </div>
    </div>

    @if (_loading)
    {
        <div style="text-align:center; padding:60px; color:#94A3B8;">Carregando...</div>
    }
    else
    {
        @* Banner de alerta se não tem email *@
        @if (string.IsNullOrEmpty(_emailAtual))
        {
            <div style="background:#FFF7ED; border:1px solid #FED7AA; border-radius:10px;
                        padding:14px 18px; margin-bottom:20px; display:flex; gap:12px; align-items:flex-start;">
                <div style="font-size:20px; flex-shrink:0;">⚠️</div>
                <div>
                    <div style="font-weight:700; color:#C2410C; font-size:14px; margin-bottom:4px;">
                        E-mail não cadastrado
                    </div>
                    <div style="font-size:13px; color:#92400E; line-height:1.5;">
                        Sem e-mail cadastrado você não consegue recuperar a senha caso a esqueça.
                        Adicione um e-mail abaixo.
                    </div>
                </div>
            </div>
        }

        <div style="background:white; border-radius:12px; padding:28px;
                    box-shadow:0 2px 8px rgba(0,0,0,.06);">

            @if (!string.IsNullOrEmpty(_erro))
            {
                <div style="background:#FEF2F2; border:1px solid #FECACA; border-radius:8px;
                            padding:12px 16px; color:#DC2626; margin-bottom:16px; font-size:13px;">
                    ❌ @_erro
                </div>
            }
            @if (_salvo)
            {
                <div style="background:#F0FDF4; border:1px solid #BBF7D0; border-radius:8px;
                            padding:12px 16px; color:#16A34A; margin-bottom:16px; font-size:13px;">
                    ✅ E-mail atualizado com sucesso!
                </div>
            }

            @* Campos readonly *@
            <div style="margin-bottom:16px;">
                <label style="font-size:12px; font-weight:600; color:#64748B; display:block; margin-bottom:6px;">
                    NOME
                </label>
                <div style="padding:10px 12px; background:#F8FAFC; border:1px solid #E2E8F0;
                            border-radius:8px; font-size:14px; color:#475569;">
                    @_nome
                </div>
            </div>

            <div style="margin-bottom:16px;">
                <label style="font-size:12px; font-weight:600; color:#64748B; display:block; margin-bottom:6px;">
                    USUÁRIO
                </label>
                <div style="padding:10px 12px; background:#F8FAFC; border:1px solid #E2E8F0;
                            border-radius:8px; font-size:14px; color:#475569;">
                    @_username
                </div>
            </div>

            @* E-mail editável *@
            <div style="margin-bottom:20px;">
                <label style="font-size:12px; font-weight:600; color:#64748B; display:block; margin-bottom:6px;">
                    E-MAIL DE RECUPERAÇÃO
                </label>
                <input @bind="_emailNovo"
                       type="email"
                       placeholder="contato@suaempresa.com.br"
                       style="width:100%; padding:10px 12px; border:1px solid #CBD5E1;
                              border-radius:8px; font-size:14px; box-sizing:border-box;" />
                <div style="font-size:11px; color:#94A3B8; margin-top:4px;">
                    Usado para recuperar a senha caso você a esqueça.
                </div>
            </div>

            <button @onclick="SalvarEmailAsync" disabled="@_salvando"
                    style="width:100%; background:#1E62A6; color:white; border:none;
                           padding:11px; border-radius:8px; font-size:14px;
                           font-weight:700; cursor:pointer;">
                @(_salvando ? "Salvando..." : "💾 SALVAR E-MAIL")
            </button>
        </div>

        @* Link para trocar senha *@
        <div style="margin-top:16px; text-align:center;">
            <a href="/trocar-senha" style="font-size:13px; color:#64748B; text-decoration:underline;">
                Alterar senha
            </a>
        </div>
    }
</div>

@code {
    private bool    _loading  = true;
    private bool    _salvando = false;
    private bool    _salvo    = false;
    private string  _nome     = "";
    private string  _username = "";
    private string? _emailAtual;
    private string  _emailNovo = "";
    private string? _erro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var perfil = await Api.GetAsync<PerfilDto>("api/auth/perfil");
            if (perfil != null)
            {
                _nome      = perfil.Name;
                _username  = perfil.Username;
                _emailAtual = perfil.Email;
                _emailNovo  = perfil.Email ?? "";
            }
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task SalvarEmailAsync()
    {
        _erro    = null;
        _salvo   = false;

        if (string.IsNullOrWhiteSpace(_emailNovo) || !_emailNovo.Contains('@'))
        {
            _erro = "Informe um e-mail válido.";
            return;
        }

        _salvando = true;
        try
        {
            await Api.PutAsync("api/auth/perfil/email", new { Email = _emailNovo });
            _emailAtual = _emailNovo;
            _salvo = true;
            await Task.Delay(3000);
            _salvo = false;
        }
        catch (Exception ex)
        {
            _erro = ex.Message;
        }
        finally { _salvando = false; }
    }

    private class PerfilDto
    {
        public Guid    Id       { get; set; }
        public string  Name     { get; set; } = "";
        public string  Username { get; set; } = "";
        public string? Email    { get; set; }
    }
}
