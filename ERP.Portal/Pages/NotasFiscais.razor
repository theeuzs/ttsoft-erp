@page "/notas-fiscais"
@using ERP.Portal.Services
@inject ApiClient Api
@inject IJSRuntime JS

<div style="padding:0 0 24px;">

    @if (_toast != null)
    {
        <div style="position:fixed; top:20px; right:20px; z-index:9999;
                    background:@_toastBg; color:white; padding:14px 20px; border-radius:10px;
                    box-shadow:0 8px 24px rgba(0,0,0,.20); font-weight:600; font-size:14px;
                    display:flex; align-items:center; gap:10px; min-width:280px;">
            <span>@_toast</span>
            <button @onclick="() => _toast = null"
                    style="margin-left:auto; background:transparent; border:none; color:white;
                           font-size:18px; cursor:pointer;">×</button>
        </div>
    }

    <!-- Modal emitir nota de venda existente -->
    @if (_modalEmitirVendaId != null)
    {
        <div style="position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:200;
                    display:flex; align-items:center; justify-content:center;">
            <div style="background:white; border-radius:16px; padding:28px; max-width:420px;
                        width:90%; box-shadow:0 20px 60px rgba(0,0,0,.3);">
                <div style="font-size:16px; font-weight:800; color:#1E293B; margin-bottom:6px;">
                    🧾 Emitir nota para venda #@_modalEmitirNumero
                </div>
                <div style="font-size:13px; color:#94A3B8; margin-bottom:20px;">
                    Escolha o tipo de documento fiscal a emitir.
                </div>
                <div style="display:flex; flex-direction:column; gap:10px;">
                    <button @onclick="EmitirNfceModal"
                            disabled="@_emitindo"
                            style="padding:14px; background:#1E62A6; color:white; border:none;
                                   border-radius:10px; font-weight:700; cursor:pointer; font-size:14px;
                                   text-align:left; display:flex; align-items:center; gap:10px;">
                        <span style="font-size:20px;">📱</span>
                        <div>
                            <div>NFC-e — Nota Fiscal do Consumidor</div>
                            <div style="font-size:11px; opacity:.8;">Emissão imediata · sem dados do tomador</div>
                        </div>
                    </button>
                    <button @onclick="EmitirNfeModal"
                            disabled="@_emitindo"
                            style="padding:14px; background:#7C3AED; color:white; border:none;
                                   border-radius:10px; font-weight:700; cursor:pointer; font-size:14px;
                                   text-align:left; display:flex; align-items:center; gap:10px;">
                        <span style="font-size:20px;">📄</span>
                        <div>
                            <div>NF-e — Nota Fiscal Eletrônica</div>
                            <div style="font-size:11px; opacity:.8;">Para CNPJ · requer dados completos do cliente</div>
                        </div>
                    </button>
                </div>
                @if (_emitindo)
                {
                    <div style="text-align:center; margin-top:16px; color:#94A3B8; font-size:13px;">
                        ⏳ Emitindo nota, aguarde...
                    </div>
                }
                <button @onclick="FecharModalEmitir"
                        style="width:100%; margin-top:16px; background:#F1F5F9; border:none;
                               padding:12px; border-radius:8px; font-weight:600; cursor:pointer;
                               color:#64748B; font-size:13px;">
                    Cancelar
                </button>
            </div>
        </div>
    }

    <!-- Cabeçalho -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
        <div>
            <h2 style="color:#1E293B; font-weight:800; margin:0;">🧾 Notas Fiscais</h2>
            <p style="color:#94A3B8; font-size:13px; margin:4px 0 0;">
                Gerencie NFC-e e NF-e emitidas
            </p>
        </div>
        <div style="display:flex; gap:10px;">
            <button @onclick="CarregarNotasAsync"
                    style="background:#F1F5F9; color:#64748B; border:1px solid #E2E8F0;
                           padding:10px 16px; border-radius:8px; cursor:pointer; font-weight:600; font-size:13px;">
                🔄 Atualizar
            </button>
            <button @onclick="AbrirEmitirDeVenda"
                    style="background:#1E62A6; color:white; border:none; padding:10px 18px;
                           border-radius:8px; cursor:pointer; font-weight:700; font-size:13px;">
                + Emitir de Venda
            </button>
        </div>
    </div>

    <!-- Filtros -->
    <div style="background:white; border-radius:12px; padding:16px; margin-bottom:20px;
                box-shadow:0 2px 8px rgba(0,0,0,.06); display:flex; gap:12px; flex-wrap:wrap;">
        <input @bind="_filtroNumero" placeholder="🔍 Número ou tomador..."
               style="flex:1; min-width:180px; padding:9px 14px; border:1px solid #E2E8F0;
                      border-radius:8px; font-size:13px;"/>
        <select @bind="_filtroStatus"
                style="padding:9px 14px; border:1px solid #E2E8F0; border-radius:8px;
                       font-size:13px; background:white; min-width:140px;">
            <option value="">Todos os status</option>
            <option value="Autorizado">✅ Autorizado</option>
            <option value="Pendente">⏳ Pendente</option>
            <option value="Cancelado">❌ Cancelado</option>
            <option value="Erro">⚠ Erro</option>
        </select>
        <input type="date" @bind="_filtroDe"
               style="padding:9px 14px; border:1px solid #E2E8F0; border-radius:8px; font-size:13px;"/>
        <input type="date" @bind="_filtroAte"
               style="padding:9px 14px; border:1px solid #E2E8F0; border-radius:8px; font-size:13px;"/>
        <button @onclick="CarregarNotasAsync"
                style="background:#1E62A6; color:white; border:none; padding:9px 18px;
                       border-radius:8px; font-weight:700; cursor:pointer; font-size:13px;">
            Filtrar
        </button>
    </div>

    <!-- Tabela -->
    <div style="background:white; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,.06); overflow:hidden;">
        @if (_loading)
        {
            <div style="text-align:center; padding:60px; color:#94A3B8;">
                <div style="font-size:32px; margin-bottom:8px;">⏳</div>
                Carregando notas...
            </div>
        }
        else if (_notas.Count == 0)
        {
            <div style="text-align:center; padding:60px; color:#94A3B8;">
                <div style="font-size:40px; margin-bottom:12px;">🧾</div>
                Nenhuma nota encontrada para os filtros selecionados.
            </div>
        }
        else
        {
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:#F8FAFC; border-bottom:2px solid #E2E8F0;">
                        <th style="@Th">Nº NOTA</th>
                        <th style="@Th">DATA</th>
                        <th style="@Th">TOMADOR</th>
                        <th style="@Th; text-align:right;">VALOR</th>
                        <th style="@Th; text-align:center;">STATUS</th>
                        <th style="@Th; text-align:center;">AÇÕES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var nota in NotasFiltradas)
                    {
                        var (bgStatus, corStatus, txStatus) = nota.Status switch
                        {
                            "Autorizado" => ("#D1FAE5", "#065F46", "✅ Autorizado"),
                            "Cancelado"  => ("#FEE2E2", "#991B1B", "❌ Cancelado"),
                            "Erro"       => ("#FEF3C7", "#92400E", "⚠ Erro"),
                            _            => ("#EFF6FF", "#1E40AF", "⏳ Pendente")
                        };

                        <tr style="border-bottom:1px solid #F1F5F9;"
                            onmouseover="this.style.background='#FAFAFA'"
                            onmouseout="this.style.background=''">
                            <td style="@Td; font-family:monospace; font-weight:700; color:#1E62A6;">
                                @(nota.NumeroNfse ?? nota.Referencia ?? "—")
                            </td>
                            <td style="@Td; color:#64748B; white-space:nowrap;">
                                @nota.DataEmissao.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td style="@Td; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                                title="@nota.TomadorNome">
                                @(string.IsNullOrEmpty(nota.TomadorNome) ? "Consumidor Final" : nota.TomadorNome)
                                @if (!string.IsNullOrEmpty(nota.TomadorCpfCnpj))
                                {
                                    <div style="font-size:11px; color:#94A3B8;">@nota.TomadorCpfCnpj</div>
                                }
                            </td>
                            <td style="@Td; text-align:right; font-weight:700; color:#1E293B;">
                                @nota.ValorLiquido.ToString("C")
                            </td>
                            <td style="@Td; text-align:center;">
                                <span style="background:@bgStatus; color:@corStatus;
                                      font-size:11px; font-weight:700; padding:4px 10px;
                                      border-radius:20px; white-space:nowrap;">
                                    @txStatus
                                </span>
                            </td>
                            <td style="@Td; text-align:center;">
                                <div style="display:flex; gap:6px; justify-content:center;">
                                    @if (!string.IsNullOrEmpty(nota.UrlDanfse))
                                    {
                                        <a href="@nota.UrlDanfse" target="_blank"
                                           style="background:#EFF6FF; color:#1E62A6; border:none;
                                                  padding:5px 10px; border-radius:6px; font-size:11px;
                                                  font-weight:700; text-decoration:none;">
                                            🖨️ DANFE
                                        </a>
                                    }
                                    @if (nota.Status == "Autorizado")
                                    {
                                        <button @onclick="() => IniciarCancelamento(nota)"
                                                style="background:#FEE2E2; color:#991B1B; border:none;
                                                       padding:5px 10px; border-radius:6px; font-size:11px;
                                                       font-weight:700; cursor:pointer;">
                                            ❌ Cancelar
                                        </button>
                                    }
                                    @if (nota.Status == "Erro" && nota.VendaId.HasValue)
                                    {
                                        <button @onclick="() => AbrirEmitirDeVendaId(nota.VendaId.Value, nota.NumeroNfse ?? string.Empty)"
                                                style="background:#FEF3C7; color:#92400E; border:none;
                                                       padding:5px 10px; border-radius:6px; font-size:11px;
                                                       font-weight:700; cursor:pointer;">
                                            🔄 Reemitir
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (_totalPaginas > 1)
            {
                <div style="display:flex; justify-content:center; gap:8px; padding:16px;">
                    <button @onclick="PaginaAnterior" disabled="@(_pagina <= 1)"
                            style="padding:7px 14px; border:1px solid #E2E8F0; border-radius:8px;
                                   background:white; cursor:pointer; font-size:13px;">← Anterior</button>
                    <span style="padding:7px 14px; color:#64748B; font-size:13px;">
                        @_pagina / @_totalPaginas
                    </span>
                    <button @onclick="ProximaPagina" disabled="@(_pagina >= _totalPaginas)"
                            style="padding:7px 14px; border:1px solid #E2E8F0; border-radius:8px;
                                   background:white; cursor:pointer; font-size:13px;">Próxima →</button>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<NotaDto> _notas        = [];
    private bool          _loading      = true;
    private bool          _emitindo     = false;
    private string?       _toast;
    private string        _toastBg      = "#10B981";
    private int           _pagina       = 1;
    private int           _totalPaginas = 1;
    private const int     PageSize      = 20;

    private string    _filtroNumero = "";
    private string    _filtroStatus = "";
    private DateTime? _filtroDe;
    private DateTime? _filtroAte;

    private Guid?  _modalEmitirVendaId;
    private string _modalEmitirNumero = "";

    private const string Th = "padding:12px 16px; font-size:11px; font-weight:700; color:#64748B; text-align:left;";
    private const string Td = "padding:12px 16px; font-size:13px;";

    private IEnumerable<NotaDto> NotasFiltradas => _notas
        .Where(n =>
            (string.IsNullOrEmpty(_filtroNumero) ||
             (n.NumeroNfse?.Contains(_filtroNumero, StringComparison.OrdinalIgnoreCase) == true) ||
             (n.TomadorNome?.Contains(_filtroNumero, StringComparison.OrdinalIgnoreCase) == true)) &&
            (string.IsNullOrEmpty(_filtroStatus) || n.Status == _filtroStatus));

    protected override async Task OnInitializedAsync()
    {
        _filtroDe  = DateTime.Today.AddDays(-30);
        _filtroAte = DateTime.Today;
        await CarregarNotasAsync();
    }

    private async Task CarregarNotasAsync()
    {
        _loading = true;
        try
        {
            var url = $"api/notas-fiscais?pagina={_pagina}&tam={PageSize}";
            if (_filtroDe.HasValue)  url += $"&de={_filtroDe.Value:yyyy-MM-dd}";
            if (_filtroAte.HasValue) url += $"&ate={_filtroAte.Value:yyyy-MM-dd}";

            var result    = await Api.GetAsync<PagedNotasDto>(url);
            _notas        = result?.Items?.ToList() ?? [];
            _totalPaginas = result?.TotalPages ?? 1;
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task PaginaAnterior() { if (_pagina > 1) { _pagina--; await CarregarNotasAsync(); } }
    private async Task ProximaPagina()  { if (_pagina < _totalPaginas) { _pagina++; await CarregarNotasAsync(); } }

    private void FecharModalEmitir() { _modalEmitirVendaId = null; _emitindo = false; }

    private async Task AbrirEmitirDeVenda()
    {
        var vendas = await Api.GetAsync<VendaSimplesDto[]>("api/Sales?pageSize=10");
        if (vendas?.Length > 0)
        {
            _modalEmitirVendaId = vendas[0].Id;
            _modalEmitirNumero  = vendas[0].SaleNumber;
        }
    }

    private void AbrirEmitirDeVendaId(Guid vendaId, string numero)
    {
        _modalEmitirVendaId = vendaId;
        _modalEmitirNumero  = numero;
    }

    // Atalhos para o modal — evita captura de variável nula no @onclick
    private Task EmitirNfceModal() =>
        _modalEmitirVendaId.HasValue
            ? EmitirNfceDaVendaAsync(_modalEmitirVendaId.Value)
            : Task.CompletedTask;

    private Task EmitirNfeModal() =>
        _modalEmitirVendaId.HasValue
            ? EmitirNfeDaVendaAsync(_modalEmitirVendaId.Value)
            : Task.CompletedTask;

    private async Task EmitirNfceDaVendaAsync(Guid vendaId)
    {
        _emitindo = true;
        try
        {
            var resp = await Api.PostAsync(
                $"api/notas-fiscais/nfce/emitir-da-venda/{vendaId}", new { });

            _modalEmitirVendaId = null;
            _emitindo           = false;

            if (resp.IsSuccessStatusCode)
            {
                await Toast("✅ NFC-e emitida com sucesso!", "#10B981");
            }
            else
            {
                var err    = await resp.Content.ReadAsStringAsync();
                var trunc  = err.Length > 60 ? err[..60] : err;
                await Toast($"❌ Erro ao emitir NFC-e: {trunc}", "#EF4444");
            }

            await CarregarNotasAsync();
        }
        catch (Exception ex)
        {
            _emitindo = false;
            await Toast($"❌ Erro: {ex.Message}", "#EF4444");
        }
    }

    private async Task EmitirNfeDaVendaAsync(Guid vendaId)
    {
        _emitindo = true;
        try
        {
            var resp = await Api.PostAsync(
                $"api/notas-fiscais/nfe/emitir-da-venda/{vendaId}", new { });

            _modalEmitirVendaId = null;
            _emitindo           = false;

            if (resp.IsSuccessStatusCode)
            {
                await Toast("✅ NF-e emitida com sucesso!", "#10B981");
            }
            else
            {
                var err   = await resp.Content.ReadAsStringAsync();
                var trunc = err.Length > 60 ? err[..60] : err;
                await Toast($"❌ Erro ao emitir NF-e: {trunc}", "#EF4444");
            }

            await CarregarNotasAsync();
        }
        catch (Exception ex)
        {
            _emitindo = false;
            await Toast($"❌ Erro: {ex.Message}", "#EF4444");
        }
    }

    private async Task IniciarCancelamento(NotaDto nota)
    {
        var justificativa = await JS.InvokeAsync<string>("prompt",
            "Informe a justificativa do cancelamento (mínimo 15 caracteres):",
            "Cancelamento solicitado pelo cliente");

        if (string.IsNullOrWhiteSpace(justificativa) || justificativa.Length < 15)
        {
            await Toast("⚠ Justificativa deve ter ao menos 15 caracteres.", "#F59E0B");
            return;
        }

        var referencia = nota.Referencia ?? nota.NumeroNfse ?? nota.Id.ToString();
        var resp = await Api.PostAsync(
            $"api/notas-fiscais/{referencia}/cancelar",
            new { Justificativa = justificativa });

        if (resp.IsSuccessStatusCode)
        {
            await Toast("✅ Nota cancelada com sucesso.", "#10B981");
            await CarregarNotasAsync();
        }
        else
        {
            await Toast("❌ Erro ao cancelar nota. Verifique o prazo de cancelamento.", "#EF4444");
        }
    }

    private async Task Toast(string msg, string bg)
    {
        _toast   = msg;
        _toastBg = bg;
        StateHasChanged();
        await Task.Delay(4000);
        _toast = null;
        StateHasChanged();
    }

    class NotaDto
    {
        public Guid      Id              { get; set; }
        public string?   NumeroNfse      { get; set; }
        public string?   Referencia      { get; set; }
        public DateTime  DataEmissao     { get; set; }
        public string    Status          { get; set; } = "";
        public string    TomadorNome     { get; set; } = "";
        public string?   TomadorCpfCnpj { get; set; }
        public decimal   ValorLiquido    { get; set; }
        public string?   UrlDanfse       { get; set; }
        public string?   MensagemErro    { get; set; }
        public Guid?     VendaId         { get; set; }
    }
    class PagedNotasDto
    {
        public List<NotaDto> Items      { get; set; } = [];
        public int           TotalItems { get; set; }
        public int           TotalPages { get; set; }
    }
    record VendaSimplesDto(Guid Id, string SaleNumber, decimal Total);
}
