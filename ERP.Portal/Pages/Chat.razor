@page "/chat"
@using ERP.Portal.Services
@inject PortalChatService _chatSvc
@inject AuthService Auth
@implements IAsyncDisposable

<!-- Botão flutuante fixo no canto inferior direito -->
<div style="position:fixed; bottom:24px; right:24px; z-index:1000;">

    @if (_aberto)
    {
        <div style="width:340px; height:480px; background:#1E293B; border-radius:16px;
             box-shadow:0 8px 32px rgba(0,0,0,.4); display:flex; flex-direction:column;
             margin-bottom:12px; overflow:hidden;">

            <!-- Cabeçalho -->
            <div style="background:#0F172A; padding:14px 16px; display:flex;
                 justify-content:space-between; align-items:center;">
                <div>
                    <div style="font-weight:700; font-size:14px; color:white;">💬 Chat Interno</div>
                    <div style="font-size:11px; color:#94A3B8; margin-top:2px;">
                        @(_chatSvc.Conectado ? "🟢 Conectado" : "🔴 Offline") —
                        @MensagensReais mensagem(s)
                    </div>
                </div>
                <button @onclick="FecharChat"
                        style="background:none; border:none; color:#94A3B8; font-size:18px;
                        cursor:pointer; padding:4px 8px;">✕</button>
            </div>

            <!-- Mensagens -->
            <div id="chat-msgs" style="flex:1; overflow-y:auto; padding:12px;
                 display:flex; flex-direction:column; gap:8px;">
                @if (!_chatSvc.Mensagens.Any())
                {
                    <div style="text-align:center; color:#64748B; font-size:13px; margin:auto;">
                        Nenhuma mensagem ainda.<br/>
                        Digite abaixo para falar com os outros terminais.
                    </div>
                }
                @foreach (var msg in _chatSvc.Mensagens)
                {
                    @if (msg.IsSistema)
                    {
                        <!-- Separador de histórico -->
                        <div style="text-align:center; color:#475569; font-size:10px;
                             padding:4px 0; border-top:1px solid #334155;
                             border-bottom:1px solid #334155; margin:4px 0;">
                            @msg.Texto
                        </div>
                    }
                    else
                    {
                        <div style="display:flex; flex-direction:column;
                             align-items:@(msg.EhMinha ? "flex-end" : "flex-start");">
                            @if (!msg.EhMinha)
                            {
                                <span style="font-size:10px; color:#94A3B8; margin-bottom:2px;">
                                    @msg.De
                                </span>
                            }
                            <div style="max-width:240px; padding:8px 12px; border-radius:12px;
                                 background:@(msg.EhMinha ? "#1E62A6" : "#334155");
                                 color:white; font-size:13px; word-break:break-word;">
                                @msg.Texto
                            </div>
                            <div style="display:flex; align-items:center; gap:4px; margin-top:2px;">
                                <span style="font-size:10px; color:#64748B;">@msg.Hora</span>
                                @if (msg.Persistida)
                                {
                                    <span style="font-size:9px; color:#475569;"
                                          title="Mensagem salva">✓</span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Campo de entrada -->
            <div style="padding:10px; background:#0F172A; display:flex; gap:8px;">
                <input @bind="_texto" @bind:event="oninput"
                       @onkeydown="OnKeyDown"
                       placeholder="Digite uma mensagem..."
                       style="flex:1; padding:9px 12px; background:#334155; color:white;
                       border:1px solid #475569; border-radius:8px; font-size:13px;
                       outline:none;"/>
                <button @onclick="EnviarAsync"
                        disabled="@(string.IsNullOrWhiteSpace(_texto) || !_chatSvc.Conectado)"
                        style="background:#1E62A6; color:white; border:none; padding:9px 14px;
                        border-radius:8px; cursor:pointer; font-size:16px;
                        opacity:@(string.IsNullOrWhiteSpace(_texto) ? "0.4" : "1");">
                    ▶
                </button>
            </div>
        </div>
    }

    <!-- Botão flutuante + badge -->
    <div style="display:flex; justify-content:flex-end;">
        <button @onclick="ToggleChat"
                style="width:56px; height:56px; border-radius:50%; border:none;
                background:@(_temNova ? "#EF4444" : "#1E62A6"); color:white;
                font-size:22px; cursor:pointer; box-shadow:0 4px 16px rgba(0,0,0,.3);
                transition:background .2s; position:relative;">
            💬
            @if (_temNova && !_aberto)
            {
                <span style="position:absolute; top:-4px; right:-4px; background:#F59E0B;
                      color:white; border-radius:50%; width:20px; height:20px;
                      font-size:11px; font-weight:700; display:flex; align-items:center;
                      justify-content:center;">
                    @(_novasCount > 9 ? "9+" : _novasCount.ToString())
                </span>
            }
        </button>
    </div>
</div>

@code {
    private bool   _aberto     = false;
    private string _texto      = "";
    private bool   _temNova    = false;
    private int    _novasCount = 0;

    // Conta apenas mensagens reais (exclui separador de sistema)
    private int MensagensReais =>
        _chatSvc.Mensagens.Count(m => !m.IsSistema);

    protected override async Task OnInitializedAsync()
    {
        if (!_chatSvc.Conectado && Auth.LoggedIn)
            await _chatSvc.ConectarAsync(Auth.Usuario ?? "Portal", Auth.TenantId ?? "default", Auth.Token ?? "");

        _chatSvc.OnMensagemNova += OnNovaMensagem;
    }

    private void OnNovaMensagem()
    {
        var ultima = _chatSvc.Mensagens.LastOrDefault();
        if (ultima != null && !ultima.EhMinha && !ultima.IsSistema && !_aberto)
        {
            _temNova = true;
            _novasCount++;
        }
        InvokeAsync(StateHasChanged);
        InvokeAsync(() => JS?.InvokeVoidAsync("scrollChatToBottom", "chat-msgs"));
    }

    [Microsoft.AspNetCore.Components.Inject]
    private Microsoft.JSInterop.IJSRuntime? JS { get; set; }

    private void ToggleChat()
    {
        _aberto     = !_aberto;
        _temNova    = false;
        _novasCount = 0;

        // Scrolla para o fim ao abrir
        if (_aberto)
            InvokeAsync(() => JS?.InvokeVoidAsync("scrollChatToBottom", "chat-msgs"));
    }

    private void FecharChat() => _aberto = false;

    private async Task EnviarAsync()
    {
        if (string.IsNullOrWhiteSpace(_texto) || !_chatSvc.Conectado) return;
        var txt = _texto.Trim();
        _texto = "";
        await _chatSvc.EnviarAsync(txt);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await EnviarAsync();
    }

    public async ValueTask DisposeAsync()
    {
        _chatSvc.OnMensagemNova -= OnNovaMensagem;
        await _chatSvc.DisposeAsync();
    }
}
