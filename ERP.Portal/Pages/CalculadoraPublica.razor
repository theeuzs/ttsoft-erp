@page "/calculadora-publica"
@using System.Text
@inject HttpClient Http
@inject IJSRuntime JS
@layout ERP.Portal.Pages.EmptyLayout

<PageTitle>Calculadora de Materiais — ConstruTTor</PageTitle>

<div style="background:#F8FAFC; min-height:100vh; font-family:'Segoe UI',sans-serif;">

    <!-- Header público -->
    <div style="background:white; padding:16px 32px; box-shadow:0 2px 8px rgba(0,0,0,.06);
                display:flex; justify-content:space-between; align-items:center;
                position:sticky; top:0; z-index:100;">
        <div style="display:flex; align-items:center; gap:12px;">
            <span style="font-size:28px;">🏗️</span>
            <div>
                <div style="font-weight:800; font-size:18px; color:#1E293B;">ConstruTTor</div>
                <div style="font-size:12px; color:#94A3B8;">Calculadora de Materiais Gratuita</div>
            </div>
        </div>
        <div style="display:flex; gap:10px; align-items:center;">
            <a href="/catalogo" style="color:#1E62A6; font-weight:600; font-size:13px;
               text-decoration:none;">← Ver catálogo</a>
            <a href="@_whatsappLoja" target="_blank"
               style="background:#25D366; color:white; padding:10px 18px; border-radius:8px;
                      font-weight:700; font-size:13px; text-decoration:none;">
                💬 Falar com vendedor
            </a>
        </div>
    </div>

    <div style="max-width:1100px; margin:0 auto; padding:24px 16px;">

        <!-- Hero -->
        <div style="background:linear-gradient(135deg,#1E3A5F,#1E62A6); border-radius:16px;
                    padding:32px; color:white; margin-bottom:28px; text-align:center;">
            <div style="font-size:40px; margin-bottom:12px;">🧮</div>
            <h1 style="font-size:24px; font-weight:900; margin:0 0 8px;">
                Calculadora de Materiais de Construção
            </h1>
            <p style="opacity:.85; font-size:14px; margin:0;">
                Informe as medidas da obra e receba a lista completa de materiais com quantidades precisas.
                100% gratuito — sem cadastro.
            </p>
        </div>

        @if (_loadingTemplates)
        {
            <div style="text-align:center; padding:60px; color:#94A3B8;">
                <div style="font-size:32px; margin-bottom:8px;">⏳</div>
                Carregando tipos de obra...
            </div>
        }
        else
        {
            <div style="display:grid; grid-template-columns:280px 1fr; gap:20px;">

                <!-- Painel esquerdo — templates -->
                <div>
                    <div style="font-size:11px; font-weight:700; color:#64748B;
                                margin-bottom:12px; letter-spacing:.05em;">
                        TIPO DE OBRA
                    </div>
                    @foreach (var t in _templates)
                    {
                        var sel = _templateSelecionado?.Id == t.Id;
                        <button @onclick="() => SelecionarTemplate(t)"
                                style="width:100%; text-align:left; padding:14px 16px;
                                border:2px solid @(sel ? "#1E62A6" : "#E2E8F0");
                                background:@(sel ? "#EFF6FF" : "white");
                                border-radius:10px; margin-bottom:8px; cursor:pointer;
                                transition:all .15s;">
                            <div style="font-size:20px; margin-bottom:4px;">@t.Icone</div>
                            <div style="font-weight:700; font-size:13px; color:#1E293B;">@t.Nome</div>
                            <div style="font-size:11px; color:#94A3B8; margin-top:2px;">@t.Descricao</div>
                        </button>
                    }
                </div>

                <!-- Painel direito -->
                <div>
                    @if (_templateSelecionado == null)
                    {
                        <div style="background:white; border-radius:12px; padding:60px;
                             text-align:center; box-shadow:0 2px 8px rgba(0,0,0,.06);">
                            <div style="font-size:48px; margin-bottom:16px;">👈</div>
                            <div style="font-size:16px; font-weight:700; color:#1E293B; margin-bottom:8px;">
                                Selecione o tipo de obra
                            </div>
                            <p style="color:#94A3B8; font-size:13px;">
                                Escolha uma categoria à esquerda para calcular os materiais.
                            </p>
                        </div>
                    }
                    else
                    {
                        <!-- Formulário -->
                        <div style="background:white; border-radius:12px; padding:24px;
                             box-shadow:0 2px 8px rgba(0,0,0,.06); margin-bottom:16px;">
                            <h3 style="font-size:16px; font-weight:800; color:#1E293B; margin:0 0 20px;">
                                @_templateSelecionado.Icone @_templateSelecionado.Nome
                            </h3>

                            @foreach (var param in _templateSelecionado.Parametros)
                            {
                                <div style="margin-bottom:16px;">
                                    <label style="font-size:12px; font-weight:700; color:#64748B;
                                           display:block; margin-bottom:6px;">
                                        @param.Label.ToUpper()
                                    </label>
                                    <div style="display:flex; align-items:center; gap:12px;">
                                        <input type="number"
                                               value="@GetParam(param.Nome)"
                                               @oninput="e => SetParam(param.Nome, e.Value?.ToString())"
                                               min="@param.Min" max="@param.Max" step="0.5"
                                               style="flex:1; padding:10px 14px; border:2px solid #E2E8F0;
                                               border-radius:8px; font-size:18px; font-weight:700;"/>
                                        <span style="font-size:13px; color:#64748B; min-width:40px;">
                                            @param.Unidade
                                        </span>
                                    </div>
                                    <div style="font-size:11px; color:#94A3B8; margin-top:4px;">
                                        Entre @param.Min e @param.Max @param.Unidade
                                    </div>
                                </div>
                            }

                            <button @onclick="CalcularAsync" disabled="@_calculando"
                                    style="width:100%; background:@(_calculando ? "#94A3B8" : "#1E62A6");
                                    color:white; border:none; padding:14px; border-radius:8px;
                                    font-weight:700; cursor:@(_calculando ? "not-allowed" : "pointer");
                                    font-size:15px; margin-top:8px;">
                                @(_calculando ? "⏳ Calculando..." : "🧮 Calcular Materiais")
                            </button>
                        </div>

                        <!-- Resultado -->
                        @if (_resultado != null)
                        {
                            <div id="resultado-publico" style="background:white; border-radius:12px;
                                 padding:24px; box-shadow:0 2px 8px rgba(0,0,0,.06);">

                                <!-- Cabeçalho resultado -->
                                <div style="display:flex; justify-content:space-between;
                                     align-items:center; margin-bottom:20px; padding-bottom:16px;
                                     border-bottom:2px solid #F1F5F9;">
                                    <div>
                                        <h3 style="font-size:16px; font-weight:800; color:#1E293B; margin:0;">
                                            Lista de Materiais
                                        </h3>
                                        <p style="font-size:12px; color:#94A3B8; margin:4px 0 0;">
                                            @_templateSelecionado.Nome —
                                            @string.Join(", ", _parametros.Select(p =>
                                                $"{p.Value:F0} {_templateSelecionado.Parametros.FirstOrDefault(x => x.Nome == p.Key)?.Unidade}"))
                                        </p>
                                    </div>
                                    <span style="background:#EFF6FF; color:#1E62A6; padding:6px 14px;
                                          border-radius:20px; font-size:12px; font-weight:700;">
                                        @_resultado.Count materiais
                                    </span>
                                </div>

                                <!-- Tabela de materiais -->
                                <table style="width:100%; border-collapse:collapse; margin-bottom:24px;">
                                    <thead>
                                        <tr style="background:#F8FAFC; border-bottom:2px solid #E2E8F0;">
                                            <th style="@Th">MATERIAL</th>
                                            <th style="@Th; text-align:right;">QTDE</th>
                                            <th style="@Th;">UNIDADE</th>
                                            <th style="@Th; color:#94A3B8;">OBSERVAÇÃO</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var (item, idx) in _resultado.Select((x, i) => (x, i)))
                                        {
                                            <tr style="border-bottom:1px solid #F1F5F9;
                                                 background:@(idx % 2 == 0 ? "white" : "#FAFAFA")">
                                                <td style="@Td; font-weight:700; color:#1E293B;">
                                                    @item.Nome
                                                </td>
                                                <td style="@Td; text-align:right; font-size:18px;
                                                     font-weight:800; color:#1E62A6;">
                                                    @item.Quantidade.ToString("F1")
                                                </td>
                                                <td style="@Td; color:#64748B;">@item.Unidade</td>
                                                <td style="@Td; color:#94A3B8; font-size:12px;">
                                                    @item.Observacao
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>

                                <!-- Dica -->
                                <div style="padding:16px; background:#F0F9FF; border-radius:8px;
                                     border-left:4px solid #1E62A6; margin-bottom:20px;">
                                    <div style="font-size:12px; color:#1E62A6; font-weight:700; margin-bottom:4px;">
                                        💡 DICA
                                    </div>
                                    <div style="font-size:13px; color:#1E293B;">
                                        As quantidades incluem margem de segurança de 5–10%.
                                        Recomendamos comprar 10% a mais para evitar diferença de lote.
                                    </div>
                                </div>

                                <!-- CTAs de lead generation -->
                                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                                    <button @onclick="EnviarWhatsApp"
                                            style="background:#25D366; color:white; border:none;
                                            padding:16px; border-radius:10px; font-weight:700;
                                            cursor:pointer; font-size:14px; display:flex;
                                            align-items:center; justify-content:center; gap:8px;">
                                        💬 Solicitar Orçamento no WhatsApp
                                    </button>
                                    <button @onclick="ImprimirAsync"
                                            style="background:#F1F5F9; color:#1E293B; border:none;
                                            padding:16px; border-radius:10px; font-weight:700;
                                            cursor:pointer; font-size:14px; display:flex;
                                            align-items:center; justify-content:center; gap:8px;">
                                        🖨️ Imprimir Lista
                                    </button>
                                </div>

                                <!-- CTA para catálogo -->
                                <div style="margin-top:16px; padding:16px; background:#F0FDF4;
                                     border-radius:8px; border:1px solid #BBF7D0;
                                     display:flex; justify-content:space-between; align-items:center;">
                                    <div>
                                        <div style="font-weight:700; color:#065F46; font-size:13px;">
                                            🛒 Compre tudo em um só lugar
                                        </div>
                                        <div style="font-size:12px; color:#047857; margin-top:2px;">
                                            Veja nossos produtos e preços no catálogo online
                                        </div>
                                    </div>
                                    <a href="/catalogo" style="background:#10B981; color:white;
                                       padding:10px 18px; border-radius:8px; font-weight:700;
                                       font-size:13px; text-decoration:none; white-space:nowrap;">
                                        Ver Catálogo →
                                    </a>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>

    <!-- Rodapé -->
    <div style="text-align:center; padding:24px; color:#94A3B8; font-size:12px;
                border-top:1px solid #E2E8F0; margin-top:32px;">
        Calculadora gratuita ConstruTTor · Quantidades estimadas com base em padrões técnicos da construção civil ·
        <a href="@_whatsappLoja" target="_blank" style="color:#25D366;">Confirme com nosso especialista</a>
    </div>
</div>

<style>
    @@media print {
        div[style*="sticky"], div[style*="Hero"], a[href="/catalogo"],
        button:not(#btn-imprimir) { display: none !important; }
        #resultado-publico { box-shadow: none !important; }
    }
</style>

@code {
    private List<TemplateDto>           _templates           = [];
    private TemplateDto?                _templateSelecionado;
    private Dictionary<string, decimal> _parametros          = new();
    private List<MaterialSimples>?      _resultado;
    private bool                        _loadingTemplates    = true;
    private bool                        _calculando          = false;
    private string                      _whatsappLoja        = "https://wa.me/";

    private const string Th = "padding:10px 16px; font-size:11px; font-weight:700; color:#64748B; text-align:left;";
    private const string Td = "padding:12px 16px; font-size:13px;";

    protected override async Task OnInitializedAsync()
    {
        // Templates: endpoint público (AllowAnonymous)
        try
        {
            var lista = await Http.GetFromJsonAsync<TemplateDto[]>("api/Calculadora/templates");
            _templates = lista?.ToList() ?? [];
        }
        catch { }

        // Config pública da loja (telefone para WhatsApp)
        try
        {
            var cfg = await Http.GetFromJsonAsync<ConfigPublica>("api/Config/public");
            if (cfg != null)
            {
                var tel = new string(cfg.Telefone?.Where(char.IsDigit).ToArray() ?? []);
                if (tel.Length >= 10)
                {
                    if (!tel.StartsWith("55")) tel = "55" + tel;
                    _whatsappLoja = $"https://wa.me/{tel}";
                }
            }
        }
        catch { }

        _loadingTemplates = false;
    }

    private void SelecionarTemplate(TemplateDto t)
    {
        _templateSelecionado = t;
        _resultado           = null;
        _parametros          = t.Parametros.ToDictionary(p => p.Nome, p => p.Min);
    }

    private decimal GetParam(string nome) => _parametros.GetValueOrDefault(nome, 0);

    private void SetParam(string nome, string? valor)
    {
        if (decimal.TryParse(valor?.Replace(",", "."),
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var v))
            _parametros[nome] = v;
    }

    private async Task CalcularAsync()
    {
        if (_templateSelecionado == null) return;
        _calculando = true;
        try
        {
            // Endpoint público — não exige autenticação
            var resp = await Http.PostAsJsonAsync("api/Calculadora/calcular", new
            {
                Template   = _templateSelecionado.Id,
                Parametros = _parametros
            });

            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<CalcResultado>();
                _resultado = result?.Materiais ?? [];
            }
        }
        finally { _calculando = false; }
    }

    private async Task EnviarWhatsApp()
    {
        if (_resultado == null || _templateSelecionado == null) return;

        var sb = new StringBuilder();
        sb.AppendLine($"🏗️ *Lista de Materiais — {_templateSelecionado.Nome}*");
        sb.AppendLine($"📅 {DateTime.Now:dd/MM/yyyy}");
        sb.AppendLine();
        foreach (var m in _resultado)
            sb.AppendLine($"• {m.Nome}: *{m.Quantidade:F1} {m.Unidade}*");
        sb.AppendLine();
        sb.AppendLine("Gostaria de um orçamento com preços para esses materiais?");

        var enc = Uri.EscapeDataString(sb.ToString());
        var url = _whatsappLoja.Contains("?")
            ? _whatsappLoja + "&text=" + enc
            : _whatsappLoja + "?text=" + enc;

        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task ImprimirAsync()
        => await JS.InvokeVoidAsync("window.print");

    // ── DTOs locais ───────────────────────────────────────────────────────────
    record TemplateDto(string Id, string Nome, string Descricao, string Icone,
        List<ParamDto> Parametros);
    record ParamDto(string Nome, string Label, string Unidade, decimal Min, decimal Max);
    record MaterialSimples(string Nome, decimal Quantidade, string Unidade, string Observacao);
    record CalcResultado(List<MaterialSimples> Materiais, int TotalItens);
    record ConfigPublica(string NomeFantasia, string? Telefone);
}
