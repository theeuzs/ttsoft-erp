@page "/caixa"
@using ERP.Portal.Services
@inject ApiClient Api
@inject IJSRuntime JS

<div style="padding:0 0 32px; max-width:760px;">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
        <div style="font-size:32px;">🏪</div>
        <div>
            <h2 style="color:#1E293B; font-weight:800; margin:0;">Caixa</h2>
            <p style="color:#94A3B8; font-size:13px; margin:4px 0 0;">
                Abertura, fechamento e movimentações do caixa
            </p>
        </div>
    </div>

    @if (_loading)
    {
        <div style="text-align:center; padding:60px; color:#94A3B8;">Verificando caixa...</div>
    }
    else if (_caixa is null)
    {
        <!-- Caixa Fechado — Abrir -->
        <div style="background:white; border-radius:12px; padding:32px;
                    box-shadow:0 2px 8px rgba(0,0,0,.06); text-align:center;">
            <div style="font-size:48px; margin-bottom:12px;">🔒</div>
            <h3 style="color:#1E293B; font-weight:700; margin:0 0 8px;">Caixa Fechado</h3>
            <p style="color:#94A3B8; font-size:14px; margin:0 0 24px;">
                Informe o valor inicial para abrir o caixa do dia.
            </p>
            <div style="max-width:300px; margin:0 auto;">
                <label style="font-size:12px; font-weight:700; color:#475569;
                               display:block; margin-bottom:6px; text-transform:uppercase;">
                    Valor de Abertura (R$)
                </label>
                <input type="number" @bind="_valorAbertura" min="0" step="0.01"
                       placeholder="0,00"
                       style="width:100%; padding:12px 14px; border:1px solid #E2E8F0;
                              border-radius:8px; font-size:16px; text-align:center; outline:none;
                              margin-bottom:16px;" />
                @if (!string.IsNullOrEmpty(_erro))
                {
                    <div style="color:#DC2626; font-size:13px; margin-bottom:12px;">❌ @_erro</div>
                }
                <button @onclick="AbrirCaixaAsync" disabled="@_salvando"
                        style="width:100%; background:#27AE60; color:white; border:none; padding:14px;
                               border-radius:8px; font-size:15px; font-weight:700; cursor:pointer;
                               opacity:@(_salvando ? "0.6" : "1");">
                    @(_salvando ? "Abrindo..." : "✅ Abrir Caixa")
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- Caixa Aberto -->
        <div style="background:#F0FDF4; border:1px solid #BBF7D0; border-radius:12px; padding:20px;
                    margin-bottom:20px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
            <div>
                <div style="font-size:13px; font-weight:700; color:#16A34A;">🟢 CAIXA ABERTO</div>
                <div style="font-size:12px; color:#64748B; margin-top:2px;">
                    Aberto em @_caixa.DataAbertura.ToString("dd/MM/yyyy HH:mm")
                    — Abertura: @_caixa.ValorAbertura.ToString("C2")
                </div>
            </div>
            <button @onclick="FecharCaixaAsync" disabled="@_salvando"
                    style="background:#EF4444; color:white; border:none; padding:10px 20px;
                           border-radius:8px; font-size:13px; font-weight:700; cursor:pointer;
                           opacity:@(_salvando ? "0.6" : "1");">
                🔒 Fechar Caixa
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_erro))
        {
            <div style="background:#FEF2F2; border:1px solid #FECACA; border-radius:8px;
                        padding:12px 16px; color:#DC2626; margin-bottom:16px; font-size:13px;">
                ❌ @_erro
            </div>
        }
        @if (!string.IsNullOrEmpty(_sucesso))
        {
            <div style="background:#F0FDF4; border:1px solid #BBF7D0; border-radius:8px;
                        padding:12px 16px; color:#16A34A; margin-bottom:16px; font-size:13px;">
                ✅ @_sucesso
            </div>
        }

        <!-- Sangria e Suprimento -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:20px;">
            <div style="background:white; border-radius:12px; padding:20px;
                        box-shadow:0 2px 8px rgba(0,0,0,.06); border-top:4px solid #EF4444;">
                <h3 style="font-size:14px; font-weight:700; color:#1E293B; margin:0 0 16px;">
                    📤 Sangria (Retirada)
                </h3>
                <input type="number" @bind="_valorSangria" min="0.01" step="0.01"
                       placeholder="Valor (R$)"
                       style="width:100%; padding:10px 12px; border:1px solid #E2E8F0;
                              border-radius:8px; font-size:14px; outline:none; margin-bottom:8px;" />
                <input @bind="_descSangria" placeholder="Descrição (ex: troco para o caixa)"
                       style="width:100%; padding:10px 12px; border:1px solid #E2E8F0;
                              border-radius:8px; font-size:14px; outline:none; margin-bottom:12px;" />
                <button @onclick="SangriaAsync" disabled="@_salvando"
                        style="width:100%; background:#EF4444; color:white; border:none; padding:10px;
                               border-radius:8px; font-size:13px; font-weight:700; cursor:pointer;">
                    Registrar Sangria
                </button>
            </div>

            <div style="background:white; border-radius:12px; padding:20px;
                        box-shadow:0 2px 8px rgba(0,0,0,.06); border-top:4px solid #27AE60;">
                <h3 style="font-size:14px; font-weight:700; color:#1E293B; margin:0 0 16px;">
                    📥 Suprimento (Reforço)
                </h3>
                <input type="number" @bind="_valorSuprimento" min="0.01" step="0.01"
                       placeholder="Valor (R$)"
                       style="width:100%; padding:10px 12px; border:1px solid #E2E8F0;
                              border-radius:8px; font-size:14px; outline:none; margin-bottom:8px;" />
                <input @bind="_descSuprimento" placeholder="Descrição (ex: troco recebido do banco)"
                       style="width:100%; padding:10px 12px; border:1px solid #E2E8F0;
                              border-radius:8px; font-size:14px; outline:none; margin-bottom:12px;" />
                <button @onclick="SuprimentoAsync" disabled="@_salvando"
                        style="width:100%; background:#27AE60; color:white; border:none; padding:10px;
                               border-radius:8px; font-size:13px; font-weight:700; cursor:pointer;">
                    Registrar Suprimento
                </button>
            </div>
        </div>

        <!-- Totais do caixa -->
        @if (_caixa.Saldo is not null)
        {
            <div style="background:white; border-radius:12px; padding:20px;
                        box-shadow:0 2px 8px rgba(0,0,0,.06);">
                <h3 style="font-size:15px; font-weight:700; color:#1E293B; margin:0 0 16px;">
                    📊 Resumo do Caixa
                </h3>
                <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px;">
                    @foreach (var item in _caixa.Saldo)
                    {
                        <div style="background:#F8FAFC; border-radius:8px; padding:14px; text-align:center;">
                            <div style="font-size:16px; font-weight:700; color:#1E293B;">
                                @item.Total.ToString("C0")
                            </div>
                            <div style="font-size:11px; color:#94A3B8; margin-top:4px; font-weight:600;">
                                @item.FormaPagamento
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private CaixaDto?    _caixa          = null;
    private bool         _loading        = true;
    private bool         _salvando       = false;
    private string?      _erro;
    private string?      _sucesso;
    private decimal      _valorAbertura  = 0;
    private decimal      _valorSangria   = 0;
    private string       _descSangria    = "";
    private decimal      _valorSuprimento = 0;
    private string       _descSuprimento = "";

    protected override async Task OnInitializedAsync() => await CarregarAsync();

    private async Task CarregarAsync()
    {
        _loading = true;
        _erro    = null;
        try
        {
            _caixa = await Api.GetAsync<CaixaDto>("api/Caixa/aberto");
        }
        catch { _caixa = null; }
        finally { _loading = false; }
    }

    private async Task AbrirCaixaAsync()
    {
        _salvando = true;
        _erro     = null;
        try
        {
            await Api.PostAsync("api/Caixa/abrir", new { ValorAbertura = _valorAbertura });
            await CarregarAsync();
        }
        catch (Exception ex) { _erro = ex.Message; }
        finally { _salvando = false; }
    }

    private async Task FecharCaixaAsync()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Confirma o fechamento do caixa?")) return;
        _salvando = true;
        _erro     = null;
        try
        {
            await Api.PostAsync("api/Caixa/fechar", new { });
            _sucesso = "Caixa fechado com sucesso.";
            _caixa   = null;
        }
        catch (Exception ex) { _erro = ex.Message; }
        finally { _salvando = false; }
    }

    private async Task SangriaAsync()
    {
        if (_valorSangria <= 0) { _erro = "Informe um valor maior que zero."; return; }
        _salvando = true;
        _erro     = null;
        try
        {
            await Api.PostAsync("api/Caixa/sangria",
                new { Valor = _valorSangria, Descricao = _descSangria });
            _sucesso        = $"Sangria de {_valorSangria:C2} registrada.";
            _valorSangria   = 0;
            _descSangria    = "";
            await CarregarAsync();
        }
        catch (Exception ex) { _erro = ex.Message; }
        finally { _salvando = false; }
    }

    private async Task SuprimentoAsync()
    {
        if (_valorSuprimento <= 0) { _erro = "Informe um valor maior que zero."; return; }
        _salvando = true;
        _erro     = null;
        try
        {
            await Api.PostAsync("api/Caixa/suprimento",
                new { Valor = _valorSuprimento, Descricao = _descSuprimento });
            _sucesso          = $"Suprimento de {_valorSuprimento:C2} registrado.";
            _valorSuprimento  = 0;
            _descSuprimento   = "";
            await CarregarAsync();
        }
        catch (Exception ex) { _erro = ex.Message; }
        finally { _salvando = false; }
    }

    private class CaixaDto
    {
        public DateTime          DataAbertura  { get; set; }
        public decimal           ValorAbertura { get; set; }
        public List<SaldoItem>?  Saldo         { get; set; }
    }

    private class SaldoItem
    {
        public string  FormaPagamento { get; set; } = "";
        public decimal Total          { get; set; }
    }
}
