<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ════════════════════════════════════════════════════════════════════════════
     DARK MODE STYLES — ERP TTSoft
     Estilos IMPLÍCITOS aplicam automaticamente a todos os controles do tipo.
     O ThemeService sobrescreve as chaves DynamicResource em runtime.
    ════════════════════════════════════════════════════════════════════════════
    -->

    <!-- ── TextBox ─────────────────────────────────────────────────────────── -->
    <Style TargetType="TextBox">
        <Setter Property="Background"             Value="{DynamicResource FundoInput}"/>
        <Setter Property="Foreground"             Value="{DynamicResource TextDark}"/>
        <Setter Property="BorderBrush"            Value="{DynamicResource BordaInput}"/>
        <Setter Property="CaretBrush"             Value="{DynamicResource TextDark}"/>
        <Setter Property="SelectionBrush"         Value="#3B82F6"/>
        <Setter Property="Padding"                Value="8,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource CorAcento}"/>
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── PasswordBox ─────────────────────────────────────────────────────── -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background"  Value="{DynamicResource FundoInput}"/>
        <Setter Property="Foreground"  Value="{DynamicResource TextDark}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BordaInput}"/>
        <Setter Property="Padding"     Value="8,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ── ComboBox — cores via propriedades simples ──────────────────────── -->
    <!-- Não usamos ControlTemplate pois quebra o DisplayMemberPath.           -->
    <!-- As cores do dropdown são controladas via SystemColors no App.xaml.    -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"      Value="{DynamicResource FundoInput}"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextDark}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BordaInput}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource FundoInput}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
        <Setter Property="Padding"    Value="10,6"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource CardBgAlt}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#1E3A5F"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── DataGrid ────────────────────────────────────────────────────────── -->
    <Style TargetType="DataGrid">
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="RowBackground"            Value="{DynamicResource CardBg}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource CardBgAlt}"/>
        <Setter Property="Foreground"               Value="{DynamicResource TextDark}"/>
        <Setter Property="GridLinesVisibility"      Value="None"/>
        <Setter Property="BorderThickness"          Value="0"/>
    </Style>

    <!-- DataGridRow: só fundo — cada DataGrid controla highlight via DataGrid.Resources -->
    <Style TargetType="DataGridRow">
        <Setter Property="Background"      Value="{DynamicResource CardBg}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource RowHoverBg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DataGridCell: sem Foreground global — cada DataGrid define via DataGrid.Resources -->
    <Style TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background"      Value="Transparent"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{DynamicResource CorAcento}"/>
        <Setter Property="Padding"         Value="12,12,12,8"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BordaInput}"/>
    </Style>

    <!-- ── ListBox ─────────────────────────────────────────────────────────── -->
    <Style TargetType="ListBox">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextDark}"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource CardBgAlt}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#1E3A5F"/>
                <Setter Property="Foreground" Value="#F1F5F9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── ScrollBar ───────────────────────────────────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width"      Value="6"/>
    </Style>

    <!-- ── Label ───────────────────────────────────────────────────────────── -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
    </Style>

    <!-- ── CheckBox ────────────────────────────────────────────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
    </Style>

    <!-- ── TabControl / TabItem ─────────────────────────────────────────────── -->
    <Style TargetType="TabControl">
        <Setter Property="Background"  Value="{DynamicResource CardBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BordaInput}"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource CardBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        <Setter Property="Padding"    Value="14,8"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource CorAcento}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── GroupBox ────────────────────────────────────────────────────────── -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground"  Value="{DynamicResource TextDark}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BordaInput}"/>
        <Setter Property="Background"  Value="{DynamicResource CardBg}"/>
    </Style>

    <!-- ── ToolTip ─────────────────────────────────────────────────────────── -->
    <Style TargetType="ToolTip">
        <Setter Property="Background"  Value="{DynamicResource CardBg}"/>
        <Setter Property="Foreground"  Value="{DynamicResource TextDark}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BordaInput}"/>
    </Style>

    <!-- ── UserControl — fundo de cada view/página ─────────────────────────── -->
    <Style TargetType="UserControl">
        <Setter Property="Background" Value="{DynamicResource FundoGeral}"/>
    </Style>

    <!-- ── Window genérica — cobre popups e dialogs ─────────────────────────── -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource FundoGeral}"/>
    </Style>

</ResourceDictionary>
