<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════
         SOMBRAS
    ══════════════════════════════════════════════ -->
    <DropShadowEffect x:Key="CardShadow"
                      BlurRadius="48" ShadowDepth="16"
                      Direction="270" Opacity="0.18"
                      Color="#0F172A"/>

    <DropShadowEffect x:Key="ButtonShadow"
                      BlurRadius="20" ShadowDepth="6"
                      Direction="270" Opacity="0.45"
                      Color="#1565C0"/>

    <DropShadowEffect x:Key="WaShadow"
                      BlurRadius="18" ShadowDepth="5"
                      Direction="270" Opacity="0.5"
                      Color="#25D366"/>

    <!-- ══════════════════════════════════════════════
         LABEL DOS CAMPOS
    ══════════════════════════════════════════════ -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
        <Setter Property="Foreground" Value="#374151"/>
        <Setter Property="Margin"     Value="0,0,0,8"/>
    </Style>

    <!-- ══════════════════════════════════════════════
         MODERN TEXT BOX
    ══════════════════════════════════════════════ -->
    <Style x:Key="ModernTextBox" TargetType="TextBox">
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="FontSize"                 Value="15"/>
        <Setter Property="FontFamily"               Value="Segoe UI"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Foreground"               Value="#111827"/>
        <Setter Property="CaretBrush"               Value="#1565C0"/>
        <Setter Property="SelectionBrush"           Value="#90B8E0"/>
        <Setter Property="Padding"                  Value="0,0,12,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <ScrollViewer x:Name="PART_ContentHost"
                                  VerticalAlignment="Center"
                                  Padding="0"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         MODERN PASSWORD BOX
    ══════════════════════════════════════════════ -->
    <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="FontSize"                 Value="15"/>
        <Setter Property="FontFamily"               Value="Segoe UI"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Foreground"               Value="#111827"/>
        <Setter Property="Padding"                  Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Grid VerticalAlignment="Center">
                        <ScrollViewer x:Name="PART_ContentHost" Padding="0"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         PRIMARY BUTTON (ATUALIZADO COM CARREGAMENTO E DESATIVADO CORRETOS)
    ══════════════════════════════════════════════ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Height"          Value="56"/>
        <Setter Property="FontSize"        Value="16"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="14" Effect="{StaticResource ButtonShadow}" x:Name="Root">
                        <Border.Background>
                            <LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#1976D2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="BtnContent"/>

                            <Path Data="M 12 2 A 10 10 0 0 1 22 12" Height="24" RenderTransformOrigin="0.5,0.5" Stroke="White" StrokeEndLineCap="Round" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeThickness="3" Visibility="Collapsed" Width="24" x:Name="Spinner">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0" x:Name="SpinnerRotate"/>
                                </Path.RenderTransform>
                            </Path>
                        </Grid>
                    </Border>
                    
                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" TargetName="Root">
                                <Setter.Value>
                                    <LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
                                        <GradientStop Color="#0D47A1" Offset="0"/>
                                        <GradientStop Color="#1565C0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        
                        <!-- Click -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform" TargetName="Root">
                                <Setter.Value>
                                    <ScaleTransform CenterX="240" CenterY="28" ScaleX="0.985" ScaleY="0.985"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        
                        <!-- DESATIVADO PADRÃO (Sem dados preenchidos) -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" TargetName="Root" Value="0.55"/>
                        </Trigger>
                        
                        <!-- CARREGANDO (Ativado pelo Tag via ViewModel.IsBusy) -->
                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Mode=TemplatedParent}}" Value="True">
                            <Setter Property="Opacity" TargetName="Root" Value="0.8"/>
                            <Setter Property="Visibility" TargetName="BtnContent" Value="Hidden"/>
                            <Setter Property="Visibility" TargetName="Spinner" Value="Visible"/>
                            
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="SpinAnimation">
                                    <Storyboard>
                                        <DoubleAnimation Duration="0:0:0.8" From="0" RepeatBehavior="Forever" Storyboard.TargetName="SpinnerRotate" Storyboard.TargetProperty="Angle" To="360"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="SpinAnimation"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>