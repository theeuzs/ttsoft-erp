<UserControl x:Class="ERP.WPF.Views.CargosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ERP.WPF.Converters"
             Background="Transparent" FontFamily="Segoe UI">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ COLUNA ESQUERDA: Lista de Cargos ══════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Lista de cargos -->
            <Border Grid.Row="0" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="Black" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CARGOS" FontSize="11" FontWeight="Black"
                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,12"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Roles}"
                             SelectedItem="{Binding SelectedRole}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="10,10"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#EBF2FB"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   FontSize="14" Foreground="#1E293B"/>
                                        <!-- Badge "Protegido" para Administrador -->
                                        <Border Background="#FEF3C7" CornerRadius="4" Padding="5,1"
                                                Margin="6,0,0,0"
                                                Visibility="{Binding IsProtected, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="🔒" FontSize="10"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0">
                                        <Run Text="{Binding UserCount, StringFormat='{}{0} usuário(s)', Mode=OneWay}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding PermissionCodes.Count, StringFormat='{}{0} perm.', Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Criar novo cargo -->
            <Border Grid.Row="1" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="16" Margin="0,12,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="Black" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="NOVO CARGO" FontSize="11" FontWeight="Black"
                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                    <TextBox Text="{Binding NovoCargoNome, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="13" BorderBrush="{DynamicResource BordaInput}"
                             ToolTip="Nome do novo cargo"/>
                    <Button Content="➕ Criar Cargo" Command="{Binding CriarCommand}"
                            Background="#1E62A6" Foreground="White" FontWeight="Bold"
                            FontSize="13" Height="36" Margin="0,8,0,0" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ COLUNA DIREITA: Permissões do Cargo Selecionado ═══════════════ -->
        <Grid Grid.Column="2">
            <!-- Placeholder quando nenhum cargo está selecionado -->
            <TextBlock Text="← Selecione um cargo para editar suas permissões"
                       FontSize="15" Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding TemCargoSelecionado, Converter={StaticResource InverseBool}}"/>

            <!-- Painel de edição -->
            <Grid Visibility="{Binding TemCargoSelecionado, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Card de limites operacionais -->
                <Border Grid.Row="0" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="Black" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="% DESCONTO MÁXIMO" FontSize="11" FontWeight="Black"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding MaxDiscount, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8" FontSize="16" BorderBrush="{DynamicResource BordaInput}"
                                     IsEnabled="{Binding IsCargoEditavel}"/>
                            <TextBlock Text="Ex: 10 = até 10% de desconto" FontSize="11"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="SANGRIA MÁXIMA (R$)" FontSize="11" FontWeight="Black"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding MaxSangria, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8" FontSize="16" BorderBrush="{DynamicResource BordaInput}"
                                     IsEnabled="{Binding IsCargoEditavel}"/>
                            <TextBlock Text="Ex: 500 = até R$ 500,00 por sangria" FontSize="11"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="COMISSÃO (%)" FontSize="11" FontWeight="Black"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"
                                               ToolTip="Sprint E — percentual de comissão sobre o total vendido pelo cargo"/>
                                    <TextBox Text="{Binding PercentualComissao, UpdateSourceTrigger=PropertyChanged, StringFormat=N2, ConverterCulture=pt-BR}"
                                             Padding="10,8" FontSize="16" BorderBrush="{DynamicResource BordaInput}"
                                             IsEnabled="{Binding IsCargoEditavel}"/>
                                    <TextBlock Text="Ex: 1,5 = 1,5% sobre o total vendido. 0 = sem comissão." FontSize="11"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>
                    </Grid>
                </Border>

                <!-- Aviso cargo protegido -->
                <Border Grid.Row="0" CornerRadius="12" Background="#FEF9C3" Padding="12,8"
                        Margin="0,0,0,-8" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                        Visibility="{Binding SelectedRole.IsProtected, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="🔒  O cargo Administrador é protegido — permissões e limites não podem ser alterados."
                               FontSize="12" Foreground="#92400E" TextWrapping="Wrap"/>
                </Border>

                <!-- Permissões agrupadas por módulo -->
                <Border Grid.Row="2" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="Black" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="PERMISSÕES DO CARGO" FontSize="11" FontWeight="Black"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,14"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      IsEnabled="{Binding IsCargoEditavel}">
                            <ItemsControl ItemsSource="{Binding PermissionGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,18">
                                            <!-- Cabeçalho do grupo -->
                                            <TextBlock Text="{Binding GroupName}" FontWeight="Bold"
                                                       FontSize="13" Foreground="#1E62A6" Margin="0,0,0,8"/>
                                            <Separator Background="#E2E8F0" Margin="0,0,0,8"/>

                                            <!-- Checkboxes das permissões -->
                                            <ItemsControl ItemsSource="{Binding Permissions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#F8FAFC" CornerRadius="8"
                                                                Padding="10,7" Margin="0,0,8,8"
                                                                BorderBrush="#E2E8F0" BorderThickness="1">
                                                            <CheckBox IsChecked="{Binding IsChecked}"
                                                                      VerticalContentAlignment="Center">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               FontSize="13" FontWeight="SemiBold"
                                                                               Foreground="#1E293B"/>
                                                                    <TextBlock Text="{Binding Code}"
                                                                               FontSize="10" Foreground="{DynamicResource TextMuted}"
                                                                               Margin="0,1,0,0"/>
                                                                </StackPanel>
                                                            </CheckBox>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Botões de ação -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🗑️ Excluir Cargo" Command="{Binding ExcluirCommand}"
                            Background="#EF4444" Foreground="White" FontWeight="Bold"
                            FontSize="13" Height="38" Padding="18,0" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,10,0"
                            Visibility="{Binding PodeExcluir, Converter={StaticResource BoolToVis}}">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="💾 Salvar Alterações" Command="{Binding SalvarCommand}"
                            Background="#1E62A6" Foreground="White" FontWeight="Bold"
                            FontSize="13" Height="38" Padding="20,0" BorderThickness="0"
                            Cursor="Hand"
                            IsEnabled="{Binding IsCargoEditavel}">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
