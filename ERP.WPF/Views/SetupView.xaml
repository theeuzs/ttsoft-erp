<Window x:Class="ERP.WPF.Views.SetupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuração Inicial — ERP" Height="480" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E293B">

    <Window.Resources>
        <!-- Estilo base dos campos de texto -->
        <Style x:Key="Campo" TargetType="TextBox">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CampoSenha" TargetType="PasswordBox">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="BotaoPrimario" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BotaoSecundario" TargetType="Button">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#475569"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="16"/>    <!-- Espaço -->
            <RowDefinition Height="*"/>     <!-- Formulário -->
            <RowDefinition Height="Auto"/>  <!-- Preview -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- Status -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- Botões -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────── -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Bem-vindo ao ERP" FontSize="22" FontWeight="Bold"
                       Foreground="#F1F5F9"/>
            <TextBlock Text="Configure a conexão com o banco de dados para começar."
                       FontSize="13" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ── Formulário ──────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Servidor (ocupa 2 colunas) -->
            <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                <TextBlock Text="Servidor SQL" Style="{StaticResource Label}"/>
                <TextBox Text="{Binding Servidor, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Campo}"
                         ToolTip="Ex: localhost\SQLEXPRESS  ou  192.168.0.10\SQLEXPRESS"/>
            </StackPanel>

            <!-- Banco -->
            <StackPanel Grid.Row="2" Grid.Column="0">
                <TextBlock Text="Nome do Banco" Style="{StaticResource Label}"/>
                <TextBox Text="{Binding Banco, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Campo}"/>
            </StackPanel>

            <!-- Usuário -->
            <StackPanel Grid.Row="2" Grid.Column="2">
                <TextBlock Text="Usuário" Style="{StaticResource Label}"/>
                <TextBox Text="{Binding Usuario, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Campo}"/>
            </StackPanel>

            <!-- Senha (ocupa 2 colunas) -->
            <StackPanel Grid.Row="4" Grid.ColumnSpan="3">
                <TextBlock Text="Senha" Style="{StaticResource Label}"/>
                <!-- PasswordBox não tem Binding nativo, usamos o code-behind -->
                <PasswordBox x:Name="SenhaBox"
                             Style="{StaticResource CampoSenha}"
                             PasswordChanged="SenhaBox_PasswordChanged"/>
            </StackPanel>
        </Grid>

        <!-- ── Preview da connection string ───────────── -->
        <Border Grid.Row="3" Background="#0F172A" CornerRadius="4" Padding="12,8">
            <TextBlock Text="{Binding Preview}" Foreground="{DynamicResource TextMuted}"
                       FontFamily="Consolas" FontSize="11"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ── Status ──────────────────────────────────── -->
        <TextBlock Grid.Row="5" Text="{Binding StatusMensagem}"
                   FontSize="12" TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#94A3B8"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ConexaoOk}" Value="True">
                            <Setter Property="Foreground" Value="#4ADE80"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Testando}" Value="True">
                            <Setter Property="Foreground" Value="#60A5FA"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- ── Botões ───────────────────────────────────── -->
        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Testar Conexão"
                    Command="{Binding TestarConexaoCommand}"
                    Style="{StaticResource BotaoSecundario}"/>
            <Button Grid.Column="2" Content="Salvar e Continuar →"
                    Command="{Binding SalvarCommand}"
                    Style="{StaticResource BotaoPrimario}"/>
        </Grid>
    </Grid>
</Window>
