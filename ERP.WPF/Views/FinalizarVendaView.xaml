<Window x:Class="ERP.WPF.Views.FinalizarVendaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finalizar Venda" Height="650" SizeToContent="Width"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="TtBlue" Color="#1E62A6"/>
        <SolidColorBrush x:Key="TtSilver" Color="#8A939C"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TtBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GreenButton" BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BordaCard}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CardBgAlt}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A5F"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource CardBg}" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="600"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource FundoRodape}" CornerRadius="20,0,0,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Resumo do Pedido" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TtBlue}" Margin="0,0,0,15"/>

                    <TextBlock Text="Vendedor:" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                    <ComboBox ItemsSource="{Binding Vendedores}"
                              SelectedItem="{Binding SelectedVendedor}"
                              DisplayMemberPath="Name"
                              Margin="0,5,0,15" Padding="5,0" Height="35" VerticalContentAlignment="Center"
                              Background="{DynamicResource FundoInput}"
                              Foreground="{DynamicResource TextDark}"
                              BorderBrush="{DynamicResource BordaInput}"/>

                    <ScrollViewer Height="250" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ItensCarrinho}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,5,0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextDark}" FontWeight="SemiBold" Margin="0,0,10,0">
                                                <Run Text="{Binding Quantity}"/><Run Text="x "/><Run Text="{Binding ProductName}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="{Binding Total, StringFormat='R$ {0:N2}'}"
                                                       FontWeight="Bold" Foreground="{StaticResource TtBlue}" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="✏️" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0.7"/>
                                            <TextBox Text="{Binding Observacao, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="240" Background="Transparent" BorderThickness="0"
                                                     FontSize="11" Foreground="{DynamicResource TextMuted}" FontStyle="Italic"
                                                     ToolTip="Escreva uma observação (ex: entregar nos fundos)"/>
                                        </StackPanel>
                                        <Separator Margin="0,8,0,0" Background="{DynamicResource BordaCard}" Height="1"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Separator Margin="0,20" Background="{DynamicResource BordaCard}"/>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Margin="0,0,0,10">
                            <TextBlock Text="{Binding TotalVenda, StringFormat='De: R$ {0:N2}'}"
                                       FontSize="18" Foreground="#ef4444" TextDecorations="Strikethrough" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TemDesconto}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock FontSize="18" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Total a Pagar:"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TemDesconto}" Value="True">
                                                <Setter Property="Text" Value="Total c/ Desconto:"/>
                                                <Setter Property="Foreground" Value="#16a34a"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ValorComDesconto, StringFormat='R$ {0:N2}'}"
                                       FontSize="42" FontWeight="Black" Foreground="{StaticResource TtBlue}" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ToggleComissaoCommand}"
                                Width="45" Height="45" Background="{DynamicResource CardBgAlt}"
                                BorderThickness="0" Cursor="Hand" FontSize="20" IsTabStop="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                        <TextBlock Text="🤑" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0" Margin="0,0,0,10">
                    <StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="👤 Cliente (Opcional)" FontWeight="Bold" Foreground="{StaticResource TtBlue}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,0,10,0">
                                    <TextBox x:Name="TxtBuscaClienteFinalizar"
                                             Text="{Binding ClienteBusca, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="8,0" Height="40" VerticalContentAlignment="Center"
                                             Background="{DynamicResource FundoInput}"
                                             BorderBrush="{DynamicResource BordaInput}" BorderThickness="1"
                                             TabIndex="0" PreviewKeyDown="TxtBuscaCliente_PreviewKeyDown"/>
                                    <Popup IsOpen="{Binding ClienteListaAberta}"
                                           PlacementTarget="{Binding ElementName=TxtBuscaClienteFinalizar}"
                                           Placement="Bottom" StaysOpen="False"
                                           MinWidth="{Binding ElementName=TxtBuscaClienteFinalizar, Path=ActualWidth}">
                                        <Border Background="{DynamicResource CardBg}"
                                                BorderBrush="{DynamicResource BordaInput}" BorderThickness="1" MaxHeight="250">
                                            <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.15" ShadowDepth="2"/></Border.Effect>
                                            <ListBox x:Name="ListaClientesFinalizar"
                                                     ItemsSource="{Binding ClientesFiltrados}"
                                                     PreviewKeyDown="ListaClientes_PreviewKeyDown"
                                                     BorderThickness="0" Background="Transparent"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="12,8" Cursor="Hand" Background="Transparent">
                                                            <Border.InputBindings>
                                                                <MouseBinding Gesture="LeftClick"
                                                                              Command="{Binding DataContext.SelecionarClienteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              CommandParameter="{Binding}"/>
                                                            </Border.InputBindings>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                                           Foreground="{DynamicResource TextDark}"/>
                                                                <TextBlock Text="{Binding Document}" FontSize="11"
                                                                           Foreground="{DynamicResource TextMuted}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <Button Grid.Column="1" Content="+" Command="{Binding QuickCreateCustomerCommand}"
                                        Width="45" Height="40" FontSize="20" Style="{StaticResource PrimaryButton}"
                                        Background="#3B82F6" ToolTip="Cadastrar Novo Cliente" IsTabStop="False"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="💰 Forma de Pagamento" FontWeight="Bold" Foreground="{StaticResource TtBlue}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtValor" Grid.Column="0"
                                         Text="{Binding ValorDigitado, UpdateSourceTrigger=LostFocus}"
                                         FontSize="14" Padding="8,0" Height="40" VerticalContentAlignment="Center" Margin="0,0,10,0"
                                         Background="{DynamicResource FundoInput}"
                                         BorderBrush="{DynamicResource BordaInput}" BorderThickness="1"
                                         GotFocus="TextBox_GotFocus" TabIndex="2"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding FormasPagamento}"
                                          SelectedItem="{Binding FormaPagamento}"
                                          FontSize="14" Padding="8,0" Height="40" VerticalContentAlignment="Center" Margin="0,0,10,0"
                                          Background="{DynamicResource FundoInput}"
                                          Foreground="{DynamicResource TextDark}"
                                          BorderBrush="{DynamicResource BordaInput}" BorderThickness="1"
                                          TabIndex="3"/>
                                <Button x:Name="BtnAddPagamento" Grid.Column="2" Content="+"
                                        Command="{Binding AdicionarPagamentoCommand}"
                                        Width="45" Height="40" FontSize="20" Style="{StaticResource PrimaryButton}"
                                        Background="#3B82F6" TabIndex="4" Click="BtnAddPagamento_Click"/>
                            </Grid>

                            <Border Background="{DynamicResource FundoRodape}" Padding="15" CornerRadius="8"
                                    BorderBrush="{DynamicResource BordaCard}" BorderThickness="1">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding Pagamentos}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,5">
                                                    <TextBlock Text="{Binding Forma}" FontWeight="Bold"
                                                               Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="{Binding Valor, StringFormat='R$ {0:N2}'}"
                                                               Foreground="{DynamicResource CorAcento}" HorizontalAlignment="Center"/>
                                                    <Button Content="✖" Foreground="#dc2626" Background="Transparent" BorderThickness="0"
                                                            Command="{Binding DataContext.RemoverPagamentoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" HorizontalAlignment="Right" Cursor="Hand" FontWeight="Bold"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Separator Margin="0,10" Background="{DynamicResource BordaCard}"/>
                                    <Grid>
                                        <TextBlock Text="{Binding FaltaPagar, StringFormat='Falta: R$ {0:N2}'}"
                                                   Foreground="#dc2626" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="{Binding Troco, StringFormat='Troco: R$ {0:N2}'}"
                                                   Foreground="#059669" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Troco}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="🏷️ Desconto de Cortesia" FontWeight="Bold" Foreground="{StaticResource TtBlue}" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Porcentagem (%)" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding DescontoPercentual, UpdateSourceTrigger=LostFocus, StringFormat='N2'}"
                                             Background="{DynamicResource FundoInput}"
                                             Foreground="{DynamicResource TextDark}" FontWeight="Bold"
                                             FontSize="14" Padding="8,0" Height="40" VerticalContentAlignment="Center"
                                             BorderBrush="{DynamicResource BordaInput}" BorderThickness="1"
                                             TabIndex="5"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="ou" FontSize="12" Foreground="{DynamicResource TextMuted}" 
                                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12"/>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Valor (R$)" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding DescontoReais, UpdateSourceTrigger=LostFocus, StringFormat='N2'}"
                                             Background="{DynamicResource FundoInput}"
                                             Foreground="{DynamicResource TextDark}" FontWeight="Bold"
                                             FontSize="14" Padding="8,0" Height="40" VerticalContentAlignment="Center"
                                             BorderBrush="{DynamicResource BordaInput}" BorderThickness="1"
                                             TabIndex="6"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Border Background="{DynamicResource FundoRodape}" Padding="10" CornerRadius="8" Margin="0,0,0,5">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="🚚 Entregar no endereço?" VerticalAlignment="Center"
                                               FontWeight="Bold" Foreground="{StaticResource TtBlue}"/>
                                    <ComboBox x:Name="CmbEntrega" Grid.Column="1" Width="80" SelectedIndex="0"
                                              SelectionChanged="CmbEntrega_SelectionChanged" TabIndex="7"
                                              Height="35" VerticalContentAlignment="Center"
                                              Background="{DynamicResource FundoInput}"
                                              Foreground="{DynamicResource TextDark}"
                                              BorderBrush="{DynamicResource BordaCard}" BorderThickness="1"
                                              Padding="8,0" FontSize="13" FontWeight="Bold">
                                        <ComboBoxItem Content="Não"/>
                                        <ComboBoxItem Content="Sim"/>
                                    </ComboBox>
                                </Grid>
                                <TextBox x:Name="TxtEndereco" Text="{Binding EnderecoEntrega}"
                                         Visibility="{Binding EnderecoVisivel}"
                                         Margin="0" Padding="8,4" AcceptsReturn="True" Height="45" TabIndex="8"
                                         Background="{DynamicResource FundoInput}"
                                         BorderBrush="{DynamicResource BordaInput}"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Observação Geral do Pedido ─────────────────── -->
                        <Border Background="{DynamicResource CardBg}" CornerRadius="10" Padding="14" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="📝 Observação Geral do Pedido"
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,0,0,6"/>
                                <TextBox Text="{Binding ObservacaoGeral, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,6" AcceptsReturn="True" Height="55" TabIndex="9"
                                         Background="{DynamicResource FundoInput}"
                                         BorderBrush="{DynamicResource BordaInput}"
                                         TextWrapping="Wrap"
                                         ToolTip="Aparece no recibo acima dos itens (ex: observação de entrega, prazo)"
                                         FontSize="13"/>
                                <TextBlock Text="Aparece no topo do recibo, antes dos itens."
                                           FontSize="10" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="1" Margin="0,5,0,0">
                    <!-- Sprint Q: Fidelidade -->
                    <Button Command="{Binding AbrirFidelidadeCommand}" Height="38" Margin="0,0,0,8"
                            Background="#7C3AED" Foreground="White" BorderThickness="0" Cursor="Hand"
                            ToolTip="Consultar pontos e aplicar desconto de fidelidade">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <Grid Margin="16,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="⭐" Margin="0,0,8,0"/>
                                            <TextBlock Text="FIDELIDADE" FontWeight="Bold" FontSize="13"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DescontoFidelidade, StringFormat='Desconto: R$ {0:N2}'}"
                                                   FontSize="11" Opacity="0.9"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding FinalizarNormalCommand}" Height="45" Margin="0,0,0,10"
                            Background="#64748B" Foreground="White" BorderThickness="0" Cursor="Hand" TabIndex="9">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <Grid Margin="20,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="📄" Margin="0,0,10,0"/>
                                            <TextBlock Text="VENDA NORMAL (RECIBO)" FontWeight="Bold" FontSize="14"/>
                                        </StackPanel>
                                        <TextBlock Text="Sem valor fiscal" FontSize="11" Opacity="0.8"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <UniformGrid Columns="2">
                        <Button Command="{Binding FinalizarNfceCommand}" Height="50" Margin="0,0,5,0"
                                Style="{StaticResource GreenButton}" TabIndex="10">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🧾 NFC-e" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                                <TextBlock Text="(Cupom Consumidor)" FontSize="11" Opacity="0.9" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding FinalizarNfeCommand}" Height="50" Margin="5,0,0,0"
                                Style="{StaticResource PrimaryButton}" Background="#3B82F6" TabIndex="11">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="📄 NF-e" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                                <TextBlock Text="(Nota A4 Completa)" FontSize="11" Opacity="0.9" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Grid>

            <Border Grid.Column="2" Visibility="{Binding ComissaoVisivel}"
                    Background="{DynamicResource CardBg}" Width="300" CornerRadius="15"
                    Margin="15,0,0,0" Padding="20" BorderBrush="#4ade80" BorderThickness="3">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.4" Color="#4ade80" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🤑 Previsão de Ganho" FontSize="18" FontWeight="Bold"
                               Foreground="#4ade80" Margin="0,0,0,15"/>
                    <ScrollViewer Height="350" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                        <ItemsControl ItemsSource="{Binding ItensCarrinho}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding ProductName}" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" FontSize="12"/>
                                            <TextBlock Text="Geral (1.0%)" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Foreground="#16a34a" FontWeight="Bold" VerticalAlignment="Center"
                                                   Text="{Binding Total, StringFormat='+ R$ {0:N2}'}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border Background="#14532d" Padding="15" CornerRadius="8"
                            BorderBrush="#166534" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="COMISSÃO TOTAL" FontSize="12" Foreground="#4ade80"
                                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TotalComissao, StringFormat='R$ {0:N2}'}"
                                       FontSize="32" FontWeight="Black" Foreground="#4ade80" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="* Vendedor: Você" FontSize="11" Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>