<UserControl x:Class="ERP.WPF.Views.OperadoraRecebimentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBgAlt}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="OPERADORAS DE RECEBIMENTO" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextDark}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="Cadastro de preparação — hoje só guarda os prazos de cada operadora (Stone, Cielo, Mercado Pago). Nenhuma venda usa isso ainda; serve de base para quando 'Recebíveis de Operadora' existir."
                   Foreground="{DynamicResource TextMuted}" FontSize="12" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,20"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBg}" Padding="20" CornerRadius="8" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="NOVA OPERADORA" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Nome (Ex: Stone, Cielo)" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NovoNome, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Prazo Débito (dias)" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NovoPrazoDebito, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Prazo Crédito à Vista (dias)" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NovoPrazoCreditoVista, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Prazo Crédito Parcelado (dias)" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NovoPrazoCreditoParcelado, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                    <CheckBox Content="Antecipação automática" IsChecked="{Binding NovaAntecipacaoAutomatica}" Margin="0,0,0,15"/>

                    <TextBlock Text="Taxa Débito (%)" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NovaTaxaDebito, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Taxa Crédito à Vista (%)" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NovaTaxaCreditoVista, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Taxa Crédito Parcelado (%)" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NovaTaxaCreditoParcelado, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Conta que recebe o depósito" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding ContasBancarias}" SelectedItem="{Binding NovaContaDestino}"
                              DisplayMemberPath="Apelido" Height="30" Margin="0,5,0,20" VerticalContentAlignment="Center"/>

                    <Button Content="CADASTRAR OPERADORA" Command="{Binding CriarCommand}"
                            Background="#3B82F6" Foreground="White" FontWeight="Bold" Height="40" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <ItemsControl Grid.Column="2" ItemsSource="{Binding Operadoras}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="16" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Nome}" FontWeight="Bold" FontSize="15"/>
                                        <TextBlock Text=" ⭐ PADRÃO" FontSize="10" FontWeight="Bold" Foreground="#F59E0B" VerticalAlignment="Center"
                                                   Visibility="{Binding OperadoraPadrao, Converter={StaticResource BoolToVisibility}}"/>
                                    </StackPanel>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0">
                                        <Run Text="Débito: "/><Run Text="{Binding PrazoDebitoDias}"/><Run Text="d  •  "/>
                                        <Run Text="Crédito à vista: "/><Run Text="{Binding PrazoCreditoVistaDias}"/><Run Text="d  •  "/>
                                        <Run Text="Parcelado: "/><Run Text="{Binding PrazoCreditoParceladoDias}"/><Run Text="d"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0">
                                        <Run Text="Taxas: Débito "/><Run Text="{Binding TaxaDebitoPercentual, StringFormat={}{0}%}"/>
                                        <Run Text="  •  Crédito à vista "/><Run Text="{Binding TaxaCreditoVistaPercentual, StringFormat={}{0}%}"/>
                                        <Run Text="  •  Parcelado "/><Run Text="{Binding TaxaCreditoParceladoPercentual, StringFormat={}{0}%}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0">
                                        <Run Text="Deposita em: "/><Run Text="{Binding ContaDestinoApelido}"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <Button Content="⭐ PADRÃO" Command="{Binding DataContext.DefinirPadraoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Background="Transparent" BorderBrush="#F59E0B" BorderThickness="1"
                                            Foreground="#F59E0B" Height="32" Margin="0,0,0,6" Cursor="Hand"/>
                                    <Button Content="INATIVAR" Command="{Binding DataContext.InativarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Background="Transparent" BorderBrush="#EF4444" BorderThickness="1"
                                            Foreground="#EF4444" Height="32" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
