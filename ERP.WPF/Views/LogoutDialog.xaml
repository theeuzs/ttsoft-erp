<Window x:Class="ERP.WPF.Views.LogoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" Width="420" Height="220"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize">
    
    <Border Background="{DynamicResource CardBg}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BordaCard}" Padding="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.15" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <Border Background="#FEE2E2" CornerRadius="8" Width="40" Height="40" Margin="0,0,15,0">
                    <TextBlock Text="🚪" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Sair do Sistema" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextDark}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="1" Text="Tem certeza que deseja encerrar a sessão atual? Um backup de segurança será realizado antes de fechar." 
                       TextWrapping="Wrap" FontSize="14" Foreground="{DynamicResource TextMuted}" LineHeight="20" Margin="0,5,0,0"/>

            <StackPanel x:Name="PanelBotoes" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="CANCELAR" Click="BtnCancel_Click" Width="110" Height="40" Background="{DynamicResource CardBgAlt}" Foreground="{DynamicResource TextMuted}" FontWeight="Bold" BorderThickness="0" Margin="0,0,12,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="SIM, SAIR" Click="BtnConfirm_Click" Width="120" Height="40" Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <StackPanel x:Name="PanelLoading" Grid.Row="2" Orientation="Vertical" Visibility="Collapsed" Margin="0,15,0,0" VerticalAlignment="Center">
                <TextBlock Text="Salvando backup de segurança..." FontSize="13" Foreground="#3B82F6" FontWeight="Bold" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Height="8" Foreground="#3B82F6" Background="#E2E8F0" BorderThickness="0">
                    <ProgressBar.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </ProgressBar.Resources>
                </ProgressBar>
            </StackPanel>

        </Grid>
    </Border>
</Window>