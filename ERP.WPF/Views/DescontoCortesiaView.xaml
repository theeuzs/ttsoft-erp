<Window x:Class="ERP.WPF.Views.DescontoCortesiaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aviso de Desconto" Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">
    
    <Border Background="#0F172A" CornerRadius="16" BorderBrush="#EAB308" BorderThickness="2" Padding="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Opacity="0.5" ShadowDepth="5" Color="Black"/>
        </Border.Effect>
        
        <StackPanel>
            <TextBlock Text="⚠️ ACESSO RESTRITO" Foreground="#EAB308" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
            
            <TextBlock Text="Seu perfil não possui permissão para aplicar descontos livres nesta venda." 
                       Foreground="{DynamicResource TextMuted}" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" Margin="0,15,0,0"/>

            <Border Background="#1E293B" CornerRadius="8" Padding="15" Margin="0,20,0,20">
                <StackPanel>
                    <TextBlock Text="No entanto, você pode aplicar um desconto de cortesia de até 5% para fechar o negócio." 
                               Foreground="#38BDF8" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center"/>
                    
                    <Grid Margin="0,20,0,0" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Porcentagem (%)" Foreground="{DynamicResource TextMuted}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtDescontoPerc" Background="{DynamicResource CardBg}" FontSize="18" FontWeight="Black" Foreground="#0F172A" TextAlignment="Center" Padding="5" 
                                     TextChanged="TxtDescontoPerc_TextChanged" KeyDown="Inputs_KeyDown"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="ou" Foreground="{DynamicResource TextMuted}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"/>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Valor (R$)" Foreground="{DynamicResource TextMuted}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtDescontoDinheiro" Background="{DynamicResource CardBg}" FontSize="18" FontWeight="Black" Foreground="#0F172A" TextAlignment="Center" Padding="5" 
                                     TextChanged="TxtDescontoDinheiro_TextChanged" KeyDown="Inputs_KeyDown"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" Content="CANCELAR" Click="BtnCancelar_Click" 
                        Background="#334155" Foreground="White" FontWeight="Bold" Padding="10,12" BorderThickness="0" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
                
                <Button Grid.Column="2" Content="LIBERAR CORTESIA" Click="BtnLiberar_Click" 
                        Background="#EAB308" Foreground="#0F172A" FontWeight="Black" Padding="10,12" BorderThickness="0" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>