<Window x:Class="ERP.WPF.Views.PagarDespesaDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ERP.WPF.Converters"
        Title="Pagar Despesa" Height="400" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8FAFC">
    <Window.Resources>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Pagar Despesa" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="{Binding Descricao}" FontSize="13" Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding ValorFormatado}" FontSize="22" FontWeight="Bold" Foreground="#DC2626" Margin="0,8,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <TextBlock Text="De onde sai esse pagamento?" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <RadioButton Content="Caixa atual (dinheiro em espécie)" GroupName="origem"
                         IsChecked="{Binding UsarConta, Converter={StaticResource InverseBool}}"
                         Margin="0,0,0,12" FontSize="13"/>

            <RadioButton Content="Conta bancária" GroupName="origem"
                         IsChecked="{Binding UsarConta}" Margin="0,0,0,8" FontSize="13"/>

            <ComboBox ItemsSource="{Binding ContasBancarias}" SelectedItem="{Binding ContaSelecionada}"
                      DisplayMemberPath="Apelido" IsEnabled="{Binding UsarConta}"
                      Height="34" Margin="20,0,0,0" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Command="{Binding CancelarCommand}"
                    Width="100" Height="38" Margin="0,0,10,0"
                    Background="#E2E8F0" Foreground="#334155" Cursor="Hand"/>
            <Button Content="Confirmar Pagamento" Command="{Binding ConfirmarCommand}"
                    Width="190" Height="38" Background="#DC2626" Foreground="White"
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
