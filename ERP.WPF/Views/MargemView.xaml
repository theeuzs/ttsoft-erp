<UserControl x:Class="ERP.WPF.Views.MargemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBgAlt}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <StackPanel>
                <TextBlock Text="Margem por Produto" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextDark}"/>
                <TextBlock Text="Análise de lucro e rentabilidade por produto"
                           FontSize="13" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Content="↻ Atualizar" Command="{Binding CarregarCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{DynamicResource CorAcento}" Foreground="White"
                    FontWeight="Bold" Height="34" Padding="16,0" BorderThickness="0" Cursor="Hand">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
            </Button>
        </Grid>

        <!-- Cards -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="📊 MARGEM MÉDIA" FontSize="11" FontWeight="Bold" Foreground="#3B82F6"/>
                    <TextBlock Text="{Binding MargemMedia, StringFormat='{}{0:N1}%'}"
                               FontSize="28" FontWeight="Black" Foreground="#3B82F6" Margin="0,8,0,0"/>
                    <TextBlock Text="de todos os produtos" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="💰 LUCRO POTENCIAL" FontSize="11" FontWeight="Bold" Foreground="#16A34A"/>
                    <TextBlock Text="{Binding LucroPotencial, StringFormat='R$ {0:N2}'}"
                               FontSize="22" FontWeight="Black" Foreground="#16A34A" Margin="0,8,0,0"/>
                    <TextBlock Text="se vender todo o estoque" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="#FEF2F2" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="🔴 MARGEM BAIXA (&lt;15%)" FontSize="11" FontWeight="Bold" Foreground="#DC2626"/>
                    <TextBlock Text="{Binding ProdutosMargemBaixa}"
                               FontSize="28" FontWeight="Black" Foreground="#DC2626" Margin="0,8,0,0"/>
                    <TextBlock Text="produtos precisam de ajuste" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Busca -->
        <Border Grid.Row="4" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding FiltroBusca, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8" FontSize="14" BorderBrush="{DynamicResource BordaInput}"
                         VerticalContentAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="🔍 Buscar por nome, SKU ou categoria"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- Tabela -->
        <Border Grid.Row="6" Background="{DynamicResource CardBg}" CornerRadius="12">
            <DataGrid ItemsSource="{Binding Produtos}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="Transparent" BorderThickness="0"
                      GridLinesVisibility="Horizontal" RowHeight="44"
                      AlternatingRowBackground="{DynamicResource CardBgAlt}" CanUserResizeRows="False">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Produto" Binding="{Binding Nome}" Width="3*" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="80"/>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="130"/>
                    <DataGridTextColumn Header="Custo" Binding="{Binding PrecoCusto, StringFormat='R$ {0:N2}'}" Width="100"/>
                    <DataGridTextColumn Header="Venda" Binding="{Binding PrecoVenda, StringFormat='R$ {0:N2}'}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#16A34A"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Lucro/Un" Binding="{Binding LucroUnit, StringFormat='R$ {0:N2}'}" Width="100"/>
                    <DataGridTextColumn Header="Margem" Binding="{Binding Margem, StringFormat='{}{0:N1}%'}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Black"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Classe" Binding="{Binding ClasseMargem}" Width="80"/>
                    <DataGridTextColumn Header="Estoque" Binding="{Binding Estoque, StringFormat='N2'}" Width="80"/>
                    <DataGridTextColumn Header="Lucro Potencial" Binding="{Binding LucroPotencial, StringFormat='R$ {0:N2}'}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#3B82F6"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
