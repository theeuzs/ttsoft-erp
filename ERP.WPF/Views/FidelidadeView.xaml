<Window x:Class="ERP.WPF.Views.FidelidadeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⭐ Programa de Fidelidade" Height="480" Width="480"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8FAFC">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="⭐ Programa de Fidelidade" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="{Binding NomeCliente}" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Saldo de pontos -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Background="#EFF6FF"
                BorderBrush="#BFDBFE" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Saldo de Pontos" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock Text="{Binding Saldo, StringFormat='{}{0:N0} pts'}"
                               FontSize="32" FontWeight="Black" Foreground="#1E62A6"/>
                    <TextBlock Text="{Binding ValorEquivalente, StringFormat='Equivale a {0:C}'}"
                               FontSize="12" Foreground="#3B82F6"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="1 real = 1 ponto" FontSize="11" Foreground="#94A3B8" TextAlignment="Right"/>
                    <TextBlock Text="100 pts = R$ 1,00" FontSize="11" Foreground="#94A3B8" TextAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Resgate -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Resgatar Pontos" FontSize="14" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Quantidade de pontos" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding PontosParaResgatarBinding, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="18" FontWeight="Bold" Padding="10,8"
                                 BorderBrush="#E2E8F0" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Bottom">
                        <TextBlock Text="Desconto equivalente" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding DescontoEquivalente, StringFormat='= {0:C}'}"
                                   FontSize="18" FontWeight="Bold" Foreground="#10B981"
                                   Padding="10,8"/>
                    </StackPanel>
                </Grid>

                <!-- Aviso de saldo insuficiente -->
                <Border Background="#FEE2E2" CornerRadius="6" Padding="10,6" Margin="0,0,0,8"
                        Visibility="{Binding ErroVisivel, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErroMsg}" Foreground="#991B1B" FontSize="12"/>
                </Border>

                <Button Content="⭐ Aplicar Desconto de Pontos"
                        Command="{Binding ResgatarCommand}"
                        Height="44" Background="#10B981" Foreground="White"
                        FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- Botão fechar -->
        <Button Grid.Row="3" Content="Fechar" Click="BtnFechar_Click"
                Height="38" Background="#F1F5F9" Foreground="#64748B"
                BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
            <Button.Resources>
                <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
