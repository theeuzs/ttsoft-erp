<Window x:Class="ERP.WPF.Views.TemaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Personalização do Sistema" Height="700" MinHeight="600" Width="700"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="20"/>   <RowDefinition Height="*"/>    <RowDefinition Height="20"/>   <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Personalização do Sistema" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Configure o visual do ERP para cada cliente." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,-14,0" Padding="0,0,14,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Nome do Sistema" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNome" Height="38" Padding="10,0" VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E1" TextChanged="AtualizarPreview" Margin="0,0,0,16"/>

                    <TextBlock Text="Cor da Barra Lateral" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtCorPrimaria" Height="38" Padding="10,0" VerticalContentAlignment="Center"
                                 BorderBrush="#CBD5E1" TextChanged="AtualizarPreview" FontFamily="Consolas"/>
                        <Border x:Name="PreviewCorPrimaria" Grid.Column="2" Height="38" Width="44"
                                CornerRadius="4" BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </Grid>
                    <TextBlock Text="Exemplos: #1E3A5F (azul escuro)  #0F4C2A (verde)  #4A1942 (roxo)"
                               FontSize="10" Foreground="#94A3B8" Margin="0,0,0,16"/>

                    <TextBlock Text="Cor de Destaque (botões, links)" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtCorAcento" Height="38" Padding="10,0" VerticalContentAlignment="Center"
                                 BorderBrush="#CBD5E1" TextChanged="AtualizarPreview" FontFamily="Consolas"/>
                        <Border x:Name="PreviewCorAcento" Grid.Column="2" Height="38" Width="44"
                                CornerRadius="4" BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </Grid>
                    <TextBlock Text="Exemplos: #3B82F6 (azul)  #16A34A (verde)  #DC2626 (vermelho)"
                               FontSize="10" Foreground="#94A3B8" Margin="0,0,0,16"/>

                    <Border Background="#F1F5F9" CornerRadius="8" Padding="14,12" Margin="0,0,0,16"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="🌙 Modo Escuro" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                                <TextBlock Text="Fundo escuro, menos cansativo para uso prolongado."
                                           FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" x:Name="BordaToggle" Width="48" Height="26"
                                    CornerRadius="13" Background="#CBD5E1" Cursor="Hand"
                                    MouseLeftButtonUp="Toggle_Click" VerticalAlignment="Center">
                                <Border x:Name="CirculoToggle" Width="20" Height="20" CornerRadius="10"
                                        Background="White" HorizontalAlignment="Left" Margin="3,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2"/>
                                    </Border.Effect>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>

                    <TextBlock Text="TEMAS PRONTOS" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <Button Content="🔵 Clássico Azul"  Click="AplicarPreset" Tag="#1E3A5F|#3B82F6"
                                Margin="0,0,8,8" Padding="10,6" Background="#EFF6FF" BorderBrush="#BFDBFE" Cursor="Hand"/>
                        <Button Content="🟢 Verde Floresta" Click="AplicarPreset" Tag="#0F4C2A|#16A34A"
                                Margin="0,0,8,8" Padding="10,6" Background="#F0FDF4" BorderBrush="#BBF7D0" Cursor="Hand"/>
                        <Button Content="🟤 Terracota"      Click="AplicarPreset" Tag="#7C2D12|#EA580C"
                                Margin="0,0,8,8" Padding="10,6" Background="#FFF7ED" BorderBrush="#FED7AA" Cursor="Hand"/>
                        <Button Content="⚫ Grafite"         Click="AplicarPreset" Tag="#1C1917|#6366F1"
                                Margin="0,0,8,8" Padding="10,6" Background="#F8FAFC" BorderBrush="#E2E8F0" Cursor="Hand"/>
                        <Button Content="🟣 Roxo Elegante"  Click="AplicarPreset" Tag="#4A1942|#9333EA"
                                Margin="0,0,8,8" Padding="10,6" Background="#FAF5FF" BorderBrush="#E9D5FF" Cursor="Hand"/>
                        <Button Content="🌑 Dark Pro"       Click="AplicarPreset" Tag="#0F172A|#6366F1|dark"
                                Margin="0,0,8,8" Padding="10,6" Background="#1E293B" Foreground="#94A3B8" BorderBrush="#334155" Cursor="Hand"/>
                    </WrapPanel>
                </StackPanel>

                <Grid Grid.Column="2" VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="PREVIEW" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                    <Border Grid.Row="2" CornerRadius="10" ClipToBounds="True" BorderBrush="#CBD5E1" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="PreviewSidebar" Grid.Column="0" CornerRadius="10,0,0,10">
                                <StackPanel Margin="8,16,8,16"> <TextBlock x:Name="PreviewNomeSistema" FontSize="9" FontWeight="Bold"
                                               Foreground="White" TextWrapping="Wrap" TextAlignment="Center"
                                               Margin="0,0,0,16"/>
                                    <Border Background="#FFFFFF22" CornerRadius="4" Padding="6,4" Margin="0,0,0,4">
                                        <TextBlock Text="Dashboard" FontSize="9" Foreground="White"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,4" Margin="0,0,0,4">
                                        <TextBlock Text="PDV" FontSize="9" Foreground="#FFFFFF99"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,4" Margin="0,0,0,4">
                                        <TextBlock Text="Produtos" FontSize="9" Foreground="#FFFFFF99"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,4" Margin="0,0,0,4">
                                        <TextBlock Text="Compras" FontSize="9" Foreground="#FFFFFF99"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Border x:Name="PreviewConteudo" Grid.Column="1" CornerRadius="0,10,10,0" Background="White">
                                <StackPanel Margin="12,12,12,12">
                                    <TextBlock x:Name="PreviewTextoTitulo" Text="Ponto de Venda"
                                               FontSize="11" FontWeight="Bold" Margin="0,0,0,8" Foreground="#1E293B"/>
                                    <Border x:Name="PreviewInput" Height="28" CornerRadius="4" Margin="0,0,0,6" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <TextBlock Text="Buscar produto..." FontSize="9" Foreground="#94A3B8"
                                                   VerticalAlignment="Center" Margin="8,0"/>
                                    </Border>
                                    <Border x:Name="PreviewBotao" Height="28" CornerRadius="4">
                                        <TextBlock Text="FINALIZAR VENDA" FontSize="9" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <Button Content="Cancelar" Click="Cancelar_Click"
                    Height="40" Background="#F1F5F9" Foreground="#475569" BorderBrush="#CBD5E1" Cursor="Hand"/>
            <Button Grid.Column="2" Content="✅  Salvar e Aplicar" Click="Salvar_Click"
                    Height="40" Background="#16A34A" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>