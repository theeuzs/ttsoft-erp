<UserControl x:Class="ERP.WPF.Views.SpedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource FundoPrincipal}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">

            <!-- Cabeçalho -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="📊" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="SPED Fiscal" FontSize="24" FontWeight="Black"
                               Foreground="{DynamicResource TextDark}"/>
                    <TextBlock Text="Escrituração Fiscal Digital — EFD-ICMS/IPI e EFD-Contribuições"
                               FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Status -->
            <Border Background="{DynamicResource CardBgAlt}" CornerRadius="8"
                    Padding="14" Margin="0,0,0,20"
                    BorderBrush="{DynamicResource BordaInput}" BorderThickness="1">
                <TextBlock Text="{Binding Status}" FontSize="13"
                           Foreground="{DynamicResource TextDark}" TextWrapping="Wrap"/>
            </Border>

            <!-- Tipo de arquivo -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                    Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BordaInput}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="TIPO DE ARQUIVO" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource CorAcento}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton Content="EFD-ICMS/IPI  (Entrega mensal ao SEFAZ)"
                                     IsChecked="{Binding GerarEfdIcms}"
                                     FontSize="13" Foreground="{DynamicResource TextDark}"
                                     Margin="0,0,24,0"/>
                        <RadioButton Content="EFD-Contribuições  (PIS/COFINS — Receita Federal)"
                                     IsChecked="{Binding GerarEfdContrib}"
                                     FontSize="13" Foreground="{DynamicResource TextDark}"/>
                    </StackPanel>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}"
                               Text="Para Simples Nacional: EFD-ICMS é obrigatória em MG, MT, MS, PR e RS. EFD-Contribuições geralmente dispensada — confirme com seu contador."/>
                </StackPanel>
            </Border>

            <!-- Período -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                    Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BordaInput}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="PERÍODO" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource CorAcento}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Data Início" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding DataInicio}" Width="160" Height="36"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Data Fim" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding DataFim}" Width="160" Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Dados da Empresa -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                    Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BordaInput}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="DADOS DA EMPRESA" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource CorAcento}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Razão Social" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding RazaoSocial}" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CNPJ" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CNPJ}" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="IE (Inscrição Estadual)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding IE}" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Endereço completo" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Endereco}" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Código Município IBGE" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding CodigoMunicipio}" Style="{StaticResource InputStyle}"
                                     ToolTip="Ex: 4106902 = Curitiba/PR. Consulte tabela IBGE."/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Dados do Contabilista -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                    Padding="20" Margin="0,0,0,24"
                    BorderBrush="{DynamicResource BordaInput}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="CONTABILISTA (OPCIONAL)" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource CorAcento}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nome" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ContabNome}" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CPF" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ContabCpf}" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="CRC" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ContabCrc}" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="E-mail" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ContabEmail}" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Telefone" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ContabFone}" Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Botão gerar -->
            <Button Command="{Binding GerarCommand}"
                    HorizontalAlignment="Left" Padding="32,12"
                    Background="{DynamicResource CorAcento}" Foreground="White"
                    FontSize="15" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⬇️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Gerar e Salvar Arquivo SPED" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBlock Margin="0,12,0,0" FontSize="11" Foreground="{DynamicResource TextMuted}"
                       TextWrapping="Wrap"
                       Text="⚠ O arquivo gerado contempla somente vendas com NF-e emitida (status Nota Emitida). Vendas sem nota não são incluídas por não constarem nos registros fiscais."/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
