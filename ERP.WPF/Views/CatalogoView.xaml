<UserControl x:Class="ERP.WPF.Views.CatalogoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource FundoGeral}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="{DynamicResource CardBg}" Padding="20,14" Margin="0,0,0,12">
            <Grid>
                <StackPanel>
                    <TextBlock Text="🏠 Catálogo de Pisos e Revestimentos"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="{Binding TotalProdutos, StringFormat='{}{0} produtos encontrados'}"
                               FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Filtrar:" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMuted}" Margin="0,0,8,0"/>
                    <TextBox Width="200" Text="{Binding FiltroBusca, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" Background="{DynamicResource FundoInput}"
                             BorderBrush="{DynamicResource BordaInput}"
                             VerticalAlignment="Center"/>
                    <Button Content="🔍" Command="{Binding BuscarCommand}"
                            Margin="8,0,0,0" Padding="10,6" Cursor="Hand"
                            Background="#1E62A6" Foreground="White" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filtros de categoria/dimensão -->
        <Border Grid.Row="1" Background="{DynamicResource CardBg}" Padding="16,10" Margin="0,0,0,12">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="Categoria:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,8,0" FontSize="13"/>
                <ComboBox Width="180" SelectedItem="{Binding CategoriaFiltro}"
                          Margin="0,0,16,0" Padding="8,4"
                          Background="{DynamicResource FundoInput}">
                    <ComboBoxItem Content="Todos"/>
                    <ComboBoxItem Content="Pisos"/>
                    <ComboBoxItem Content="Revestimentos"/>
                    <ComboBoxItem Content="Porcelanatos"/>
                    <ComboBoxItem Content="Cerâmicas"/>
                    <ComboBoxItem Content="Mosaicos"/>
                </ComboBox>
                <TextBlock Text="Ordenar:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,8,0" FontSize="13"/>
                <ComboBox Width="150" SelectedItem="{Binding Ordenacao}" Padding="8,4"
                          Background="{DynamicResource FundoInput}">
                    <ComboBoxItem Content="Nome A-Z"/>
                    <ComboBoxItem Content="Menor Preço"/>
                    <ComboBoxItem Content="Maior Preço"/>
                    <ComboBoxItem Content="Estoque"/>
                </ComboBox>
            </WrapPanel>
        </Border>

        <!-- Grid de Cards visuais -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Produtos}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" Margin="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Margin="8" CornerRadius="12" Cursor="Hand"
                                Background="{DynamicResource CardBg}"
                                BorderThickness="2" BorderBrush="Transparent">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#1E62A6"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#1E62A6" BlurRadius="8"
                                                                      ShadowDepth="0" Opacity="0.3"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <!-- Imagem do produto -->
                                <Border CornerRadius="10,10,0,0" ClipToBounds="True" Height="160"
                                        Background="#F1F5F9">
                                    <Grid>
                                        <!-- Placeholder quando sem foto -->
                                        <TextBlock Text="📷" FontSize="48"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#CBD5E1"
                                                   Visibility="{Binding SemImagem, Converter={StaticResource BoolToVis}}"/>
                                        <!-- Foto do produto -->
                                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"
                                               Visibility="{Binding TemImagem, Converter={StaticResource BoolToVis}}"/>
                                        <!-- Badge "Em Campanha" -->
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Background="#F59E0B" CornerRadius="0,10,0,10"
                                                Padding="8,4"
                                                Visibility="{Binding EmCampanha, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="🔥 OFERTA" FontSize="10"
                                                       FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Informações -->
                                <StackPanel Margin="12,10">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold" FontSize="13"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Dimensões (da descrição detalhada) -->
                                    <TextBlock Text="{Binding DimensoesExibicao}"
                                               FontSize="11" Foreground="{DynamicResource TextMuted}"
                                               Margin="0,3,0,0"/>

                                    <Separator Margin="0,8" Background="{DynamicResource BordaInput}"/>

                                    <!-- Preço e estoque -->
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="{Binding SalePrice, StringFormat='R$ {0:N2}'}"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="#1E62A6"/>
                                            <TextBlock FontSize="11">
                                                <TextBlock.Inlines>
                                                    <Run Text="Estoque: "/>
                                                    <Run Text="{Binding Stock, StringFormat='{}{0:F0}', Mode=OneWay}"
                                                         Foreground="{Binding CorEstoque}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Unit, Mode=OneWay}"/>
                                                </TextBlock.Inlines>
                                            </TextBlock>
                                        </StackPanel>
                                        <!-- Botão adicionar ao carrinho -->
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Width="36" Height="36"
                                                Command="{Binding DataContext.AdicionarAoCarrinhoCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#1E62A6" BorderThickness="0"
                                                Cursor="Hand" ToolTip="Adicionar ao carrinho">
                                            <Button.Resources>
                                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="18"/></Style>
                                            </Button.Resources>
                                            <TextBlock Text="+" FontSize="20" Foreground="White"
                                                       HorizontalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading -->
        <Grid Grid.Row="2" Background="#80FFFFFF"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Carregando catálogo..." FontSize="16"
                           Foreground="{DynamicResource TextMuted}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
