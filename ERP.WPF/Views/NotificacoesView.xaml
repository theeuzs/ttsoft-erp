<UserControl x:Class="ERP.WPF.Views.NotificacoesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBgAlt}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <StackPanel>
                <TextBlock Text="🔔 Notificações" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextDark}"/>
                <TextBlock Text="Alertas automáticos do sistema — atualizado a cada 5 minutos"
                           FontSize="13" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="↻  Verificar Agora" Command="{Binding AtualizarCommand}"
                        Background="{DynamicResource CorAcento}" Foreground="White"
                        FontWeight="Bold" Height="34" Padding="16,0" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
                <Button Content="✓  Marcar todas como lidas" Command="{Binding MarcarTodasLidasCommand}"
                        Background="#E2E8F0" Foreground="{DynamicResource TextMuted}"
                        FontWeight="Bold" Height="34" Padding="16,0" BorderThickness="0" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Lista de notificações -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Estado vazio -->
                <Border Visibility="{Binding TemNotificacoes, Converter={StaticResource InverseBoolToVisibilityConverter}, FallbackValue=Collapsed}"
                        Background="{DynamicResource CardBg}" CornerRadius="16" Padding="60,50">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✅" FontSize="64" HorizontalAlignment="Center"/>
                        <TextBlock Text="Tudo em ordem!" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextDark}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        <TextBlock Text="Nenhum alerta no momento. O sistema está verificando automaticamente."
                                   FontSize="14" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"
                                   TextAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Cards de notificação -->
                <ItemsControl ItemsSource="{Binding Notificacoes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12" CornerRadius="14" Background="{DynamicResource CardBg}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="Black" Direction="270"/>
                                </Border.Effect>
                                <Grid>
                                    <!-- Barra colorida lateral -->
                                    <Border Width="5" HorizontalAlignment="Left" CornerRadius="14,0,0,14"
                                            Background="{Binding Cor}"/>

                                    <Grid Margin="20,18,20,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Ícone em círculo -->
                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Cor, Converter={StaticResource StringToColorConverter}}" Opacity="0.15"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Icone}" FontSize="22"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Conteúdo -->
                                        <StackPanel Grid.Column="1" Margin="16,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Titulo}" FontSize="15" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextDark}"/>
                                            <TextBlock Text="{Binding Mensagem}" FontSize="13"
                                                       Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Data -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <Border Background="{DynamicResource CardBgAlt}" CornerRadius="6" Padding="10,4">
                                                <TextBlock Text="{Binding DataFormatada}" FontSize="11"
                                                           Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
