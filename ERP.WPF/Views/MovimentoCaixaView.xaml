<Window x:Class="ERP.WPF.Views.MovimentoCaixaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TipoMovimento}" Height="350" Width="420"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent">
    
    <Border Background="{DynamicResource CardBg}" CornerRadius="12" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="2"/>
        </Border.Effect>
        <StackPanel Margin="25">
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border Background="{Binding CorTema}" CornerRadius="15" Width="30" Height="30" Margin="0,0,10,0">
                    <TextBlock Text="{Binding Icone}" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding TipoMovimento}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextDark}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Motivo / Descrição" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Descricao, UpdateSourceTrigger=PropertyChanged}" 
                     FontSize="14" Padding="10" Background="{DynamicResource FundoRodape}" BorderBrush="{DynamicResource BordaInput}" BorderThickness="1" Margin="0,0,0,15"/>

            <TextBlock Text="Valor (R$)" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Valor, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" 
                     FontSize="20" Padding="10" FontWeight="Bold" Foreground="{Binding CorTema}"
                     BorderBrush="{DynamicResource BordaInput}" BorderThickness="1" Background="{DynamicResource FundoRodape}" Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" Content="✓ Confirmar" Command="{Binding ConfirmarCommand}" 
                        Background="{Binding CorTema}" Foreground="White" FontWeight="Bold" 
                        FontSize="14" BorderThickness="0" Height="40" Margin="0,0,10,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"> <Setter Property="CornerRadius" Value="6"/> </Style>
                    </Button.Resources>
                </Button>
                
                <Button Grid.Column="1" Content="Cancelar" Click="Cancelar_Click" 
                        Background="{DynamicResource CardBgAlt}" Foreground="{DynamicResource TextMuted}" FontWeight="Bold" 
                        FontSize="14" BorderThickness="0" Height="40" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"> <Setter Property="CornerRadius" Value="6"/> </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>