<Window x:Class="ERP.WPF.Views.PixQrCodeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PIX — Aguardando Pagamento" Height="460" SizeToContent="Height" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F0FDF4">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="💚 PIX" FontSize="28" FontWeight="Bold"
                       Foreground="#16A34A" HorizontalAlignment="Center"/>
            <TextBlock Text="Aponte a câmera do celular para o QR Code"
                       FontSize="12" Foreground="#4B7A5C" HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Valor -->
        <Border Grid.Row="2" Background="#DCFCE7" CornerRadius="8" Padding="16,10">
            <TextBlock x:Name="TxtValor" FontSize="24" FontWeight="Bold"
                       Foreground="#15803D" HorizontalAlignment="Center"/>
        </Border>

        <!-- QR Code image -->
        <Border Grid.Row="4" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="12"
                HorizontalAlignment="Center"
                BorderBrush="#BBF7D0" BorderThickness="2">
            <Image x:Name="ImgQrCode" Width="180" Height="180" Stretch="Uniform"/>
        </Border>

        <!-- Chave PIX copiável -->
        <Border Grid.Row="6" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="12,8"
                BorderBrush="#D1FAE5" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="PIX Copia e Cola" FontSize="10" Foreground="#6B7280"/>
                    <TextBox x:Name="TxtPayload" FontSize="10" FontFamily="Consolas"
                             IsReadOnly="True" BorderThickness="0" Background="Transparent"
                             TextWrapping="Wrap" Foreground="#374151"
                             MaxHeight="48" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
                <Button Grid.Column="1" Content="📋" FontSize="16"
                        Click="CopiarPayload_Click"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" ToolTip="Copiar código PIX"
                        VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Status + timer + botão -->
        <StackPanel Grid.Row="8">
            <Border x:Name="BorderStatus" Background="#FEF9C3" CornerRadius="8" Padding="10,8"
                    Margin="0,0,0,10" BorderBrush="#FDE047" BorderThickness="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtStatus" Text="⏳ Aguardando pagamento..."
                               FontSize="12" FontWeight="SemiBold" Foreground="#854D0E"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTimer" FontSize="11" Foreground="#A16207"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </Border>
            <Button x:Name="BtnConfirmar" Content="✓  Confirmar Manualmente"
                    Click="BtnConfirmar_Click"
                    Height="44" Background="#16A34A" Foreground="White"
                    FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
