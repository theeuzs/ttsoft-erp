<Window x:Class="ERP.WPF.Views.ChatPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ERP.WPF.Converters"
        Title="💬 Chat Interno — TTSoft"
        Width="360" Height="480"
        WindowStartupLocation="Manual"
        ResizeMode="CanResize"
        Background="#1E293B"
        Topmost="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToAlignmentConverter x:Key="BoolToAlignmentConverter"/>
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F172A">
            <Grid Margin="12,0">
                <TextBlock Text="💬 Chat Interno" VerticalAlignment="Center"
                           FontSize="14" FontWeight="Bold" Foreground="White"/>
                <Button x:Name="BtnFechar" Content="✕" HorizontalAlignment="Right"
                        Width="28" Height="28" Background="Transparent" BorderThickness="0"
                        Foreground="#94A3B8" FontSize="16" Cursor="Hand"
                        Click="BtnFechar_Click"/>
            </Grid>
        </Border>

        <ListBox x:Name="LstMensagens" Grid.Row="1"
                 Background="#1E293B" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="10" Padding="10,8" MaxWidth="260"
                                HorizontalAlignment="{Binding EhMinha, Converter={StaticResource BoolToAlignmentConverter}}"
                                Background="{Binding EhMinha, Converter={StaticResource BoolToBrushConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding De}" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"/>
                                
                                <TextBlock Text="{Binding Texto}" FontSize="13" Foreground="White"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Hora}" FontSize="9"
                                           Foreground="#64748B" HorizontalAlignment="Right"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Border Grid.Row="2" Background="#0F172A" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtMensagem" Grid.Column="0"
                         Padding="10,8" Background="#334155" Foreground="White"
                         BorderBrush="#475569" BorderThickness="1"
                         CaretBrush="White" FontSize="13"
                         AcceptsReturn="False"
                         KeyDown="TxtMensagem_KeyDown">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                    </TextBox.Resources>
                </TextBox>
                <Button x:Name="BtnEnviar" Grid.Column="1" Content="▶"
                        Width="40" Height="40" Margin="8,0,0,0"
                        Background="#1E62A6" Foreground="White" BorderThickness="0"
                        FontSize="16" Cursor="Hand" Click="BtnEnviar_Click">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>