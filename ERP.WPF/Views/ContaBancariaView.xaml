<UserControl x:Class="ERP.WPF.Views.ContaBancariaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBgAlt}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="CONTAS BANCÁRIAS E SALDO CONSOLIDADO" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextDark}" Margin="0,0,0,20"/>

        <!-- Saldo Consolidado: 3 cartões de resumo -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBg}" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="CAIXAS ABERTOS (TODOS OS OPERADORES)" FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Text="{Binding SaldoTotalCaixas, StringFormat=C2}" FontSize="22" FontWeight="Bold" Foreground="#3B82F6"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource CardBg}" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="CONTAS BANCÁRIAS" FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Text="{Binding SaldoTotalContas, StringFormat=C2}" FontSize="22" FontWeight="Bold" Foreground="#3B82F6"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="{DynamicResource CardBg}" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="SALDO CONSOLIDADO" FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Text="{Binding SaldoConsolidado, StringFormat=C2}" FontSize="22" FontWeight="Bold" Foreground="#22C55E"/>
                </StackPanel>
            </Border>

            <Button Grid.Column="6" Content="ATUALIZAR" Command="{Binding AtualizarPosicaoCommand}"
                    Background="#3B82F6" Foreground="White" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Coluna esquerda: nova conta + lista de contas -->
            <StackPanel Grid.Column="0">
                <Border Background="{DynamicResource CardBg}" Padding="20" CornerRadius="8" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="NOVA CONTA BANCÁRIA" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                        <TextBlock Text="Apelido (Ex: Conta Principal)" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NovoApelido, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Banco" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NovoBanco, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Agência" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NovaAgencia, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Número da Conta" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NovoNumeroConta, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Saldo Inicial (R$)" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NovoSaldoInicial, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,20" Height="30" VerticalContentAlignment="Center"/>

                        <Button Content="CADASTRAR CONTA" Command="{Binding CriarContaCommand}"
                                Background="#3B82F6" Foreground="White" FontWeight="Bold" Height="40" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBg}" Padding="10" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="SUAS CONTAS" FontSize="14" FontWeight="Bold" Margin="10,5,0,10"/>
                        <ListBox ItemsSource="{Binding Contas}" SelectedItem="{Binding ContaSelecionada}"
                                 BorderThickness="0" Background="Transparent" MaxHeight="400">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="0,2" CornerRadius="6" Background="{DynamicResource CardBgAlt}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Apelido}" FontWeight="Bold"/>
                                                <TextBlock Text=" ⭐ PADRÃO" FontSize="10" FontWeight="Bold" Foreground="#F59E0B" VerticalAlignment="Center"
                                                           Visibility="{Binding ContaPadrao, Converter={StaticResource BoolToVisibility}}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Banco}" FontSize="11" Opacity="0.7"/>
                                            <TextBlock Text="{Binding SaldoAtual, StringFormat=C2}" FontWeight="SemiBold" Foreground="#22C55E"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Coluna direita: lançamento + extrato da conta selecionada -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource CardBg}" Padding="20" CornerRadius="8" Margin="0,0,0,15"
                        Visibility="{Binding ContaSelecionada, Converter={StaticResource NullToCollapsed}}">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,15">
                            <Run Text="LANÇAMENTO — "/><Run Text="{Binding ContaSelecionada.Apelido}"/>
                        </TextBlock>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Descrição" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding DescricaoLancamento, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Valor (R$)" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding ValorLancamento, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="LANÇAR ENTRADA" Command="{Binding LancarEntradaCommand}"
                                    Background="#22C55E" Foreground="White" FontWeight="Bold" Height="38" Padding="15,0" Margin="0,0,10,0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="LANÇAR SAÍDA" Command="{Binding LancarSaidaCommand}"
                                    Background="#EF4444" Foreground="White" FontWeight="Bold" Height="38" Padding="15,0" Margin="0,0,10,0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="INATIVAR CONTA" Command="{Binding InativarContaCommand}"
                                    Background="Transparent" BorderBrush="#EF4444" BorderThickness="1" Foreground="#EF4444" Height="38" Padding="15,0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="⭐ DEFINIR COMO PADRÃO" Command="{Binding DefinirPadraoCommand}"
                                    Background="Transparent" BorderBrush="#F59E0B" BorderThickness="1" Foreground="#F59E0B" Height="38" Padding="15,0" Margin="10,0,0,0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Extrato}" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="{DynamicResource CardBg}" RowHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data" Binding="{Binding DataHora, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                        <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="*"/>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="100"/>
                        <DataGridTextColumn Header="Valor" Binding="{Binding Valor, StringFormat=C2}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tipo}" Value="Entrada">
                                            <Setter Property="Foreground" Value="#22C55E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tipo}" Value="Saida">
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
