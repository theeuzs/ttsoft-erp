<UserControl x:Class="ERP.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ERP.WPF.Converters"
             Background="{DynamicResource FundoGeral}" FontFamily="Segoe UI">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TtBlue" Color="#1E62A6"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#27AE60"/>
        <SolidColorBrush x:Key="DangerRed" Color="#E74C3C"/>
        <SolidColorBrush x:Key="WarningOrange" Color="#F39C12"/>
        <conv:RoleToVisibilityConverter x:Key="RoleToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <RowDefinition Height="Auto"/>  <RowDefinition Height="200"/>   <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>     </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Visão Geral - Meu Negócio" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TtBlue}"/>
                <TextBlock Text="Resumo operacional e financeiro do dia" FontSize="14" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="🤝 COMISSÕES" Command="{Binding OpenComissaoCommand}"
                        Height="40" Width="140" Background="#F59E0B" Foreground="White"
                        FontWeight="Bold" FontSize="14" Cursor="Hand" Margin="0,0,15,0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                </Button>
                <Button Content="📦 CURVA ABC" Command="{Binding OpenAbcCommand}"
                        Height="40" Width="150" Background="#8B5CF6" Foreground="White"
                        FontWeight="Bold" FontSize="14" Cursor="Hand" Margin="0,0,15,0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                </Button>
                
                <Button Content="📈 DRE SIMPLIFICADO" Command="{Binding OpenDreCommand}"
                        Height="40" Width="200" Background="{StaticResource TtBlue}" Foreground="White"
                        FontWeight="Bold" FontSize="14" Cursor="Hand" Margin="0,0,15,0"
                        Visibility="{Binding Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=fluxocaixa.view}">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                </Button>
                <Button Content="📊 RELATÓRIO DE VENDAS" Command="{Binding OpenSalesReportCommand}"
                        Height="40" Width="220" Background="{StaticResource SuccessGreen}" Foreground="White"
                        FontWeight="Bold" FontSize="14" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Faturamento Hoje" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding RevenueToday, StringFormat='R$ \{0:N2\}'}" FontSize="26" FontWeight="Black" Foreground="{StaticResource SuccessGreen}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Vendas Realizadas Hoje" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding SalesCountToday, StringFormat='{}{0} Pedidos'}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TtBlue}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Despesas do Mês" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding ExpensesThisMonth, StringFormat='R$ \{0:N2\}'}" FontSize="26" FontWeight="Black" Foreground="{StaticResource DangerRed}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Produtos em Estoque Baixo" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding LowStockCount, StringFormat='{}{0} Itens'}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource WarningOrange}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="8" Background="#FEF3C7" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="⚠️ Contas Vencendo Hoje" FontSize="13" FontWeight="SemiBold" Foreground="#92400E"/>
                    <TextBlock Text="{Binding ContasVencendoHoje}" FontSize="26" FontWeight="Black" Foreground="#B45309" Margin="0,8,0,4"/>
                    <TextBlock Text="{Binding ValorVencendoHoje, StringFormat='R$ {0:N2}'}" FontSize="13" Foreground="#92400E"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource CardBg}" CornerRadius="12" Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="{DynamicResource CorAcento}" CornerRadius="12,12,0,0" Padding="16,10">
                    <TextBlock Text="📊 Vendas — Últimos 7 dias" FontSize="13" FontWeight="Bold" Foreground="White"/>
                </Border>
                <ContentControl x:Name="GraficoDashboard" Grid.Row="1" Margin="8"/>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Últimas Vendas" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextDark}" Margin="0,0,0,16"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding RecentSales}" AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0" HeadersVisibility="None"
                              GridLinesVisibility="None" RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding SaleDate, StringFormat='HH:mm'}" Width="60" Foreground="{DynamicResource TextMuted}"/>
                            <DataGridTextColumn Binding="{Binding SaleNumber}" Width="Auto" FontWeight="SemiBold"/>
                            <DataGridTextColumn Binding="{Binding PaymentMethod}" Width="*"/>
                            <DataGridTextColumn Binding="{Binding Total, StringFormat='R$ \{0:N2\}'}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource SuccessGreen}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="⚠️ Reposição Necessária" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DangerRed}" Margin="0,0,0,16"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LowStockProducts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF5F5" BorderBrush="#FED7D7" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextDark}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding SKU}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Stock, StringFormat='Qtd: {0}'}" FontWeight="Bold" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding MinStock, StringFormat='Min: {0}'}" FontSize="11" Foreground="{StaticResource WarningOrange}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>