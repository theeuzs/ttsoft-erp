<UserControl x:Class="ERP.WPF.Views.RecebivelOperadoraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBgAlt}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="RECEBÍVEIS DE OPERADORA" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextDark}"/>
            <Button Grid.Column="1" Content="ATUALIZAR" Command="{Binding AtualizarCommand}"
                    Background="#3B82F6" Foreground="White" FontWeight="Bold" Height="36" Cursor="Hand"/>
        </Grid>

        <TextBlock Grid.Row="1" Text="Dinheiro de vendas em cartão que ainda não caiu na conta bancária — selecione os recebíveis do mesmo depósito (lote) do seu extrato e confirme o valor real que caiu."
                   Foreground="{DynamicResource TextMuted}" FontSize="12" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Pendentes}" AutoGenerateColumns="False"
                  Background="{DynamicResource CardBg}" GridLinesVisibility="Horizontal" RowHeight="38">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelecionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                <DataGridTextColumn Header="Operadora" Binding="{Binding Dto.OperadoraNome}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Forma" Binding="{Binding Dto.FormaRecebimento}" Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="Data Venda" Binding="{Binding Dto.DataVenda, StringFormat=dd/MM/yyyy}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Previsto p/" Binding="{Binding Dto.DataPrevistaLiquidacao, StringFormat=dd/MM/yyyy}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Bruto" Binding="{Binding Dto.ValorBruto, StringFormat=C2}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Taxa" Binding="{Binding Dto.ValorTaxa, StringFormat=C2}" Width="100" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#DC2626"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Líquido" Binding="{Binding Dto.ValorLiquido, StringFormat=C2}" Width="110" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="#16A34A"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Painel de liquidação -->
        <Border Grid.Row="3" Background="{DynamicResource CardBg}" Padding="16" CornerRadius="8" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontSize="13">
                        <Run Text="{Binding QuantidadeSelecionada, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text=" selecionado(s)  •  Líquido esperado: "/>
                        <Run Text="{Binding TotalLiquidoSelecionado, StringFormat=C2, Mode=OneWay}" FontWeight="Bold" Foreground="#16A34A"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Valor real depositado" FontWeight="SemiBold" FontSize="11"/>
                    <TextBox Text="{Binding ValorRealDepositado, UpdateSourceTrigger=PropertyChanged}" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Data da liquidação" FontWeight="SemiBold" FontSize="11"/>
                    <DatePicker SelectedDate="{Binding DataLiquidacao}" Height="32"/>
                </StackPanel>

                <Button Grid.Column="6" Content="LIQUIDAR SELECIONADOS" Command="{Binding LiquidarCommand}"
                        Background="#16A34A" Foreground="White" FontWeight="Bold" VerticalAlignment="Bottom" Height="36" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
