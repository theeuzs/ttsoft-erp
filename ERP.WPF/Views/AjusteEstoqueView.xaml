<Window x:Class="ERP.WPF.Views.AjusteEstoqueView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajuste Rápido de Estoque" Height="500" Width="600" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource CardBg}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Ajuste de Estoque / Inventário" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="{DynamicResource CardBgAlt}" BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="8" Padding="25">
            <StackPanel>
                
                <TextBlock Text="Localizar Produto (Nome ou Cód. Barras)" Foreground="Gray" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding ListaProdutos}" 
          SelectedItem="{Binding ProdutoSelecionado}"
          Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}" 
          IsDropDownOpen="{Binding DropDownAberto, Mode=TwoWay}"
          DisplayMemberPath="Name"
          IsEditable="True"
          IsTextSearchEnabled="False"
          Height="40" FontSize="16" Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Estoque Atual do Sistema" Foreground="Gray" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding EstoqueAtual, Mode=OneWay}" IsReadOnly="True" Background="#E9ECEF" Height="40" FontSize="18" FontWeight="Bold" TextAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="15,0,15,0">
                        <TextBlock Text="Estoque Físico Contado" Foreground="#2980B9" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NovoEstoque, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="18" FontWeight="Bold" TextAlignment="Center" BorderBrush="#2980B9" BorderThickness="2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="15,0,0,0">
                        <TextBlock Text="Divergência" Foreground="Gray" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Divergencia, Mode=OneWay}" IsReadOnly="True" Background="#FEF9E7" Foreground="#B9770E" Height="40" FontSize="18" FontWeight="Bold" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Motivo do Ajuste" Foreground="Gray" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox SelectedItem="{Binding MotivoSelecionado}" Height="40" FontSize="16" Margin="0,0,0,25">
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Contagem Inicial / Implantação</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Quebra / Avaria de Material</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Perda / Furto</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Uso Interno da Loja</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Erro de Digitação Anterior</System:String>
                </ComboBox>

                <Button Content="✅ CONFIRMAR AJUSTE DE ESTOQUE" Command="{Binding SalvarAjusteCommand}" 
                        Height="50" Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="16" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>