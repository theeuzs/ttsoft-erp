<Window x:Class="ERP.WPF.Views.AbrirCaixaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abrir Caixa" SizeToContent="Height" Width="380"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent">
    
    <Border Background="{DynamicResource CardBg}" CornerRadius="12" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="2"/>
        </Border.Effect>
        <StackPanel Margin="25">
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="💰" FontSize="22" Margin="0,0,10,0"/>
                <TextBlock Text="Abrir Caixa" FontSize="20" FontWeight="Bold" Foreground="#1E62A6" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Valor de Abertura" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource TextDark}" Margin="0,0,0,8"/>
            <TextBox Text="{Binding ValorAbertura, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" 
                     FontSize="18" Padding="10" FontWeight="Bold" Foreground="{DynamicResource TextDark}"
                     BorderBrush="{DynamicResource BordaInput}" BorderThickness="1" Background="{DynamicResource FundoRodape}" Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" Content="✓ Abrir Caixa" Command="{Binding AbrirCommand}" 
                        Background="#27AE60" Foreground="White" FontWeight="Bold" 
                        FontSize="14" BorderThickness="0" Height="40" Margin="0,0,10,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"> <Setter Property="CornerRadius" Value="6"/> </Style>
                    </Button.Resources>
                </Button>
                
                <Button Grid.Column="1" Content="Cancelar" Click="Cancelar_Click" 
                        Background="{DynamicResource CardBgAlt}" Foreground="{DynamicResource TextMuted}" FontWeight="Bold" 
                        FontSize="14" BorderThickness="0" Height="40" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"> <Setter Property="CornerRadius" Value="6"/> </Style>
                    </Button.Resources>
                </Button>
            </Grid>
            
        </StackPanel>
    </Border>
</Window>