<Window x:Class="ERP.WPF.Views.ReciboPreviewView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visualização do Recibo" Height="650" Width="400"
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow" Background="#CBD5E1">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FEFCE8" CornerRadius="0,0,8,8" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.2" ShadowDepth="3"/>
            </Border.Effect>
            
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel TextElement.FontFamily="Consolas" TextElement.FontSize="13" TextElement.Foreground="{DynamicResource TextDark}">
                    
                    <TextBlock Text="VILA VERDE" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="MATERIAIS DE CONSTRUÇÃO" HorizontalAlignment="Center"/>
                    <TextBlock Text="CNPJ: 12.820.608/0001-41" HorizontalAlignment="Center"/>
                    <TextBlock Text="----------------------------------------" HorizontalAlignment="Center" Margin="0,5"/>
                    
                    <TextBlock Text="{Binding Data, StringFormat='DATA: dd/MM/yyyy HH:mm'}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TituloDocumento}" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding NumeroDocumento}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding NomeCliente, StringFormat='CLIENTE: {0}'}"/>
                    <TextBlock Text="----------------------------------------" HorizontalAlignment="Center" Margin="0,5"/>

                    <TextBlock Text="QTD   UN.V      DESCRICAO          TOTAL" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding Itens}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Quantidade, StringFormat='{}{0:0}'}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PrecoUnitario, StringFormat=C}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Descricao}" TextTrimming="CharacterEllipsis" Margin="5,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding ValorTotal, StringFormat=C}" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="----------------------------------------" HorizontalAlignment="Center" Margin="0,5"/>

                    <Grid>
                        <TextBlock Text="TOTAL R$" FontWeight="Bold" FontSize="18"/>
                        <TextBlock Text="{Binding TotalDocumento, StringFormat=N2}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Right"/>
                    </Grid>
                    
                    <TextBlock Text="OBRIGADO PELA PREFERENCIA!" HorizontalAlignment="Center" Margin="0,30,0,0"/>
                    <TextBlock Text="Documento nao fiscal" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2" Content="🖨️ IMPRIMIR RECIBO" Command="{Binding ImprimirCommand}" 
                Background="#0284C7" Foreground="White" FontWeight="Bold" FontSize="16" Height="50" BorderThickness="0" Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>