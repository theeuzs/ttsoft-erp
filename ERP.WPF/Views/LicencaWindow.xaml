<Window x:Class="ERP.WPF.Views.LicencaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="Informações da Licença" Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        Background="#F5F6FA" FontFamily="Segoe UI">

    <Border Padding="25" BorderBrush="#DCDDE1" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="🛡️ TTSoft Sistemas" FontSize="22" FontWeight="Bold" Foreground="#2F3640" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Gerenciador de Licença de Uso" FontSize="14" Foreground="#718093" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <Grid Margin="10,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status atual:" FontWeight="SemiBold" Foreground="#353B48" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtStatus" Text="Carregando..." FontWeight="Bold" Foreground="#4CD137" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Data de vencimento:" FontWeight="SemiBold" Foreground="#353B48" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtVencimento" Text="00/00/0000" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Dias restantes:" FontWeight="SemiBold" Foreground="#353B48" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtDias" Text="0 dias" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="ID deste Terminal:" FontWeight="SemiBold" Foreground="#353B48" VerticalAlignment="Bottom"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtMachineId" Text="ABC123XYZ" IsReadOnly="True" BorderThickness="0" Background="Transparent" Foreground="#0097E6" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" TextAlignment="Right"/>
            </Grid>

            <Separator Margin="0,20,0,20" Background="#DCDDE1"/>

            <Button Content="FECHAR" Width="120" Height="35" Background="#00A8FF" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnFechar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
</Window>