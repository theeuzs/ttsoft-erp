<UserControl x:Class="ERP.WPF.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ERP.WPF.Views"
             Background="{DynamicResource FundoGeral}" FontFamily="Segoe UI">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TtBlue" Color="#1E62A6"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CorAcento}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.9"/></Trigger>
                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
        </Style>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#E2E8F0"/></Trigger>
                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Coluna esquerda: lista de clientes ─────────────────────── -->
        <Border Grid.Column="0" Background="{DynamicResource CardBg}" Margin="24,24,12,24" CornerRadius="16" Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <!-- ── Barra de paginação ── -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header com contador -->
                <Border Grid.Row="0" Background="{DynamicResource CorAcento}" CornerRadius="16,16,0,0" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="Carteira de Clientes" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="{Binding TotalClientes, StringFormat='{}{0} clientes cadastrados'}"
                                   FontSize="11" Foreground="#FFFFFF99" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Busca em tempo real -->
                <Border Grid.Row="1" Padding="16,12,16,8">
                    <Border Background="{DynamicResource CardBgAlt}" CornerRadius="8" BorderBrush="{DynamicResource BordaCard}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="10,0,6,0" Opacity="0.5"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="13" VerticalContentAlignment="Center" Padding="0,8"/>
                            <Button Grid.Column="2" Content="✕" Command="{Binding LimparBuscaCommand}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Foreground="{DynamicResource TextMuted}" FontSize="12" Padding="8,0"
                                    Visibility="{Binding SearchTerm, Converter={StaticResource NegativoConverter}}"/>
                        </Grid>
                    </Border>
                </Border>

                <!-- Lista -->
                <ListBox Grid.Row="2" ItemsSource="{Binding CustomersList}"
                         SelectedItem="{Binding SelectedCustomer}"
                         BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Margin="8,0,8,0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bdr" Background="Transparent" CornerRadius="10" Margin="4,3">
                                            <ContentPresenter Margin="0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bdr" Property="Background" Value="#EFF6FF"/>
                                                <Setter TargetName="Bdr" Property="BorderBrush" Value="#BFDBFE"/>
                                                <Setter TargetName="Bdr" Property="BorderThickness" Value="1.5"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bdr" Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                        Background="{DynamicResource CorAcento}" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name[0]}" Foreground="White" FontWeight="Bold"
                                               FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{DynamicResource TextDark}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Document}" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="📜"
                                        Command="{Binding DataContext.AbrirHistoricoCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Background="{DynamicResource CardBgAlt}" Foreground="{DynamicResource TextMuted}"
                                        FontSize="14" Width="32" Height="32"
                                        BorderThickness="0" Cursor="Hand" ToolTip="Ver histórico" VerticalAlignment="Center">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- ── Barra de paginação ─────────────────────────────── -->
                <Border Grid.Row="3" Background="{DynamicResource FundoRodape}" BorderBrush="{DynamicResource BordaCard}" BorderThickness="0,1,0,0" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="◀" Style="{StaticResource NavButton}"
                                Command="{Binding AnteriorPaginaCommand}"
                                IsEnabled="{Binding PodeAnterior}"
                                ToolTip="Página anterior"/>
                        <TextBlock Grid.Column="1" Text="{Binding PaginaInfo}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold"/>
                        <Button Grid.Column="2" Content="▶" Style="{StaticResource NavButton}"
                                Command="{Binding ProximaPaginaCommand}"
                                IsEnabled="{Binding PodeProxima}"
                                ToolTip="Próxima página"/>
                    </Grid>
                </Border>

                <!-- Botões -->
                <Grid Grid.Row="4" Margin="16,12,16,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="+ Novo Cliente" Command="{Binding NewCommand}" Style="{StaticResource PrimaryButton}" Padding="0,11"/>
                    <Button Grid.Column="2" Content="🗑️ Excluir" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Padding="0,11"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Coluna direita: formulário ─────────────────────────────── -->
        <Border Grid.Column="1" Background="{DynamicResource CardBg}" Margin="12,24,24,24" CornerRadius="16" Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource CorAcento}" CornerRadius="16,16,0,0" Padding="24,16">
                    <TextBlock Text="{Binding TituloFormulario}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                </Border>

                <TabControl Grid.Row="1" Margin="0" BorderThickness="0" Background="Transparent">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Padding" Value="20,10"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource CorAcento}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="👤  Dados Gerais">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                                    <TextBlock Text="Nome Completo / Razão Social *" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="CPF / CNPJ *" Style="{StaticResource LabelStyle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding Document, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" Content="🔍" Command="{Binding SearchCnpjCommand}" Style="{StaticResource PrimaryButton}" ToolTip="Consultar CNPJ na Receita Federal"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2">
                                    <TextBlock Text="RG / Inscrição Estadual" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding StateRegistration}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="Telefone / WhatsApp" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding Phone}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="E-mail" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding Email}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="📍  Endereço de Entrega">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0"><TextBlock Text="CEP" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding ZipCode}" Style="{StaticResource InputStyle}"/></StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2"><TextBlock Text="Rua / Logradouro" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Street}" Style="{StaticResource InputStyle}"/></StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="4"><TextBlock Text="Número" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Number}" Style="{StaticResource InputStyle}"/></StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"><TextBlock Text="Complemento" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Complement}" Style="{StaticResource InputStyle}"/></StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"><TextBlock Text="Bairro" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Neighborhood}" Style="{StaticResource InputStyle}"/></StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Grid.RowSpan="1" Margin="24,0,0,0" Grid.ColumnSpan="2"><TextBlock Text="Cidade" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding City}" Style="{StaticResource InputStyle}"/></StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="4"><TextBlock Text="UF" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding State}" Style="{StaticResource InputStyle}" MaxLength="2"/></StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="🏷️  Grupo e Crédito">
                        <StackPanel Margin="16">
                            <!-- Sprint C: Grupo de preço -->
                            <TextBlock Text="GRUPO DE PREÇO" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource CorAcento}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding GruposDisponiveis}"
                                      SelectedItem="{Binding GrupoPreco}"
                                      Margin="0,0,0,16" Height="36">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}">
                                                    <Binding/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20"
                                       Text="A = Varejo (preço normal) | B = Revendedor | C = Atacadista"/>
                            <!-- Sprint D: Limite de crédito -->
                            <TextBlock Text="LIMITE DE CRÉDITO (R$)" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource CorAcento}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding LimiteCredito, UpdateSourceTrigger=LostFocus, StringFormat=N2, ConverterCulture=pt-BR}"
                                     Height="36" Padding="10,8" Margin="0,0,0,8"
                                     Background="{DynamicResource FundoInput}" Foreground="{DynamicResource TextDark}"
                                     BorderBrush="{DynamicResource BordaInput}" BorderThickness="1">
                                <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                            </TextBox>
                            <TextBlock Text="0 = sem limite definido" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20"/>
                            <!-- Situação do crédito (somente leitura) -->
                            <Border Background="{DynamicResource FundoInput}" CornerRadius="8" Padding="14" Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="SITUAÇÃO DO CRÉDITO" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SituacaoCredito}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextDark}"/>
                                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}">
                                        <Run Text="Devedor: "/>
                                        <Run Text="{Binding SaldoDevedor, StringFormat=C, Mode=OneWay}"/>
                                        <Run Text="  |  Disponível: "/>
                                        <Run Text="{Binding CreditoDisponivel, StringFormat=C, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="💳  Haver">
                        <ContentControl Content="{Binding HaverVm}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate>
                                    <local:HaverView DataContext="{Binding}"/>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </TabItem>
                </TabControl>

                <Border Grid.Row="2" Background="{DynamicResource FundoRodape}" Padding="24,16" CornerRadius="0,0,16,16"
                        BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BordaCard}">
                    <Button Content="💾  SALVAR CLIENTE" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}" Width="200" Padding="0,12"
                            HorizontalAlignment="Right"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
