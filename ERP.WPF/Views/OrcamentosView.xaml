<UserControl x:Class="ERP.WPF.Views.OrcamentosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource FundoGeral}" FontFamily="Segoe UI">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TtBlue" Color="#1E62A6"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Orçamentos Salvos" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TtBlue}"/>
            <TextBlock Text="Consulte as cotações feitas e envie direto para o PDV" FontSize="14" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Total em Orçamentos Abertos" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding TotalOrcamentosAbertos, StringFormat='R$ {0:N2}'}" FontSize="28" FontWeight="Black" Foreground="#F59E0B" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Orçamentos Pendentes" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding QtdOrcamentosAbertos, StringFormat='{}{0} Cotações'}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TtBlue}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Conversão do Mês" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding QtdOrcamentosAprovados, StringFormat='{}{0} Aprovados'}" FontSize="28" FontWeight="Bold" Foreground="#10B981" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource CardBg}" CornerRadius="10"
                Padding="16,10" Margin="0,0,0,16"
                Effect="{DynamicResource CardShadow}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🗓 Período:" FontWeight="SemiBold"
                           Foreground="{StaticResource TtBlue}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="De:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource TextMuted}"/>
                <DatePicker SelectedDate="{Binding DataInicial, Mode=TwoWay}"
                            Width="130" VerticalAlignment="Center" Margin="0,0,16,0"
                            FontSize="14"/>
                <TextBlock Text="Até:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource TextMuted}"/>
                <DatePicker SelectedDate="{Binding DataFinal, Mode=TwoWay}"
                            Width="130" VerticalAlignment="Center" Margin="0,0,20,0"
                            FontSize="14"/>
                <Button Content="🔍 Filtrar"
                        Command="{Binding CarregarOrcamentosCommand}"
                        Background="{StaticResource TtBlue}" Foreground="White"
                        FontWeight="Bold" Padding="16,7" BorderThickness="0"
                        Cursor="Hand" FontSize="13">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMuted}" FontSize="12"
                           Text="(Mude as datas e clique em Filtrar para ver outros períodos)"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="{DynamicResource CardBg}" CornerRadius="12" Effect="{DynamicResource CardShadow}">
            <DataGrid ItemsSource="{Binding ListaOrcamentos}" AutoGenerateColumns="False" IsReadOnly="True" 
                      Background="Transparent" BorderThickness="0" RowHeight="52" Margin="12"
                      GridLinesVisibility="None" RowBackground="Transparent" AlternatingRowBackground="{DynamicResource CardBgAlt}">
                
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TtBlue}"/>
                        <Setter Property="Padding" Value="12"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="NÚMERO" Binding="{Binding Numero}" Width="160"/>
                    <DataGridTextColumn Header="CLIENTE" Binding="{Binding CustomerName}" Width="*"/>
                    <DataGridTextColumn Header="EMISSÃO" Binding="{Binding DataEmissao, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTextColumn Header="VALIDADE" Binding="{Binding DataValidade, StringFormat=dd/MM/yyyy}" Width="110"/>
                    
                    <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Aberto">
                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Aprovado">
                                        <Setter Property="Foreground" Value="#10B981"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="TOTAL" Binding="{Binding ValorTotal, StringFormat='R$ {0:N2}'}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="AÇÕES" Width="380">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="👀 Visualizar" 
                                            Command="{Binding DataContext.VisualizarOrcamentoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#3B82F6" Foreground="White" FontWeight="Bold" Padding="8,5" Margin="2,2,3,2" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                    </Button>

                                    <Button Content="💬 WhatsApp" 
                                            Command="{Binding DataContext.EnviarWhatsAppOrcamentoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#25D366" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="8,5" Margin="2,2,3,2" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                    </Button>

                                    <Button Content="🖨️ Imprimir" 
                                            Command="{Binding DataContext.ImprimirOrcamentoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#F59E0B" Foreground="White" FontWeight="Bold" Padding="8,5" Margin="2,2,3,2" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                    </Button>

                                    <Button Content="🛒 Pro PDV" 
                                            Command="{Binding DataContext.MandarParaCaixaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="8,5" Margin="2,2,0,2" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                    </Button>
                                </WrapPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>