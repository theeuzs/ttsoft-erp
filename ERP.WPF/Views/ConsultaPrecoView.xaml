<Window x:Class="ERP.WPF.Views.ConsultaPrecoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Consulta de Preço" Width="700" SizeToContent="Height" MinHeight="450"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize"
        Background="#0F172A" FontFamily="Segoe UI"
        PreviewKeyDown="Window_PreviewKeyDown" Loaded="Window_Loaded">
    <Border BorderBrush="#38BDF8" BorderThickness="2" CornerRadius="8">
        <Grid Margin="30">
            <Grid.RowDefinitions> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/> </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="🔍 CONSULTA RÁPIDA E ADIÇÃO" Foreground="#38BDF8" FontSize="24" FontWeight="Black"/>
                <TextBlock Text="[ESC] FECHAR" Foreground="{DynamicResource TextMuted}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <TextBox x:Name="TxtLeitor" Grid.Row="1" Text="{Binding CodigoBarras, UpdateSourceTrigger=PropertyChanged}" KeyDown="TxtLeitor_KeyDown"
                     Background="#1E293B" Foreground="White" FontSize="24" Padding="15" BorderThickness="0" Margin="0,0,0,30" HorizontalContentAlignment="Center"/>

            <StackPanel Grid.Row="2" VerticalAlignment="Center" Visibility="{Binding NaoEncontradoVisivel}">
                <TextBlock Text="Bipe o código de barras ou digite o SKU." Foreground="{DynamicResource TextMuted}" FontSize="20" TextAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="2" Visibility="{Binding ProdutoVisivel}" Background="#1E293B">
                <Grid.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="12"/></Style></Grid.Resources>
                <Border Padding="30" BorderThickness="1" BorderBrush="#334155">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProdutoEncontrado.Name}" Foreground="White" FontSize="26" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,10" MaxHeight="120" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding ProdutoEncontrado.Stock, StringFormat='ESTOQUE ATUAL: {0:N2}'}" Foreground="{DynamicResource TextMuted}" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,10"/>
                        
                        <Viewbox MaxHeight="60">
                            <TextBlock Foreground="#22C55E" FontWeight="Black" TextAlignment="Center">
                                <Run Text="{Binding UnidadeLabel, Mode=OneWay}"/>
                                <Run Text=": R$ "/>
                                <Run Text="{Binding ProdutoEncontrado.SalePrice, StringFormat='{}{0:N2}'}"/>
                            </TextBlock>
                        </Viewbox>

                        <TextBlock Text="{Binding MensagemAtacado}" Foreground="#F59E0B" FontSize="16" FontWeight="Bold" TextAlignment="Center" Margin="0,5,0,20">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MensagemAtacado}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Border Background="#0F172A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="QTD [M]:" Foreground="{DynamicResource TextMuted}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="TxtQuantidade" Text="{Binding Quantidade, UpdateSourceTrigger=PropertyChanged, ConverterCulture=pt-BR}" KeyDown="TxtQuantidade_KeyDown" Width="100" FontSize="26" FontWeight="Black" TextAlignment="Center" Background="#1E293B" Foreground="White" BorderThickness="1" BorderBrush="#38BDF8" Padding="5"/>
                                    <TextBlock Text="{Binding UnidadeLabel, Mode=OneWay}" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="TOTAL:" Foreground="{DynamicResource TextMuted}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Total, StringFormat='R$ {0:N2}'}" FontSize="32" FontWeight="Black" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#38BDF8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAtacadoAplicado}" Value="True">
                                                        <Setter Property="Foreground" Value="#F59E0B"/> </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="{Binding InfoConversao, Mode=OneWay}" Foreground="#94A3B8" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"
                                   Visibility="{Binding InfoConversao, Mode=OneWay, Converter={StaticResource NullToCollapsed}}"/>
                        <Button Content="➕ ADICIONAR [ENTER] OU [ALT+U]" Command="{Binding AdicionarCarrinhoCommand}" Background="#22C55E" Foreground="White" FontSize="20" FontWeight="Black" Padding="15" BorderThickness="0" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>