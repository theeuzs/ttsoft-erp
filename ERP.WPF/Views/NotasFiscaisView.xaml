<UserControl x:Class="ERP.WPF.Views.NotasFiscaisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource FundoGeral}" FontFamily="Segoe UI">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🧾 Gerenciador de Notas Fiscais" FontSize="28" FontWeight="Bold" Foreground="#1E62A6"/>
            <TextBlock Text="Visualize os PDFs, consulte status e faça cancelamentos na SEFAZ." FontSize="14" Foreground="{DynamicResource TextMuted}" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="Black" Direction="270"/>
            </Border.Effect>

            <DataGrid ItemsSource="{Binding Notas}" AutoGenerateColumns="False" IsReadOnly="True" 
                      HeadersVisibility="Column" Background="Transparent" BorderThickness="0" 
                      RowBackground="{DynamicResource CardBg}" AlternatingRowBackground="{DynamicResource CardBgAlt}" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0">
                
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,15"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Referência" Binding="{Binding NumeroRef}" Width="100"/>
                    <DataGridTextColumn Header="Data / Hora" Binding="{Binding Data}" Width="150"/>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente}" Width="*"/>
                    
                    <DataGridTextColumn Header="Valor" Binding="{Binding Valor, StringFormat='R$ {0:N2}'}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#1E62A6"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Ambiente" Binding="{Binding Ambiente}" Width="120"/>
                    
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Autorizada">
                                        <Setter Property="Foreground" Value="#16A34A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Cancelada">
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Rejeitada">
                                        <Setter Property="Foreground" Value="#D97706"/> </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Ações" Width="260">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    
                                    <Button Content="📄 PDF" 
                                            Command="{Binding DataContext.AbrirPdfCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding UrlDanfe}"
                                            Background="#E2E8F0" Foreground="#334155" FontWeight="Bold" 
                                            BorderThickness="0" Padding="10,5" Margin="0,0,5,0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border"> <Setter Property="CornerRadius" Value="4"/> </Style>
                                        </Button.Resources>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UrlDanfe}" Value="">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="🔍 Motivo" 
                                            Command="{Binding DataContext.VerMotivoCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding NumeroRef}"
                                            Background="#FEF08A" Foreground="#854D0E" FontWeight="Bold" 
                                            BorderThickness="0" Padding="10,5" Margin="0,0,5,0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border"> <Setter Property="CornerRadius" Value="4"/> </Style>
                                        </Button.Resources>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed"/> <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Rejeitada">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="✖ Cancelar" 
                                            Command="{Binding DataContext.CancelarNotaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding NumeroRef}"
                                            Background="#FEE2E2" Foreground="#DC2626" FontWeight="Bold" 
                                            BorderThickness="0" Padding="10,5" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border"> <Setter Property="CornerRadius" Value="4"/> </Style>
                                        </Button.Resources>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelada">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Rejeitada">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>