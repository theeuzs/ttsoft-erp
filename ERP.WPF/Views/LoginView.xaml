<Window x:Class="ERP.WPF.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConstruTTor ERP"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#091C3E"
        WindowState="Maximized"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/LoginStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.35*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ FOTO de Fundo ══ -->
        <Image Grid.ColumnSpan="2"
               Source="/Assets/Images/login_background.jpg"
               Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- ══ Overlay Escuro Marinho ══ -->
        <Rectangle Grid.ColumnSpan="2">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#B3091C3E" Offset="0"/>
                    <GradientStop Color="#D9051024" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ══════════════════════════════════════════
             PAINEL DIREITO: Fundo branco com corte DIAGONAL
        ══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            
            <Rectangle Fill="#F8FAFC" Panel.ZIndex="0">
                <Rectangle.Clip>
                    <PathGeometry>
                        <PathFigure StartPoint="150,0" IsClosed="True">
                            <LineSegment Point="4000,0"/>
                            <LineSegment Point="4000,4000"/>
                            <LineSegment Point="0,4000"/>
                        </PathFigure>
                    </PathGeometry>
                </Rectangle.Clip>
            </Rectangle>

            <!-- Botões de janela -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,16,24,0" Panel.ZIndex="10">
                
                <Button Width="32" Height="32" Margin="0,0,4,0"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="BtnMinimize_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="R" CornerRadius="8" Background="Transparent">
                                <TextBlock Text="─" FontSize="14" Foreground="#94A3B8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="R" Property="Background" Value="#E2E8F0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="32" Height="32"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="BtnSair_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="R" CornerRadius="8" Background="Transparent">
                                <TextBlock Text="✕" FontSize="14" Foreground="#94A3B8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="R" Property="Background" Value="#FEECEC"/>
                                    <Setter Property="Foreground" Value="#DC2626"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- ══ CARD LOGIN ══ -->
            <Border x:Name="LoginCard"
                    Width="480" Padding="48,40"
                    Margin="-160,0,0,0"
                    Background="White" CornerRadius="20"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Opacity="0"
                    Effect="{StaticResource CardShadow}"
                    Panel.ZIndex="50">

                <StackPanel>
                    <!-- Badge Bem-vindo -->
                    <Border Background="#F3F4F6" CornerRadius="8"
                            Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Bem-vindo 👋" FontWeight="SemiBold"
                                       FontSize="13" Foreground="#2563EB"
                                       FontFamily="Segoe UI Semibold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Título -->
                    <TextBlock FontSize="32" FontWeight="Bold"
                               FontFamily="Segoe UI Bold" Foreground="#111827"
                               Margin="0,0,0,6">
                        <Run Text="Acesse "/>
                        <Run Text="sua" Foreground="#2563EB"/>
                        <Run Text=" conta"/>
                    </TextBlock>
                    <TextBlock FontSize="14" Foreground="#6B7280"
                               FontFamily="Segoe UI" Margin="0,0,0,32" TextWrapping="Wrap">
                        Entre com suas credenciais para acessar o sistema
                    </TextBlock>

                    <!-- Usuário -->
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Usuário"/>
                    <Border Height="52" Margin="0,0,0,16"
                            Background="White" BorderBrush="#E5E7EB"
                            BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="👤" FontSize="16" Foreground="#9CA3AF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Usuario, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <!-- Senha -->
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Senha"/>
                    <Border Height="52" Margin="0,0,0,12"
                            Background="White" BorderBrush="#E5E7EB"
                            BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="48"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔒" FontSize="16" Foreground="#9CA3AF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <PasswordBox x:Name="txtSenha" Grid.Column="1"
                                         Style="{StaticResource ModernPasswordBox}"
                                         PasswordChanged="TxtSenha_PasswordChanged"/>
                            <Button Grid.Column="2" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnToggleSenha_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <TextBlock Text="👁" FontSize="16" Foreground="#9CA3AF"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Senha visível (toggle) -->
                    <Border x:Name="SenhaNakedBorder" Height="52"
                            Margin="0,-12,0,12"
                            Background="White" BorderBrush="#2563EB"
                            BorderThickness="1" CornerRadius="8"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="48"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔒" FontSize="16" Foreground="#9CA3AF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox x:Name="SenhaNaked" Grid.Column="1"
                                     Style="{StaticResource ModernTextBox}"
                                     TextChanged="SenhaNaked_TextChanged"/>
                            <Button Grid.Column="2" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnToggleSenha_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <TextBlock Text="🙈" FontSize="16" Foreground="#2563EB"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Lembrar + Esqueci -->
                    <Grid Margin="0,4,0,32">
                        <CheckBox HorizontalAlignment="Left" VerticalAlignment="Center"
                                  FontSize="13" Foreground="#4B5563"
                                  FontFamily="Segoe UI" Content="Lembrar meus dados"/>
                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Text="Esqueci minha senha" Foreground="#2563EB"
                                   FontSize="13" FontFamily="Segoe UI" Cursor="Hand"
                                   MouseLeftButtonUp="EsqueciSenha_Click"/>
                    </Grid>

                    <!-- Botão Entrar (ATUALIZADO COM O TAG) -->
                    <Button x:Name="BtnEntrar"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginCommand}"
                            Tag="{Binding IsBusy}"
                            Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Entrar no sistema" VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="→" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Segurança -->
                    <Border Background="#F5F8FF" CornerRadius="8" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🛡️" FontSize="20"
                                       Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Ambiente seguro e monitorado"
                                           FontSize="13" Foreground="#1E3A8A"
                                           FontFamily="Segoe UI Semibold"/>
                                <TextBlock Margin="0,2,0,0" FontSize="12"
                                           Foreground="#6B7280" FontFamily="Segoe UI"
                                           TextWrapping="Wrap">
                                    Seus dados estão protegidos com os mais altos padrões de segurança.
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ══ BOTÃO WHATSAPP FLUTUANTE ══ -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,32,32" Panel.ZIndex="200" Cursor="Hand" MouseLeftButtonUp="AbrirWhatsApp">
                <Border Width="56" Height="56" CornerRadius="28" HorizontalAlignment="Center"
                        Background="#25D366" Effect="{StaticResource WaShadow}">
                    <Viewbox Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White" Data="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </Canvas>
                    </Viewbox>
                </Border>
                <TextBlock Text="Precisa de ajuda?" FontSize="13" Foreground="#25D366"
                           FontWeight="SemiBold" FontFamily="Segoe UI Semibold"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ══ CONTEÚDO ESQUERDO ══ -->
        <Grid x:Name="LeftPanel" Grid.Column="0" Opacity="0" Margin="40,40,0,40" HorizontalAlignment="Center">
            
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                
                <StackPanel HorizontalAlignment="Center">
                    <Image Source="/Assets/Images/company_logo.png"
                           Width="360" 
                           HorizontalAlignment="Center"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    
                    <Image Source="/Assets/Images/logo_construttor_nobg.png"
                           Width="540"
                           HorizontalAlignment="Center"
                           Stretch="Uniform" 
                           Margin="0,-30,0,24"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </StackPanel>

                <TextBlock Text="Sistema de Gestão Integrado"
                           FontSize="22" Foreground="#94A3B8"
                           FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                
                <Border Width="60" Height="3" Background="#2563EB" HorizontalAlignment="Center" Margin="0,20,0,40"/>

                <TextBlock FontSize="46" FontWeight="Bold" Foreground="White"
                           TextWrapping="Wrap" LineHeight="56" Margin="0,0,0,16" TextAlignment="Center"
                           FontFamily="Segoe UI Bold" MaxWidth="600">
                    <Run Text="Gestão completa para "/>
                    <Run Text="construir" Foreground="#3B82F6"/>
                    <Run Text=" resultados."/>
                </TextBlock>
                <TextBlock FontSize="18" LineHeight="28" Foreground="#94A3B8"
                           TextWrapping="Wrap" Margin="0,0,0,50" TextAlignment="Center" FontFamily="Segoe UI" MaxWidth="500">
                    Soluções inteligentes para gestão de obras, financeiro, suprimentos e muito mais.
                </TextBlock>

                <!-- Features -->
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,32,0">
                        <TextBlock Text="🛡️" FontSize="24" Foreground="#3B82F6" Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Seguro" FontWeight="SemiBold" FontSize="15" Foreground="White" FontFamily="Segoe UI Semibold"/>
                            <TextBlock Text="Seus dados protegidos&#10;com criptografia" FontSize="13" Foreground="#94A3B8" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,32,0">
                        <TextBlock Text="⏱️" FontSize="24" Foreground="#3B82F6" Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Rápido" FontWeight="SemiBold" FontSize="15" Foreground="White" FontFamily="Segoe UI Semibold"/>
                            <TextBlock Text="Acesso ágil e&#10;desempenho otimizado" FontSize="13" Foreground="#94A3B8" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="☁️" FontSize="24" Foreground="#3B82F6" Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Conectado" FontWeight="SemiBold" FontSize="15" Foreground="White" FontFamily="Segoe UI Semibold"/>
                            <TextBlock Text="Informações integradas&#10;em tempo real" FontSize="13" Foreground="#94A3B8" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Column="0" Text="© 2025 ConstruTTor. Todos os direitos reservados."
                   Foreground="#64748B" FontSize="13" FontFamily="Segoe UI" 
                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,32" Opacity="0.8"/>

        <Rectangle Grid.Column="0" Height="50" VerticalAlignment="Top"
                   Fill="Transparent" Panel.ZIndex="100"
                   MouseDown="Border_MouseDown"/>
    </Grid>
</Window>