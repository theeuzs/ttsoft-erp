<Window x:Class="ERP.WPF.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login - Vila Verde" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Sobrescreve o estilo global de TextBox apenas nesta janela -->
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="#F8FAFC"/>
            <Setter Property="Foreground"   Value="#1E293B"/>
            <Setter Property="BorderBrush"  Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10"/>
            <Setter Property="FontSize"     Value="16"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Sobrescreve o estilo global de PasswordBox apenas nesta janela -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background"   Value="#F8FAFC"/>
            <Setter Property="Foreground"   Value="#1E293B"/>
            <Setter Property="BorderBrush"  Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10"/>
            <Setter Property="FontSize"     Value="16"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="5"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E62A6" CornerRadius="15,0,0,15" Padding="40">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="/Assets/Images/company_logo.png"
                           Stretch="Uniform" MaxHeight="280" MaxWidth="280"
                           HorizontalAlignment="Center" Margin="0,0,0,20"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True">
                        <Image.Effect>
                            <DropShadowEffect ShadowDepth="2" Direction="270" Color="Black" Opacity="0.3" BlurRadius="5"/>
                        </Image.Effect>
                    </Image>
                    <Separator Margin="0,20,0,30" Background="#60A5FA" Height="2" Opacity="0.5"/>
                    <TextBlock Text="Sistema de Gestão Integrado" FontSize="16" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="40">
                <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="0" Foreground="#94A3B8"
                        FontSize="16" Cursor="Hand" Click="BtnSair_Click"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Acesso ao Sistema" FontSize="24" FontWeight="Bold"
                               Foreground="#1E293B" Margin="0,0,0,30"/>

                    <TextBlock Text="Usuário" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Usuario, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,15"/>

                    <TextBlock Text="Senha" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtSenha" PasswordChanged="TxtSenha_PasswordChanged"
                                 Margin="0,0,0,20"/>

                    <TextBlock Text="{Binding MensagemErro}" Foreground="#DC2626" FontWeight="SemiBold"
                               Visibility="{Binding TemErro, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                               Margin="0,0,0,15" HorizontalAlignment="Center"/>

                    <Button Content="ENTRAR" Command="{Binding LoginCommand}"
                            Height="50" FontSize="16" FontWeight="Bold"
                            Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
