<Window x:Class="ERP.WPF.Views.OpcoesImpressaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formato de Impressão" Height="220" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="ToolWindow" Background="#F8F9FA">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
        <TextBlock Text="Como deseja imprimir este orçamento?" FontSize="16" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,25" HorizontalAlignment="Center"/>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="📄 Folha A4" Width="140" Height="50" Margin="0,0,15,0" 
                    FontSize="15" FontWeight="Bold" Background="#2980B9" Foreground="White" 
                    Cursor="Hand" BorderThickness="0" Click="BtnA4_Click"/>
            
            <Button Content="🧾 Cupom Térmico" Width="140" Height="50" 
                    FontSize="15" FontWeight="Bold" Background="#E67E22" Foreground="White" 
                    Cursor="Hand" BorderThickness="0" Click="BtnCupom_Click"/>
        </StackPanel>
    </StackPanel>
</Window>