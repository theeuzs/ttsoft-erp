<UserControl x:Class="ERP.WPF.Views.SaleView"
             xmlns:conv="clr-namespace:ERP.WPF.Converters"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource FundoGeral}" FontFamily="Segoe UI">

    <UserControl.Resources>
        <conv:RoleToVisibilityConverter x:Key="RoleToVisibilityConverter"/>
        <SolidColorBrush x:Key="TtBlue" Color="#1E62A6"/>
        <SolidColorBrush x:Key="TtSilver" Color="#8A939C"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#27AE60"/>


        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TtBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Histórico de Vendas" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TtBlue}"/>
                <TextBlock Text="Acompanhe o faturamento e as saídas do caixa" FontSize="14" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                
                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BordaInput}" BorderThickness="1" CornerRadius="6" Margin="0,0,12,0" Width="240">
                    <Grid>
                        <TextBlock Text="🔍 Buscar Cliente ou Nº Venda..." Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText.Length, FallbackValue=0}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" BorderThickness="0" VerticalAlignment="Center" 
                                 FontSize="14" Foreground="{DynamicResource TextDark}" Padding="10,6"/>
                    </Grid>
                </Border>
                
                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BordaInput}" BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,12,0">
                    <ComboBox SelectedValue="{Binding SelectedPaymentFilter}" SelectedValuePath="Content" Width="150" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource TextDark}">
                        <ComboBoxItem Content="Todas as Formas"/>
                        <ComboBoxItem Content="Dinheiro"/>
                        <ComboBoxItem Content="PIX"/>
                        <ComboBoxItem Content="Cartão de Crédito"/>
                        <ComboBoxItem Content="Cartão de Débito"/>
                    </ComboBox>
                </Border>

                <StackPanel Orientation="Horizontal" Background="{DynamicResource CardBg}" Margin="0,0,12,0">
                    <Border BorderBrush="{DynamicResource BordaInput}" BorderThickness="1" CornerRadius="6,0,0,6" Padding="8,4">
                        <DatePicker SelectedDate="{Binding StartDate}" Width="110" BorderThickness="0" Background="Transparent"/>
                    </Border>
                    <Border BorderBrush="{DynamicResource BordaInput}" BorderThickness="0,1,1,1" CornerRadius="0,6,6,0" Padding="8,4">
                        <DatePicker SelectedDate="{Binding EndDate}" Width="110" BorderThickness="0" Background="Transparent"/>
                    </Border>
                </StackPanel>

                <Button Content="FILTRAR" Command="{Binding FilterCommand}" Style="{StaticResource PrimaryButton}" Padding="24,10"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/> <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/> <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}"
                    Visibility="{Binding Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=report.financial}">
                <StackPanel>
                    <TextBlock Text="Faturamento Válido do Período" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding FaturamentoExibicao}" FontSize="28" FontWeight="Black" Foreground="{StaticResource SuccessGreen}"/>
                        <Button Grid.Column="1" Content="👁" Command="{Binding AlternarFaturamentoCommand}"
                                Background="Transparent" BorderThickness="0" FontSize="18" Cursor="Hand"
                                VerticalAlignment="Center" ToolTip="Mostrar/ocultar faturamento"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Vendas Realizadas" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding TotalSalesCount, StringFormat='{}{0} Pedidos'}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TtBlue}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20" Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Ticket Médio" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding AverageTicket, StringFormat='R$ {0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextDark}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource CardBg}" CornerRadius="12" Effect="{DynamicResource CardShadow}">
            <DataGrid ItemsSource="{Binding SalesList}" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="Transparent" BorderThickness="0" CanUserAddRows="False"
                      SelectionMode="Single" RowHeight="52" Margin="12"
                      GridLinesVisibility="None" RowBackground="Transparent" AlternatingRowBackground="{DynamicResource CardBgAlt}">
                
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TtBlue}"/>
                        <Setter Property="Padding" Value="12,12,12,12"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EBF4FF"/>
                                <Setter Property="Foreground" Value="{StaticResource TtBlue}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="CÓD. VENDA" Binding="{Binding SaleNumber}" Width="100"/>
                    <DataGridTextColumn Header="DATA / HORA" Binding="{Binding SaleDate, StringFormat='dd/MM/yyyy HH:mm'}" Width="150"/>
                    
                    <DataGridTemplateColumn Header="PAGAMENTO" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBgAlt}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding PaymentMethods}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Cancelada">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="TOTAL" Binding="{Binding Total, StringFormat='R$ {0:N2}'}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#27AE60"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="AÇÕES" Width="Auto" MinWidth="330">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="👀 Visualizar" 
                                            Command="{Binding DataContext.VisualizarReciboCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#3B82F6" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,0,5,0" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                    </Button>
                                    
                                    <Button Content="🖨️ Imprimir" 
                                            Command="{Binding DataContext.ReimprimirReciboCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#10B981" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,0,5,0" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                    </Button>

                                    <Button Content="❌ Cancelar" 
                                            Command="{Binding DataContext.CancelarVendaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#EF4444" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,0,5,0" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                    </Button>

                                    <!-- S17: WhatsApp e Devolver mudaram pra cá, dentro do menu de
                                         "mais ações" — com o botão de NFC-e/NF-e que vem depois,
                                         a linha ficaria grande demais em monitor pequeno. -->
                                    <ToggleButton x:Name="BtnMaisAcoes" Content="•••" Width="36"
                                                  Background="{DynamicResource CardBgAlt}" Foreground="{DynamicResource TextDark}"
                                                  BorderThickness="1" BorderBrush="{DynamicResource BordaInput}" Cursor="Hand">
                                        <ToggleButton.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></ToggleButton.Resources>
                                    </ToggleButton>

                                    <Popup PlacementTarget="{Binding ElementName=BtnMaisAcoes}"
                                           IsOpen="{Binding IsChecked, ElementName=BtnMaisAcoes}"
                                           StaysOpen="False" Placement="Bottom" AllowsTransparency="True">
                                        <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BordaInput}" BorderThickness="1"
                                                CornerRadius="6" Padding="6">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" Opacity="0.15" ShadowDepth="2"/>
                                            </Border.Effect>
                                            <StackPanel Width="160">
                                                <Button Content="💬 WhatsApp" HorizontalContentAlignment="Left"
                                                        Command="{Binding DataContext.EnviarWhatsAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" Foreground="{DynamicResource TextDark}" BorderThickness="0" Padding="8,6" Cursor="Hand"/>
                                                <Button Content="↩ Devolver Itens" HorizontalContentAlignment="Left"
                                                        Command="{Binding DataContext.DevolverItensCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" Foreground="{DynamicResource TextDark}" BorderThickness="0" Padding="8,6" Cursor="Hand"/>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>