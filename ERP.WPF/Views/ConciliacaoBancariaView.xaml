<UserControl x:Class="ERP.WPF.Views.ConciliacaoBancariaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBgAlt}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="CONCILIAÇÃO BANCÁRIA" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextDark}" Margin="0,0,0,20"/>

        <!-- Escolha da conta + importar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0" ItemsSource="{Binding Contas}" SelectedItem="{Binding ContaSelecionada}"
                      DisplayMemberPath="Apelido" Height="38" VerticalContentAlignment="Center"/>

            <Button Grid.Column="2" Content="📄 IMPORTAR EXTRATO OFX" Command="{Binding ImportarArquivoCommand}"
                    Background="#3B82F6" Foreground="White" FontWeight="Bold" Height="38" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Resumo -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TotalLinhas}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <Border Background="{DynamicResource CardBg}" Padding="12,8" CornerRadius="6" Margin="0,0,10,0">
                <TextBlock>
                    <Run Text="{Binding TotalLinhas, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" linhas no extrato"/>
                </TextBlock>
            </Border>
            <Border Background="#EAF6EC" Padding="12,8" CornerRadius="6" Margin="0,0,10,0">
                <TextBlock Foreground="#166534">
                    <Run Text="{Binding TotalComSugestao, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" com sugestão automática"/>
                </TextBlock>
            </Border>
            <Border Background="#FDF3E7" Padding="12,8" CornerRadius="6">
                <TextBlock Foreground="#92400E">
                    <Run Text="{Binding TotalSemSugestao, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" sem sugestão — precisa decidir"/>
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- Lista de linhas do extrato -->
        <ItemsControl Grid.Row="3" ItemsSource="{Binding Sugestoes}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="Bold">
                                    <Run Text="{Binding Data, StringFormat=dd/MM/yyyy}"/>
                                    <Run Text=" — "/>
                                    <Run Text="{Binding Descricao}"/>
                                </TextBlock>
                                <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,4,0,0">
                                    <Run Text="Valor no extrato: "/>
                                    <Run Text="{Binding Valor, StringFormat=C2}" FontWeight="SemiBold"/>
                                </TextBlock>

                                <!-- Quando existe sugestão automática -->
                                <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="#166534"
                                           Visibility="{Binding TemSugestao, Converter={StaticResource BoolToVisibility}}">
                                    <Run Text="✓ Já existe no sistema: "/>
                                    <Run Text="{Binding MovimentoSugeridoDescricao}"/>
                                    <Run Text=" ("/>
                                    <Run Text="{Binding MovimentoSugeridoData, StringFormat=dd/MM/yyyy}"/>
                                    <Run Text=")"/>
                                </TextBlock>

                                <!-- Quando não há sugestão -->
                                <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="#92400E"
                                           Visibility="{Binding SemSugestao, Converter={StaticResource BoolToVisibility}}">
                                    <Run Text="Sem correspondência automática ("/>
                                    <Run Text="{Binding QuantidadeCandidatos}"/>
                                    <Run Text=" candidatos parecidos) — confirme manualmente ou cadastre como novo."/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button Content="✓ CONFIRMAR MATCH"
                                        Command="{Binding DataContext.ConfirmarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="#16A34A" Foreground="White" FontWeight="Bold" Height="34" Cursor="Hand"
                                        Visibility="{Binding TemSugestao, Converter={StaticResource BoolToVisibility}}"/>

                                <Button Content="+ CRIAR NOVO LANÇAMENTO"
                                        Command="{Binding DataContext.CriarNovoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="{DynamicResource CardBgAlt}" Foreground="{DynamicResource TextDark}"
                                        BorderBrush="{DynamicResource BordaInput}" Height="34" Cursor="Hand"
                                        Visibility="{Binding SemSugestao, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
