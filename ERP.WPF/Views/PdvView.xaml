<UserControl x:Class="ERP.WPF.Views.PdvView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ERP.WPF.Converters"
             Background="{DynamicResource FundoGeral}" FontFamily="Segoe UI"
             PreviewKeyDown="UserControl_PreviewKeyDown"> 
    <UserControl.Resources>
        <conv:EqualConverter          x:Key="EqualConverter"/>
        <conv:PercentToColorConverter x:Key="PercentToColorConverter"/>
        <conv:PercentToWidthConverter x:Key="PercentToWidthConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CorAcento}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GreenButton" BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="#334155" Padding="40" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding CaixaFechadoVisivel}">
            <Border.Effect><DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="5"/></Border.Effect>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🔒" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="O CAIXA ESTÁ FECHADO" Foreground="White" FontWeight="Black" FontSize="28" HorizontalAlignment="Center"/>
                <TextBlock Text="Abra o caixa para iniciar as vendas." Foreground="#CBD5E1" FontSize="16" HorizontalAlignment="Center" Margin="0,5,0,30"/>
                <Button Content="✓ ABRIR CAIXA" Command="{Binding MostrarTelaAbrirCaixaCommand}" Background="#22C55E" Foreground="White" FontWeight="Bold" FontSize="18" Padding="40,15" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                    <Button.Resources><Style TargetType="Border"> <Setter Property="CornerRadius" Value="8"/> </Style></Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Grid Visibility="{Binding CaixaAbertoVisivel}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>  
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource CorPrimaria}" Padding="15,10" Margin="24,24,24,0" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding MostrarResumoCaixaCommand}" Background="#064E3B" BorderBrush="#10B981" BorderThickness="1" Foreground="#34D399" Padding="20,8" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        <Grid MinWidth="200">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ValorAtualCaixa, StringFormat='MEU CAIXA - R$ {0:N2}'}" FontWeight="Black" FontSize="14"/>
                                <TextBlock Text="📊 Clique para Resumo" FontSize="11" Opacity="0.8" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#F59E0B" CornerRadius="4" Padding="8,4" Margin="15,0,0,0" VerticalAlignment="Center" Visibility="{Binding ModoContingenciaVisivel, FallbackValue=Collapsed}">
                                <Border.ToolTip><ToolTip Content="O sistema está em modo de contingência. As notas serão enviadas assim que a conexão retornar."/></Border.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📡" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="OFFLINE" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Button>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Click="BtnTema_Click"
                                Content="🎨 Personalizar"
                                Background="#1E293B" Foreground="#94A3B8"
                                BorderThickness="0" Padding="15,8" Margin="0,0,8,0"
                                Cursor="Hand" FontWeight="Bold"
                                ToolTip="Personalizar cores e tema do sistema">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="BtnLicenca" Click="BtnLicenca_Click"
                                Content="🛡️ Licença de Uso"
                                Background="#1E293B" Foreground="#94A3B8"
                                BorderThickness="0" Padding="15,8" Margin="0,0,15,0"
                                Cursor="Hand" FontWeight="Bold"
                                ToolTip="Ver detalhes da licença do sistema">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Ponto de Venda" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource CorAcento}" Margin="0,0,0,12"/>

                    <Border Grid.Row="1" Margin="0,0,0,12" Padding="14,10" CornerRadius="8"
                            Background="{DynamicResource CardBg}"
                            Visibility="{Binding TemMeta, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding TextoMeta}" FontSize="12"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextDark}"
                                       Margin="0,0,0,6"/>
                            <Border Grid.Row="1" Height="8" CornerRadius="4"
                                    Background="{DynamicResource BordaInput}">
                                <Border HorizontalAlignment="Left" CornerRadius="4"
                                        Background="{Binding PercentualMeta, Converter={StaticResource PercentToColorConverter}}">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                            <Binding Path="PercentualMeta"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Background="{DynamicResource CardBg}" CornerRadius="12" Margin="0,0,0,24" Effect="{DynamicResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> 
                            </Grid.ColumnDefinitions>
                            
                            <TextBox x:Name="TxtBuscaProduto" Grid.Column="0" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged, Delay=300}" 
                                     PreviewKeyDown="TxtBuscaProduto_PreviewKeyDown" 
                                     Margin="0,0,12,0" Padding="8" FontSize="14" VerticalContentAlignment="Center" 
                                     Background="{DynamicResource FundoInput}" Foreground="{DynamicResource TextDark}" BorderBrush="{DynamicResource BordaInput}" TabIndex="0"/>

                            <Button Grid.Column="1" Command="{Binding ToggleViewCommand}" Width="45" Height="40" Background="{DynamicResource FundoInput}" BorderBrush="{DynamicResource BordaInput}" Margin="0,0,12,0" Cursor="Hand" BorderThickness="1" TabIndex="2">
                                <Button.Resources><Style TargetType="Border"> <Setter Property="CornerRadius" Value="6"/> </Style></Button.Resources>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Content" Value="🔲"/>
                                        <Setter Property="ToolTip" Value="Mudar para Visualização em Grade"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGridView}" Value="True">
                                                <Setter Property="Content" Value="📋"/>
                                                <Setter Property="ToolTip" Value="Mudar para Visualização em Lista"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Column="2" Content="BUSCAR" Command="{Binding SearchProductCommand}" Style="{StaticResource PrimaryButton}" Width="100" Height="40" TabIndex="3"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" Background="{DynamicResource CardBg}" CornerRadius="12" Effect="{DynamicResource CardShadow}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6" IsHitTestVisible="False">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=GridPesquisa, Path=HasItems}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Image Source="/Assets/TTSOFT.png" Width="280" Margin="0,0,0,16" Stretch="Uniform"/>
                                <TextBlock Text="Tecnologia que impulsiona suas vendas." FontSize="20" FontWeight="Bold" Foreground="{DynamicResource CorAcento}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <DataGrid x:Name="GridPesquisa" FocusVisualStyle="{x:Null}" ItemsSource="{Binding SearchResults}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" CanUserAddRows="False" SelectionMode="Single" RowHeight="48" Margin="8" GridLinesVisibility="None" RowBackground="Transparent" AlternatingRowBackground="{DynamicResource CardBgAlt}" Foreground="{DynamicResource TextDark}">
                                <DataGrid.Style>
                                    <Style TargetType="DataGrid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGridView}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Style>
                                
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#154360"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource CorAcento}"/>
                                        <Setter Property="Padding" Value="12,12,12,8"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BordaCard}"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="90">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="Padding" Value="8,0,0,0"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Margin" Value="8,0,0,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="PRODUTO" Binding="{Binding Name}" Width="*">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="Padding" Value="8,0,0,0"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Margin" Value="8,0,0,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="UN." Binding="{Binding Unit}" Width="55">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="ESTOQUE" Binding="{Binding Stock, StringFormat='N2'}" Width="90">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                                <Setter Property="Padding" Value="0,0,10,0"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="0,0,10,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="PREÇO" Binding="{Binding SalePrice, StringFormat='R$ {0:N2}'}" Width="115">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                                <Setter Property="Padding" Value="0,0,10,0"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="#27AE60"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="0,0,10,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="QTD" Width="90">
                                        <DataGridTemplateColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTemplateColumn.HeaderStyle>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox x:Name="TxtQuantidadeInline"
                                                         Text="{Binding QuantidadeGrade, UpdateSourceTrigger=LostFocus, ConverterCulture=pt-BR}"
                                                         KeyDown="TxtQuantidadeInline_KeyDown"
                                                         PreviewTextInput="TxtQuantidade_PreviewTextInput"
                                                         Width="70" Height="30" TextAlignment="Center" VerticalContentAlignment="Center"
                                                         HorizontalAlignment="Center"
                                                         Background="{DynamicResource FundoInput}" Foreground="{DynamicResource TextDark}" BorderBrush="{DynamicResource BordaInput}" FontWeight="Bold"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <ListBox x:Name="GridPesquisa_Cards" FocusVisualStyle="{x:Null}" ItemsSource="{Binding SearchResults}" Background="Transparent" BorderThickness="0" Margin="8" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGridView}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="6"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="BorderBrush" Value="#F59E0B"/> 
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource CardBg}" CornerRadius="8" Width="170" Height="140" Padding="12" Cursor="Hand" BorderThickness="1" BorderBrush="{DynamicResource BordaCard}">
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <StackPanel>
                                                <TextBlock Text="🧱" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextDark}" FontWeight="Bold" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Height="36" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding SalePrice, StringFormat='R$ {0:N2}'}" Foreground="#27AE60" FontWeight="Black" FontSize="16" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                                <TextBlock Text="{Binding Stock, StringFormat='Estoque: {0:N2}'}" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="1" Background="{DynamicResource CardBg}" Margin="0,24,24,24" CornerRadius="16" Effect="{DynamicResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/> <RowDefinition Height="Auto"/> 
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource CorAcento}" CornerRadius="16,16,0,0" Padding="20">
                            <Grid>
                                <TextBlock Text="🛒 Carrinho de Vendas" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" >
                                    <Button Content="📈↑" Cursor="Hand"
                                            Command="{Binding AplicarMarkup5Command}"
                                            Margin="0,0,12,0"
                                            ToolTip="Aplica 5% de markup em todos os itens e arredonda para R$0,50 ou R$1,00">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="#A5D6A7" FontWeight="SemiBold" VerticalAlignment="Center" x:Name="BtnMk"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnMk" Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="⏸" Cursor="Hand"
                                            Command="{Binding SuspenderVendaCommand}"
                                            Margin="0,0,12,0"
                                            ToolTip="Suspende esta venda e libera o caixa para o próximo cliente">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="#FFF9C4"
                                                           FontWeight="SemiBold" VerticalAlignment="Center" x:Name="BtnSusp"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnSusp" Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Grid Margin="0,0,12,0">
                                        <Button Content="📋" Cursor="Hand"
                                                Command="{Binding AbrirVendasSuspensasCommand}"
                                                ToolTip="Ver vendas suspensas (de todos os operadores)">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="#BBDEFB"
                                                               FontWeight="SemiBold" VerticalAlignment="Center" x:Name="BtnLista"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnLista" Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Ellipse Width="10" Height="10" Fill="#F59E0B" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                 Margin="0,-4,-4,0" IsHitTestVisible="False"
                                                 Visibility="{Binding TemVendasSuspensas, Converter={StaticResource BoolToVisibility}}"/>
                                    </Grid>
                                    <Button Content="Limpar Tudo" Cursor="Hand" Command="{Binding ClearCartCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}" Foreground="#FFCDD2" FontWeight="SemiBold" VerticalAlignment="Center" x:Name="BtnText"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnText" Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{DynamicResource FundoRodape}" BorderBrush="{DynamicResource BordaRodape}" BorderThickness="0,0,0,1" Padding="15" Panel.ZIndex="10">
                                <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="IDENTIFICAR CLIENTE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource CorAcento}" Opacity="0.7"/>
                                        
                                        <TextBox x:Name="TxtBuscaCliente" Text="{Binding CustomerSearchTerm, UpdateSourceTrigger=PropertyChanged, Delay=300}" Margin="0,4,8,0" Padding="8" BorderThickness="1" Background="{DynamicResource FundoInput}" Foreground="{DynamicResource TextDark}" BorderBrush="{DynamicResource BordaInput}" FontSize="14" VerticalContentAlignment="Center">
                                            <TextBox.Resources>
                                                <Style TargetType="{x:Type Border}"> <Setter Property="CornerRadius" Value="4"/> </Style>
                                            </TextBox.Resources>
                                        </TextBox>
                                        
                                        <Popup AllowsTransparency="True" IsOpen="{Binding ElementName=ListClientes, Path=HasItems, Mode=OneWay}" PlacementTarget="{Binding ElementName=TxtBuscaCliente}" StaysOpen="False" MinWidth="{Binding ElementName=TxtBuscaCliente, Path=ActualWidth}">
                                            <Border Background="{DynamicResource FundoPopup}" BorderBrush="{DynamicResource BordaPopup}" BorderThickness="1" CornerRadius="4" Margin="0,2,8,0" MaxHeight="200">
                                                <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/></Border.Effect>
                                                <ListBox x:Name="ListClientes" ItemsSource="{Binding CustomerSearchResults}" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="Margin" Value="0"/>
                                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BordaPopup}"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource RowSelectedBg}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource HoverPopup}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="10,8" Cursor="Hand" Background="Transparent">
                                                                <Border.InputBindings>
                                                                    <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                                </Border.InputBindings>
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextDark}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Popup>

                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SelectedCustomerName}" FontSize="12" FontWeight="SemiBold" Foreground="#27AE60" VerticalAlignment="Center"/>
                                            <!-- Sprint C: badge do grupo de preço -->
                                            <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center"
                                                    Background="#EDE9FE" Visibility="{Binding LabelGrupoPreco, Converter={StaticResource NullToCollapsed}}">
                                                <TextBlock Text="{Binding LabelGrupoPreco}" FontSize="10" FontWeight="Bold" Foreground="#7C3AED"/>
                                            </Border>
                                            <Button Content="✕"
                                                    Command="{Binding LimparClienteCommand}"
                                                    Margin="8,0,0,0" Padding="5,2"
                                                    FontSize="11" FontWeight="Bold"
                                                    Background="#EF4444" Foreground="White"
                                                    BorderThickness="0" Cursor="Hand"
                                                    ToolTip="Remover cliente — volta para Consumidor Final">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TemClienteSelecionado}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="BUSCAR" Command="{Binding SearchCustomerCommand}" Style="{StaticResource PrimaryButton}" Width="80" Height="38" VerticalAlignment="Top" Margin="0,18,0,0"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding ClientesFrequentes}" Margin="0,8,0,0">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasClientesFrequentes}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,6,4" Padding="8,4"
                                                    Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource FundoInput}"
                                                    Foreground="{DynamicResource TextDark}"
                                                    BorderBrush="{DynamicResource BordaInput}"
                                                    BorderThickness="1" Cursor="Hand" FontSize="11">
                                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                                <TextBlock Text="{Binding Name}" MaxWidth="110" TextTrimming="CharacterEllipsis"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </StackPanel>
                            </Border>

                            <ScrollViewer x:Name="CartScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0" ScrollChanged="CartScrollViewer_ScrollChanged">
                                <ItemsControl ItemsSource="{Binding CartItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Margin="12,6,12,6" Padding="12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource CardBgAlt}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BordaCard}"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsWholesaleActive}" Value="True">
                                                                <Setter Property="Background" Value="#1A27AE60"/>
                                                                <Setter Property="BorderBrush" Value="#27AE60"/>
                                                            </DataTrigger>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource EqualConverter}">
                                                                        <Binding Path="ProductId"/>
                                                                        <Binding Path="DataContext.UltimoItemId" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="BorderBrush" Value="#F59E0B"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                                <Setter Property="Background" Value="#1AF59E0B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/> <RowDefinition Height="8"/> <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <Grid Grid.Row="0">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                                                            <TextBlock Text="{Binding ProductName}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextDark}" TextWrapping="Wrap"/>
                                                            
                                                            <TextBlock Text=" (ATACADO)" FontWeight="Bold" FontSize="12" Foreground="#27AE60" VerticalAlignment="Center" Margin="5,0,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsWholesaleActive}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            
                                                            <Button Content="💡" 
                                                                    Command="{Binding DataContext.AbrirSugestoesItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                    CommandParameter="{Binding ProductId}"
                                                                    Visibility="{Binding HasSuggestions, Converter={StaticResource BoolToVisibility}}"
                                                                    Background="#FEF3C7" Foreground="#CA8A04" FontWeight="Bold" FontSize="11" 
                                                                    Padding="6,2" Margin="10,0,0,0" BorderThickness="1" BorderBrush="#FDE047" Cursor="Hand"
                                                                    VerticalAlignment="Center" ToolTip="Ver produtos sugeridos para este item">
                                                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                                            </Button>
                                                            
                                                        </StackPanel>
                                                        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="#E74C3C" BorderThickness="0" Cursor="Hand" FontSize="14" FontWeight="Bold" Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                    </Grid>
                                                    
                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="100"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <TextBlock Grid.Column="0" Text="Qtd:" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        
                                                        <Grid Grid.Column="1" Margin="0,0,8,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="36"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Button Grid.Column="0" Content="-" Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="24" Height="24" Background="{DynamicResource FundoInput}" Foreground="{DynamicResource TextDark}" BorderThickness="0" Cursor="Hand">
                                                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4,0,0,4"/></Style></Button.Resources>
                                                            </Button>
                                                            <Border Grid.Column="1" BorderBrush="{DynamicResource BordaCard}" BorderThickness="0,1,0,1" Background="Transparent">
                                                                <TextBox Text="{Binding QuantidadeTexto, UpdateSourceTrigger=PropertyChanged}" 
                                                                         PreviewTextInput="TxtQuantidade_PreviewTextInput"
                                                                         Background="Transparent" BorderThickness="0" TextAlignment="Center" VerticalAlignment="Center" Padding="0" Foreground="{DynamicResource TextDark}"/>
                                                            </Border>
                                                            <Button Grid.Column="2" Content="+" Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="24" Height="24" Background="{DynamicResource FundoInput}" Foreground="{DynamicResource TextDark}" BorderThickness="0" Cursor="Hand">
                                                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="0,4,4,0"/></Style></Button.Resources>
                                                            </Button>
                                                        </Grid>

                                                        <TextBlock Grid.Column="2" Text="{Binding UnitPrice, StringFormat='R$ {0:N2}/un'}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="8,0" FontSize="11"/>
                                                        
                                                        <TextBlock Grid.Column="3" Text="{Binding Total, StringFormat='R$ {0:N2}'}" FontWeight="Bold" VerticalAlignment="Center" FontSize="14">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource CorAcento}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsWholesaleActive}" Value="True">
                                                                            <Setter Property="Foreground" Value="#27AE60"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            
                            <Popup AllowsTransparency="True" IsOpen="{Binding MostrarSugestoes}" Placement="Right" PlacementTarget="{Binding ElementName=CartScrollViewer}" StaysOpen="False" HorizontalOffset="-380" VerticalOffset="10">
                                <Border Background="{DynamicResource CardBg}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="0" MaxWidth="350" Margin="20">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" Opacity="0.15" ShadowDepth="4" Color="#0F172A"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        
                                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0" Padding="15,12">
                                            <Grid>
                                                <TextBlock Text="💡 Aproveite e ofereça também:" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource CorAcento}" VerticalAlignment="Center"/>
                                                <Button Content="✕" Command="{Binding FecharSugestoesCommand}" HorizontalAlignment="Right" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" Cursor="Hand" FontWeight="Bold" FontSize="14" ToolTip="Fechar Sugestões"/>
                                            </Grid>
                                        </Border>
                                        
                                        <ItemsControl ItemsSource="{Binding Sugestoes}" Margin="15,12,15,15">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,8" BorderThickness="1" BorderBrush="#E2E8F0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource CorAcento}"/>
                                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                <TextBlock Text="{Binding Nome}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextDark}" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Preco, StringFormat='R$ {0:N2}'}" Foreground="#27AE60" FontWeight="Bold" FontSize="15" Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Content="+ Adicionar" Command="{Binding DataContext.AdicionarSugestaoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="{DynamicResource CorAcento}" Foreground="White" BorderThickness="0" Padding="12,8" Cursor="Hand" FontWeight="Bold" VerticalAlignment="Center">
                                                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        
                                    </StackPanel>
                                </Border>
                            </Popup>
                            
                        </Grid>

                        <Border Grid.Row="2" Background="{DynamicResource FundoRodape}" Padding="20" CornerRadius="0,0,16,16" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BordaRodape}">
                            <StackPanel>
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="TOTAL A PAGAR:" Foreground="{DynamicResource TextDark}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Total, StringFormat='R$ {0:N2}'}" HorizontalAlignment="Right" Foreground="#27AE60" FontSize="26" FontWeight="Black"/>
                                        <TextBlock Text="{Binding TotalTributos, StringFormat='Valor Aproximado dos Tributos: R$ {0:N2}'}" HorizontalAlignment="Right" Foreground="#7F8C8D" FontSize="13" Margin="0,2,0,0" FontStyle="Italic"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,15,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="SALVAR ORÇAMENTO" Command="{Binding SalvarOrcamentoCommand}" Background="{DynamicResource CorAcento}" Foreground="White" FontWeight="Bold" FontSize="16" Height="60" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources> <Style TargetType="Border"> <Setter Property="CornerRadius" Value="8"/> </Style> </Button.Resources>
                                    </Button>
                                    <Button Grid.Column="2" Content="FINALIZAR VENDA [V]" Command="{Binding FinalizeSaleCommand}" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="16" Height="60" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources> <Style TargetType="Border"> <Setter Property="CornerRadius" Value="8"/> </Style> </Button.Resources>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>