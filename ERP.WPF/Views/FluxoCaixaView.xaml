<UserControl x:Class="ERP.WPF.Views.FluxoCaixaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBgAlt}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <StackPanel>
                <TextBlock Text="Fluxo de Caixa Projetado" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextDark}"/>
                <TextBlock Text="Entradas e saídas previstas — Contas a Receber vs Contas a Pagar"
                           FontSize="13" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="De:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextMuted}"/>
                <DatePicker SelectedDate="{Binding DataInicio}" Width="120" Height="34"/>
                <TextBlock Text="até" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource TextMuted}"/>
                <DatePicker SelectedDate="{Binding DataFim}" Width="120" Height="34"/>
                <Button Content="↻  Calcular" Command="{Binding CarregarCommand}"
                        Background="{DynamicResource CorAcento}" Foreground="White"
                        FontWeight="Bold" Height="34" Padding="16,0" BorderThickness="0"
                        Margin="12,0,0,0" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- S17 FIX: alerta de saldo negativo — Categoria A, extensão do fix
             de ligar o fluxo ao saldo real. -->
        <Border Grid.Row="2" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="8" Padding="14,10"
                Visibility="{Binding TemAlertaSaldoNegativo, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock VerticalAlignment="Center" Foreground="#991B1B" FontWeight="SemiBold">
                    <Run Text="Seu saldo projetado fica negativo em "/>
                    <Run Text="{Binding PrimeiroDiaNegativo, StringFormat=dd/MM/yyyy}"/>
                    <Run Text=" — considere antecipar recebimento ou renegociar algum pagamento."/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Cards de resumo -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="↑  ENTRADAS PREVISTAS" FontSize="11" FontWeight="Bold" Foreground="#16A34A"/>
                    <TextBlock Text="{Binding TotalEntradas, StringFormat='R$ {0:N2}'}"
                               FontSize="22" FontWeight="Bold" Foreground="#16A34A" Margin="0,8,0,0"/>
                    <TextBlock Text="Contas a receber pendentes" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="↓  SAÍDAS PREVISTAS" FontSize="11" FontWeight="Bold" Foreground="#DC2626"/>
                    <TextBlock Text="{Binding TotalSaidas, StringFormat='R$ {0:N2}'}"
                               FontSize="22" FontWeight="Bold" Foreground="#DC2626" Margin="0,8,0,0"/>
                    <TextBlock Text="Contas a pagar pendentes" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" CornerRadius="12" Padding="20">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#F0FDF4"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SaldoProjetado, Converter={StaticResource NegativoConverter}}" Value="True">
                                <Setter Property="Background" Value="#FEF2F2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="= SALDO PROJETADO" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextDark}"/>
                    <TextBlock Text="{Binding SaldoProjetado, StringFormat='R$ {0:N2}'}"
                               FontSize="22" FontWeight="Bold" Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#16A34A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SaldoProjetado, Converter={StaticResource NegativoConverter}}" Value="True">
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="no período selecionado" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Gráfico de barras -->
        <Border Grid.Row="6" Background="{DynamicResource CardBg}" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="{DynamicResource CorAcento}" CornerRadius="12,12,0,0" Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Saldo por dia" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        <Border Background="#FFFFFF22" CornerRadius="4" Padding="8,2" Margin="12,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="10" Height="10" Background="#4ADE80" CornerRadius="2" Margin="0,0,4,0"/>
                                <TextBlock Text="Positivo" FontSize="10" Foreground="White" VerticalAlignment="Center"/>
                                <Border Width="10" Height="10" Background="#F87171" CornerRadius="2" Margin="12,0,4,0"/>
                                <TextBlock Text="Negativo" FontSize="10" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                <ContentControl x:Name="GraficoContainer" Grid.Row="1" Margin="8"/>
            </Grid>
        </Border>

        <!-- Grade principal: tabela por dia + lançamentos -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Por dia -->
            <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{DynamicResource CorAcento}" CornerRadius="12,12,0,0" Padding="16,12">
                        <TextBlock Text="Por dia" FontSize="13" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Dias}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0"
                              GridLinesVisibility="Horizontal" RowHeight="42"
                              CanUserResizeRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data" Binding="{Binding DataFormatada}" Width="100"/>
                            <DataGridTextColumn Header="Saldo dia" Binding="{Binding SaldoDiaFormatado}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Lançamentos detalhados -->
            <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{DynamicResource CorAcento}" CornerRadius="12,12,0,0" Padding="16,12">
                        <TextBlock Text="Lançamentos detalhados" FontSize="13" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Lancamentos}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0"
                              GridLinesVisibility="Horizontal" RowHeight="42"
                              CanUserResizeRows="False" HeadersVisibility="Column"
                              AlternatingRowBackground="{DynamicResource CardBgAlt}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat=dd/MM/yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TipoTexto}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="*"/>
                            <DataGridTextColumn Header="Valor" Binding="{Binding ValorFormatado}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
