<UserControl x:Class="ERP.WPF.Views.IntegracoesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBgAlt}">
    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BordaInput}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CardBgAlt}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="INTEGRAÇÕES" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextDark}"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Atualizar" Command="{Binding AtualizarCommand}"
                        Style="{StaticResource OutlineButton}" Margin="0,0,10,0"/>
                <Button Content="+ Conectar Mercado Livre" Command="{Binding ConectarMercadoLivreCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>

        <!-- Mensagem de status (erro ou instrução, ex: "autorize no navegador") -->
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource TextMuted}" FontStyle="Italic"
                   Margin="0,0,0,15" TextWrapping="Wrap"
                   Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Lista de canais conectados -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Canais}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource BordaCard}" BorderThickness="1"
                                CornerRadius="6" Padding="20" Margin="0,0,0,15"
                                Effect="{DynamicResource CardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Nome, Mode=OneWay}" FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource TextDark}"/>
                                    <TextBlock Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0">
                                        <Run Text="Tipo: "/><Run Text="{Binding Tipo, Mode=OneWay}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,8,0,0">
                                        <Run Text="Status: " Foreground="{DynamicResource TextMuted}"/>
                                        <Run Text="{Binding StatusConectado, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,4,0,0" Visibility="{Binding Conectado, Converter={StaticResource BoolToVisibility}}">
                                        <Run Text="Conta: " Foreground="{DynamicResource TextMuted}"/>
                                        <Run Text="{Binding ExternalAccountId, Mode=OneWay}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,4,0,0" Visibility="{Binding Conectado, Converter={StaticResource BoolToVisibility}}">
                                        <Run Text="Token: " Foreground="{DynamicResource TextMuted}"/>
                                        <Run Text="{Binding StatusToken, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,4,0,0" Visibility="{Binding Conectado, Converter={StaticResource BoolToVisibility}}">
                                        <Run Text="Última sincronização: " Foreground="{DynamicResource TextMuted}"/>
                                        <Run Text="{Binding StatusUltimaSincronizacao, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Button Content="Sincronizar Agora"
                                            Command="{Binding DataContext.SincronizarAgoraCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}"
                                            Style="{StaticResource OutlineButton}"
                                            Visibility="{Binding Conectado, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
