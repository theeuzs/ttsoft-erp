<UserControl x:Class="ERP.WPF.Views.ComprasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBgAlt}">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- COLUNA ESQUERDA: Novo Pedido -->
        <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="10" Padding="20">
            <StackPanel>
                <TextBlock Text="NOVO PEDIDO DE COMPRA" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextDark}" Margin="0,0,0,16"/>

                <TextBlock Text="Fornecedor *" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
<ComboBox IsEditable="True" 
          Text="{Binding FornecedorNome, UpdateSourceTrigger=PropertyChanged}" 
          ItemsSource="{Binding FornecedoresDisponiveis}"
          Height="36" Padding="8,0" VerticalContentAlignment="Center" 
          BorderBrush="{DynamicResource BordaInput}" Margin="0,0,0,12"/>

                <TextBlock Text="Previsão de Chegada" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                <DatePicker SelectedDate="{Binding DataPrevista}" Height="36" Margin="0,0,0,12"/>

                <TextBlock Text="Observações" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}"
                         Height="60" Padding="8,6" TextWrapping="Wrap" AcceptsReturn="True"
                         BorderBrush="{DynamicResource BordaInput}" Margin="0,0,0,16"/>

                <Separator Margin="0,0,0,12"/>
                <TextBlock Text="ITENS DO PEDIDO" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextDark}" Margin="0,0,0,10"/>

                <!-- Busca produto + qtd + preço -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox Text="{Binding BuscaProduto, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="{DynamicResource BordaInput}"/>
                        <TextBlock IsHitTestVisible="False" Text="Produto..." Foreground="{DynamicResource TextMuted}" FontSize="11"
                                   Margin="10,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BuscaProduto}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ListBox ItemsSource="{Binding ProdutosSugestao}" SelectedItem="{Binding ProdutoSelecionado}"
         MaxHeight="160" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BordaInput}"
         Margin="0,34,0,0" Panel.ZIndex="99" VerticalAlignment="Top" DisplayMemberPath="Name">
    <ListBox.Style>
        <Style TargetType="ListBox">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ProdutosSugestao.Count}" Value="0">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </ListBox.Style>
</ListBox>
                    </Grid>
                    <TextBox Grid.Column="2" Text="{Binding QtdItem, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Padding="6,0" VerticalContentAlignment="Center"
                             BorderBrush="{DynamicResource BordaInput}" ToolTip="Quantidade"/>
                    <TextBox Grid.Column="4" Text="{Binding PrecoItem, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                             Height="34" Padding="6,0" VerticalContentAlignment="Center"
                             BorderBrush="{DynamicResource BordaInput}" ToolTip="Preço unit. (R$)"/>
                </Grid>

                <Button Content="+ Adicionar Item" Command="{Binding AdicionarItemCommand}"
                        Height="34" Background="#0EA5E9" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Margin="0,0,0,10" Cursor="Hand"/>

                <ListView ItemsSource="{Binding ItensNovoPedido}" MaxHeight="160" BorderBrush="{DynamicResource BordaCard}" BorderThickness="1">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produto" DisplayMemberBinding="{Binding ProductName}" Width="150"/>
                            <GridViewColumn Header="Qtd" DisplayMemberBinding="{Binding Quantidade}" Width="45"/>
                            <GridViewColumn Header="Total" Width="70">
                                <GridViewColumn.DisplayMemberBinding>
                                    <Binding Path="Total" StringFormat="C2"/>
                                </GridViewColumn.DisplayMemberBinding>
                            </GridViewColumn>
                            <GridViewColumn Width="30">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" FontSize="10" Background="Transparent" BorderThickness="0"
                                                Foreground="#EF4444" Cursor="Hand"
                                                Command="{Binding DataContext.RemoverItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Border Background="#F0FDF4" CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="TOTAL DO PEDIDO:  " FontWeight="Bold" FontSize="13"/>
                        <TextBlock Text="{Binding TotalNovoPedido, StringFormat=C2}" FontWeight="Bold" FontSize="13" Foreground="#16A34A"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Limpar" Command="{Binding LimparFormCommand}"
                            Height="38" Background="{DynamicResource CardBgAlt}" Foreground="{DynamicResource TextMuted}" BorderBrush="{DynamicResource BordaInput}" Cursor="Hand"/>
                    <Button Grid.Column="2" Content="{Binding TextoBotaoSalvar}" Command="{Binding SalvarPedidoCommand}"
                            Height="38" Background="#16A34A" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- COLUNA DIREITA: Lista de Pedidos -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
    <TextBlock Text="PEDIDOS DE COMPRA" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextDark}"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="↻ Atualizar" Command="{Binding CarregarCommand}"
                Background="#E2E8F0" Foreground="{DynamicResource TextMuted}" BorderThickness="0"
                Padding="12,6" Cursor="Hand" Margin="0,0,8,0"/>
        <Button Content="📄 Exportar PDF" Command="{Binding ExportarPdfCommand}"
                Background="#DC2626" Foreground="White" FontWeight="Bold"
                Height="34" Padding="16,0" BorderThickness="0" Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
            </Button.Resources>
        </Button>
    </StackPanel>
</Grid>

            <DataGrid Grid.Row="2" ItemsSource="{Binding Pedidos}" SelectedItem="{Binding PedidoSelecionado}"
                      AutoGenerateColumns="False" IsReadOnly="True" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BordaCard}"
                      GridLinesVisibility="Horizontal" RowHeight="42" SelectionMode="Single" CanUserResizeRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nº" Binding="{Binding Numero}" Width="100"/>
                    <DataGridTextColumn Header="Fornecedor" Binding="{Binding FornecedorNome}" Width="*"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding DataPedido, StringFormat=dd/MM/yyyy}" Width="90"/>
                    <DataGridTextColumn Header="Previsão" Binding="{Binding DataPrevista, StringFormat=dd/MM/yyyy}" Width="90"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C2}" Width="100"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding StatusTexto}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusTexto}" Value="Enviado">
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusTexto}" Value="Recebido">
                                        <Setter Property="Foreground" Value="#16A34A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusTexto}" Value="Cancelado">
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="4" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="AÇÕES DO PEDIDO SELECIONADO" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="✏️  Editar Pedido" Command="{Binding EditarPedidoCommand}"
                                Height="38" Background="#F59E0B" Foreground="White" FontWeight="Bold"
                                BorderThickness="0" Padding="16,0" Margin="0,0,8,0" Cursor="Hand"/>
                        <Button Content="📤  Marcar como Enviado" Command="{Binding EnviarCommand}"
                                Height="38" Background="#2563EB" Foreground="White" FontWeight="Bold"
                                BorderThickness="0" Padding="16,0" Margin="0,0,8,0" Cursor="Hand"/>
                        <Button Content="📦  Confirmar Recebimento" Command="{Binding ReceberCommand}"
                                Height="38" Background="#16A34A" Foreground="White" FontWeight="Bold"
                                BorderThickness="0" Padding="16,0" Margin="0,0,8,0" Cursor="Hand"/>
                        <Button Content="✕  Cancelar Pedido" Command="{Binding CancelarPedidoCommand}"
                                Height="38" Background="#FEF2F2" Foreground="#DC2626"
                                FontWeight="Bold" BorderBrush="#FECACA" Padding="16,0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
